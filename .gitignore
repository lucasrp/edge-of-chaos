# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db

# Databases (created at runtime)
*.db
*.sqlite

# Secrets (never commit real keys)
secrets/
!.env.example
!models.env.example

# Runtime logs
*.log
*.lock
*.pid

# User-generated content (empty dirs with .gitkeep)
blog/entries/*.md
!blog/entries/.gitkeep
blog/diffs/
!blog/diffs/.gitkeep
