#!/usr/bin/env python3
"""edge-render: Generate all instance files from agent.yaml + templates.

Usage:
    edge-render                          # uses ./agent.yaml
    edge-render --config path/to.yaml    # explicit config
    edge-render --dry-run                # show what would be generated
"""

import argparse
import os
import re
import sys
from datetime import date
from pathlib import Path

import yaml

REPO_ROOT = Path(__file__).resolve().parent.parent


def _render_checklist(items: list[str], fallback: str) -> str:
    """Render a list of strings into a markdown checklist."""
    if not items:
        return fallback
    return "\n".join(f"- {item}" for item in items)


def load_agent_yaml(path: Path) -> dict:
    """Load and validate agent.yaml, apply defaults."""
    with open(path) as f:
        cfg = yaml.safe_load(f)

    # Accept both old field names (pt-BR) and new (English)
    if "missao" in cfg and "mission" not in cfg:
        cfg["mission"] = cfg.pop("missao")
    if "dominio" in cfg and "domain" not in cfg:
        cfg["domain"] = cfg.pop("dominio")
    if "idioma" in cfg and "language" not in cfg:
        cfg["language"] = cfg.pop("idioma")

    required = ["name", "codename", "mission", "voice", "domain"]
    missing = [k for k in required if not cfg.get(k)]
    if missing:
        print(f"ERROR: Missing required fields: {', '.join(missing)}")
        sys.exit(1)

    # Normalize pre_skill/post_skill: accept string (legacy), list, or missing
    pre = cfg.get("pre_skill", [])
    if isinstance(pre, str):
        pre = [pre] if pre.strip() else []
    cfg["pre_skill"] = pre

    post = cfg.get("post_skill", [])
    if isinstance(post, str):
        post = [post] if post.strip() else []
    cfg["post_skill"] = post

    # Apply smart defaults
    cfg.setdefault("language", "pt-BR")
    cfg.setdefault("skill_prefix", cfg["codename"])
    if not cfg.get("skill_prefix"):
        cfg["skill_prefix"] = cfg["codename"]
    cfg.setdefault("tool_prefix", "edge")
    cfg.setdefault("edge_home", f"~/{cfg['codename']}")
    cfg.setdefault("heartbeat_interval", "2h")
    cfg.setdefault("blog_port", 8766)
    cfg.setdefault("blog_auth_enabled", True)
    cfg.setdefault("blog_auth_user", "admin")
    cfg.setdefault("blog_auth_pass", "change-me")
    cfg.setdefault("onboarding_mode", True)
    cfg.setdefault("bio", cfg["mission"])
    cfg.setdefault("character_sketch", cfg.get("voice", "Direct, technical."))
    cfg.setdefault("knowledge_base", "")
    cfg.setdefault("context_dir", "")
    cfg.setdefault("public_url", "")
    cfg.setdefault("repo_owner", "")
    cfg.setdefault("repo_name", cfg["name"])
    cfg.setdefault("org_name", cfg["name"])
    cfg.setdefault("org_short", cfg["codename"].upper())
    cfg.setdefault("heartbeat_prompt",
        f"Check state, analyze context, execute the highest-impact action for: {cfg['mission']}")
    cfg.setdefault("kb_type", "local")
    cfg.setdefault("kb_refresh", "on-start")
    cfg.setdefault("timezone", "America/Sao_Paulo")

    # Resolve blog_host
    blog_host = cfg.get("blog_host", "0.0.0.0")
    if blog_host == "auto":
        is_vps = not os.environ.get("DISPLAY") and sys.platform == "linux"
        cfg["blog_host"] = "0.0.0.0" if is_vps else "127.0.0.1"
    else:
        cfg["blog_host"] = blog_host

    # Compute derived values
    cfg["edge_home_expanded"] = os.path.expanduser(cfg["edge_home"])
    cfg["user_home"] = str(Path.home())

    interval_map = {"30min": 1800, "1h": 3600, "2h": 7200, "24h": 86400}
    cfg["heartbeat_seconds"] = interval_map.get(cfg["heartbeat_interval"], 7200)

    systemd_map = {"30min": "30min", "1h": "1h", "2h": "2h", "24h": "24h"}
    cfg["systemd_interval"] = systemd_map.get(cfg["heartbeat_interval"], "2h")

    # Memory project dir (Claude Code convention)
    edge_abs = os.path.expanduser(cfg["edge_home"]).rstrip("/")
    cfg["memory_project_dir"] = edge_abs.replace("/", "-").lstrip("-")

    return cfg


def build_placeholder_map(cfg: dict) -> dict:
    """Map agent.yaml fields to {{ PLACEHOLDER }} names.

    EVERY placeholder used in ANY .tpl file must be here.
    """
    today = date.today().strftime("%Y-%m-%d")
    return {
        # Identity
        "AGENT_NAME": cfg["name"],
        "CODENAME": cfg["codename"],
        "AGENT_MISSION": cfg["mission"],
        "AGENT_VOICE": cfg["voice"],
        "AGENT_DOMAIN": cfg["domain"],
        "AGENT_BIO": cfg["bio"],
        "CHARACTER_SKETCH": cfg["character_sketch"],
        "LANGUAGE": cfg["language"],
        # Org
        "ORG_NAME": cfg["org_name"],
        "ORG_SHORT": cfg["org_short"],
        # Prefixes
        "SKILL_PREFIX": cfg["skill_prefix"],
        "TOOL_PREFIX": cfg["tool_prefix"],
        # Paths
        "WORK_DIR": cfg["edge_home_expanded"],
        "USER_HOME": cfg["user_home"],
        "MEMORY_PROJECT_DIR": cfg["memory_project_dir"],
        # Blog
        "BLOG_PORT": str(cfg["blog_port"]),
        "BLOG_HOST": cfg["blog_host"],
        "BLOG_AUTH_ENABLED": str(cfg["blog_auth_enabled"]).lower(),
        "BLOG_AUTH_USER": cfg["blog_auth_user"],
        "BLOG_AUTH_PASS": cfg["blog_auth_pass"],
        # Heartbeat
        "HEARTBEAT_INTERVAL": cfg["heartbeat_interval"],
        "HEARTBEAT_SECONDS": str(cfg["heartbeat_seconds"]),
        "SYSTEMD_INTERVAL": cfg["systemd_interval"],
        "HEARTBEAT_PROMPT": cfg["heartbeat_prompt"],
        # Knowledge base
        "KB_PATH": cfg["knowledge_base"],
        "CONTEXT_DIR": cfg["context_dir"],
        "KB_TYPE": cfg["kb_type"],
        "KB_REFRESH": cfg["kb_refresh"],
        # Lifecycle hooks (rendered from lists)
        "PRE_SKILL_CHECKLIST": _render_checklist(
            cfg["pre_skill"],
            "_(no pre-skill actions configured — add items to `pre_skill` in agent.yaml)_",
        ),
        "POST_SKILL_CHECKLIST": _render_checklist(
            cfg["post_skill"],
            "_(no post-skill actions configured — add items to `post_skill` in agent.yaml)_",
        ),
        # Repo
        "REPO_OWNER": cfg["repo_owner"],
        "REPO_NAME": cfg["repo_name"],
        # Computed
        "DATE": today,
        "USER_TIMEZONE": cfg["timezone"],
        # Phenotype content (defaults, operator customizes post-install)
        "VOICE": cfg["voice"],
        "PROJECT_CONTEXT": "(no projects configured — updated by /reflexao)",
        "SHARED_PROFILE": cfg["bio"],
        "INTERESTS_TABLE": "| Area | Connection |\n|------|--------|\n| (TBD) | (TBD) |",
        "INTERSECTION_EXAMPLES": "- (TBD after domain reconnaissance)",
        "PHASE": "Onboarding" if cfg.get("onboarding_mode") else "Operational",
        "HORIZON": "2 weeks",
        "FOCUS": cfg["mission"],
        "CONSTRAINTS": "(none defined)",
        "PRIORITY_1": cfg["mission"],
        "PRIORITY_2": "Understand the domain",
        "PRIORITY_3": "Deliver first quick win",
    }


def render_template(content: str, placeholders: dict) -> str:
    """Replace {{ KEY }} and {{KEY}} with values from placeholder map."""
    for key, val in placeholders.items():
        content = content.replace(f"{{{{ {key} }}}}", str(val))
        content = content.replace(f"{{{{{key}}}}}", str(val))
    return content


def find_templates(repo_root: Path) -> list[Path]:
    """Find all .tpl files in the repo."""
    return sorted(repo_root.rglob("*.tpl"))


def render_all(repo_root: Path, placeholders: dict, dry_run: bool = False) -> list[str]:
    """Render all templates, write output files."""
    templates = find_templates(repo_root)
    results = []

    for tpl in templates:
        rel = tpl.relative_to(repo_root)
        if any(p.startswith(".") or p == "node_modules" for p in rel.parts):
            continue

        content = tpl.read_text()
        rendered = render_template(content, placeholders)

        out_path = tpl.with_suffix("")

        residuals = re.findall(r"\{\{[^}]+\}\}", rendered)

        if dry_run:
            status = "WARN" if residuals else "OK"
            results.append(f"  [{status}] {rel} → {out_path.relative_to(repo_root)}")
            if residuals:
                results.append(f"         Residuals: {residuals[:3]}")
        else:
            out_path.parent.mkdir(parents=True, exist_ok=True)
            out_path.write_text(rendered)
            status = "WARN" if residuals else "OK"
            results.append(f"  [{status}] {out_path.relative_to(repo_root)}")
            if residuals:
                results.append(f"         Residuals: {residuals[:3]}")

    return results


def main():
    parser = argparse.ArgumentParser(description="Render agent templates from agent.yaml")
    parser.add_argument("--config", "-c", default="agent.yaml", help="Path to agent.yaml")
    parser.add_argument("--dry-run", "-n", action="store_true", help="Show what would be rendered")
    args = parser.parse_args()

    config_path = Path(args.config)
    if not config_path.exists():
        print(f"ERROR: {config_path} not found. Copy agent.yaml.example → agent.yaml")
        sys.exit(1)

    cfg = load_agent_yaml(config_path)
    placeholders = build_placeholder_map(cfg)

    print(f"{'[DRY RUN] ' if args.dry_run else ''}Rendering templates for: {cfg['name']} ({cfg['codename']})")
    print(f"  edge_home: {cfg['edge_home_expanded']}")
    print(f"  blog: {cfg['blog_host']}:{cfg['blog_port']}")
    print(f"  onboarding: {'ON' if cfg.get('onboarding_mode') else 'OFF'}")
    print()

    results = render_all(REPO_ROOT, placeholders, dry_run=args.dry_run)
    for r in results:
        print(r)

    total = len([r for r in results if r.startswith("  [")])
    warns = len([r for r in results if "[WARN]" in r])
    print(f"\nRendered {total} templates ({warns} with residuals).")


if __name__ == "__main__":
    main()
