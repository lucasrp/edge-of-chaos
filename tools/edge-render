def _normalize_router_map(raw_routers) -> dict[str, dict]:
    if not isinstance(raw_routers, dict):
        return {}
    routers: dict[str, dict] = {}
    for purpose, raw in raw_routers.items():
        if not purpose or not isinstance(raw, dict):
            continue
        base_url = str(raw.get("base_url", "")).strip()
        secret_ref = str(raw.get("secret_ref", "")).strip()
        model = str(raw.get("model", "")).strip()
        if not (base_url and secret_ref and model):
            continue
        cfg = {
            "base_url": base_url,
            "secret_ref": secret_ref,
            "model": model,
        }
        headers = raw.get("headers") or {}
        if isinstance(headers, dict) and headers:
            cfg["headers"] = dict(headers)
        query = raw.get("query") or {}
        if isinstance(query, dict) and query:
            cfg["query"] = dict(query)
        routers[str(purpose)] = cfg
    return routers


def _resolve_runtime_routers(cfg: dict) -> dict[str, dict]:
    routers = _normalize_router_map(cfg.get("routers"))
    if routers:
        return routers

    resolved: dict[str, dict] = {}
    for purpose, spec in _ROUTER_FALLBACK_DEFAULTS.items():
        model = spec["model_default"]
        model_key = spec["model_key"]
        if model_key and cfg.get(model_key):
            model = str(cfg[model_key]).strip() or model
        resolved[purpose] = {
            "base_url": spec["base_url"],
            "secret_ref": spec["secret_ref"],
            "model": model,
        }
    return resolved


def _render_runtime_routers_file(routers: dict[str, dict]) -> str:
    payload = {
        "routers": routers,
    }
    return (
        "# Runtime routers — materialized from bootstrap config.\n"
        "# Runtime tools read this file; agent.yaml is bootstrap only.\n\n"
        + yaml.safe_dump(payload, sort_keys=False, allow_unicode=True).strip()
        + "\n"
    )


def load_agent_yaml(path: Path) -> dict:
    """Load and validate agent.yaml, apply defaults."""
    with open(path) as f:
        cfg = yaml.safe_load(f)

    # Accept both old field names (pt-BR) and new (English)
    if "missao" in cfg and "mission" not in cfg:
        cfg["mission"] = cfg.pop("missao")
    if "dominio" in cfg and "domain" not in cfg:
        cfg["domain"] = cfg.pop("dominio")
    if "idioma" in cfg and "language" not in cfg:
        cfg["language"] = cfg.pop("idioma")

    required = ["name", "codename", "mission", "voice", "domain"]
    missing = [k for k in required if not cfg.get(k)]
    if missing:
        print(f"ERROR: Missing required fields: {', '.join(missing)}")
        sys.exit(1)

    # Normalize pre_skill_context / pre_skill_procedure / pre_skill.
    # Prefer the split fields. If only `pre_skill` is set, treat it as
    # procedure by default.
    def _normalize_list(val):
        if val is None:
            return []
        if isinstance(val, str):
            return [val] if val.strip() else []
        return list(val)

    def _normalize_roles(val):
        if val is None:
            return []
        if isinstance(val, str):
            return [item.strip() for item in val.split(",") if item.strip()]
        if isinstance(val, list):
            return [str(item).strip() for item in val if str(item).strip()]
        return []

    def _normalize_primary(val):
        if isinstance(val, bool):
            return val
        text = str(val or "").strip().lower()
        return text in {"1", "true", "yes", "on"}

    pre_context = _normalize_list(cfg.get("pre_skill_context"))
    pre_procedure = _normalize_list(cfg.get("pre_skill_procedure"))
    pre_alias = _normalize_list(cfg.get("pre_skill"))
    cfg["agent_mandates"] = [
        item for item in _normalize_list(cfg.get("agent_mandates")) if str(item).strip()
    ]

    # Normalize `routines:` (free-form operator-authored workflows, #90).
    # Rendered later by edge-apply's phase_routines — here we just preserve
    # the list for downstream reads.
    cfg["routines"] = [
        r for r in _normalize_list(cfg.get("routines")) if r and r.strip()
    ]

    # Normalize `sources:` (capability manifest of external read primitives,
    # #94). Each entry is {name, description, roles, primary} — the description
    # is the spec the agent uses to create the primitive on first invocation
    # (exit 127). `primary: true` marks the preferred open-web/search source
    # and is carried through render/apply into state/sources-manifest.yaml.
    # No install-time resolution against a catalog. Primitives are born from
    # demand, not speculation.
    #
    # Also accepts plain strings (name only, no description).
    raw_sources = cfg.get("sources") or []
    if not isinstance(raw_sources, list):
        raw_sources = [raw_sources]
    cfg["sources"] = []
    for src in raw_sources:
        if isinstance(src, dict) and src.get("name"):
            name = src["name"].strip()
            desc = src.get("description", "").strip()
            roles = _normalize_roles(src.get("roles"))
            primary = _normalize_primary(src.get("primary"))
        elif isinstance(src, str) and src.strip():
            name = src.strip()
            desc = ""
            roles = []
            primary = False
        else:
            continue
        if name.startswith("edge-"):
            print(
                f"WARNING: 'sources:' entry '{name}' looks like an edge-native tool. "
                f"Edge-native tools are framework infra and should not be declared in sources.",
                file=sys.stderr,
            )
            continue
        if primary and "search" not in roles:
            roles.append("search")
        cfg["sources"].append({"name": name, "description": desc, "roles": roles, "primary": primary})

    # If only `pre_skill` is set, map it into procedure.
    if pre_alias and not pre_context and not pre_procedure:
        pre_procedure = pre_alias
        pre_alias = []

    cfg["pre_skill_context"] = pre_context
    cfg["pre_skill_procedure"] = pre_procedure
    # `pre_skill` kept as the combined list for any downstream consumer that
    # still reads it as a flat sequence (docs, old tooling, etc.).
    cfg["pre_skill"] = list(pre_context) + list(pre_procedure) + list(pre_alias)

    post = cfg.get("post_skill", [])
    if isinstance(post, str):
        post = [post] if post.strip() else []
    cfg["post_skill"] = post
    fan_out = cfg.get("fan_out", post)
    if isinstance(fan_out, str):
        fan_out = [fan_out] if fan_out.strip() else []
    cfg["fan_out"] = [item for item in list(fan_out or []) if str(item).strip()]
    cfg["routers"] = _resolve_runtime_routers(cfg)

    # Apply smart defaults
    cfg.setdefault("language", "pt-BR")
    cfg.setdefault("skill_prefix", cfg["codename"])
    if not cfg.get("skill_prefix"):
        cfg["skill_prefix"] = cfg["codename"]
    cfg.setdefault("tool_prefix", "edge")
    cfg.setdefault("edge_home", f"~/{cfg['codename']}")
    cfg.setdefault("heartbeat_interval", "2h")
    cfg.setdefault("blog_port", 8766)
    cfg.setdefault("blog_auth_enabled", True)
    cfg.setdefault("blog_auth_user", "admin")
    cfg.setdefault("blog_auth_pass", "change-me")
    cfg.setdefault("onboarding_mode", True)
    cfg.setdefault("bio", cfg["mission"])
    cfg.setdefault("character_sketch", cfg.get("voice", "Direct, technical."))
    cfg.setdefault("knowledge_base", "")
    cfg.setdefault("context_dir", "")
    cfg.setdefault("short_term_goal", cfg["mission"])
    cfg.setdefault("interests", [])
    cfg.setdefault("public_url", "")
    cfg.setdefault("repo_owner", "")
    cfg.setdefault("repo_name", cfg["name"])
    cfg.setdefault("org_name", cfg["name"])
    cfg.setdefault("org_short", cfg["codename"].upper())
    cfg.setdefault("heartbeat_prompt",
        f"Check state, analyze context, execute the highest-impact action for: {cfg['mission']}")
    cfg.setdefault("kb_type", "local")
    cfg.setdefault("kb_refresh", "on-start")
    cfg.setdefault("timezone", "America/Sao_Paulo")

    # Resolve blog_host
    blog_host = cfg.get("blog_host", "0.0.0.0")
    if blog_host == "auto":
        is_vps = not os.environ.get("DISPLAY") and sys.platform == "linux"
        cfg["blog_host"] = "0.0.0.0" if is_vps else "127.0.0.1"
    else:
        cfg["blog_host"] = blog_host

    # Compute derived values
    cfg["edge_home_expanded"] = os.path.expanduser(cfg["edge_home"])
    cfg["user_home"] = str(Path.home())

    # Parse yaml as source of truth — any systemd.time(7) spec is valid,
    # invalid specs hard-fail instead of silently rebaixando pra 2h.
    cfg["heartbeat_seconds"] = parse_interval(cfg["heartbeat_interval"])
    cfg["systemd_interval"] = cfg["heartbeat_interval"]

    # Memory project dir (Claude Code convention)
    edge_abs = os.path.expanduser(cfg["edge_home"]).rstrip("/")
    cfg["memory_project_dir"] = edge_abs.replace("/", "-").lstrip("-")

    return cfg


