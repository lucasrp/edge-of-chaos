def _ensure_install_context(cfg: dict) -> str:
    os.environ.setdefault("EDGE_CODENAME", str(cfg.get("codename", "agent")))
    os.environ.setdefault("EDGE_STATE_DIR", str(cfg.get("edge_home_expanded", REPO_ROOT)))
    cycle_id = os.environ.get("EDGE_CYCLE_ID")
    if cycle_id:
        return cycle_id
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    cycle_id = f"install:{cfg.get('codename', 'agent')}:{stamp}-{uuid.uuid4().hex[:6]}"
    os.environ["EDGE_CYCLE_ID"] = cycle_id
    return cycle_id


def _repo_relative(path: Path) -> str:
    try:
        return str(path.relative_to(REPO_ROOT))
    except ValueError:
        return str(path)


def _hash_text(content: str) -> str:
    return f"sha256:{hashlib.sha256(content.encode('utf-8')).hexdigest()}"


def _render_checklist(items: list[str], fallback: str) -> str:
    """Render a list of strings into a markdown checklist."""
    if not items:
        return fallback
    return "\n".join(f"- {item}" for item in items)


def _render_pre_skill(context: list[str], procedure: list[str]) -> str:
    """Render pre-skill split into context (injected knowledge) and procedure
    (pre-beat actions) subsections. When only one is populated, render a flat
    list for compact output.
    """
    if not context and not procedure:
        return "_(no pre-skill actions configured — add items to `pre_skill_context` or `pre_skill_procedure` in agent.yaml)_"
    if context and procedure:
        parts = [
            "### Context (injected knowledge)",
            "",
            "\n".join(f"- {item}" for item in context),
            "",
            "### Procedure (before each skill)",
            "",
            "\n".join(f"- {item}" for item in procedure),
        ]
        return "\n".join(parts)
    # Only one populated — flat list.
    items = context or procedure
    return "\n".join(f"- {item}" for item in items)


def _render_protocol_yaml(payload: dict) -> str:
    return yaml.safe_dump(payload, sort_keys=False, allow_unicode=True).strip() + "\n"


def _render_preflight_protocol(cfg: dict) -> str:
    payload = {
        "version": 1,
        "protocol": "preflight",
        "context_notes": list(cfg["agent_mandates"]) + list(cfg["pre_skill_context"]),
        "operator_notes": list(cfg["pre_skill_procedure"]),
        "procedures": [
            {"id": "health-snapshot", "kind": "health.snapshot"},
            {"id": "async-inbox", "kind": "inbox.snapshot"},
            {"id": "claude-sessions-digest", "kind": "claude.sessions.digest"},
            {"id": "claims-refresh", "kind": "claims.refresh"},
            {"id": "primitives-status", "kind": "primitives.status"},
            {"id": "capabilities-status", "kind": "capabilities.status"},
            {"id": "corpus-lookup", "kind": "corpus.lookup"},
            {"id": "workflow-status", "kind": "workflow.status"},
            {"id": "queue-status", "kind": "queue.status"},
            {"id": "onboarding-status", "kind": "onboarding.status"},
        ],
    }
    return _render_protocol_yaml(payload)


