                "When the adversarial prompt is too generic — task-specific prompts improve precision.\n\n"
                "## Cost\n"
                "~$0.10/execution (OpenAI consult)\n"
            ),
        },
    ]

    wf_created = 0
    # Check if any entry already has tags: [workflow] (not just "workflow" in filename)
    has_workflow_entries = False
    for f in entries_dir.glob("*.md"):
        try:
            head = f.read_text()[:500]
            if "tags:" in head and "workflow" in head.split("tags:")[1].split("\n")[0]:
                has_workflow_entries = True
                break
        except Exception:
            pass
    for wf in workflow_entries:
        wf_file = entries_dir / f"{today}-{wf['slug']}.md"
        if has_workflow_entries or wf_file.exists():
            break
        tags_str = ", ".join(wf["tags"])
        kw_str = ", ".join(wf["keywords"])
        secrets_str = ", ".join(wf["secrets"])
        wf_file.write_text(
            f"---\n"
            f"title: \"{wf['title']}\"\n"
            f"date: {today}\n"
            f"tags: [{tags_str}]\n"
            f"keywords: [{kw_str}]\n"
            f"claims:\n"
            f"  - \"Seed workflow — to be validated and reinforced through use\"\n"
            f"threads: []\n"
