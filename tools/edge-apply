# ─── Phase 3: Skills ───

def phase_skills(cfg, dry_run):
    header("3/8  Skills")
    prefix = cfg["skill_prefix"]
    skills_src = REPO_ROOT / "skills"
    skills_dst = Path.home() / ".claude" / "skills"

    if not skills_src.exists():
        warn(f"skills/ não encontrado em {REPO_ROOT}")
        return True

    installed = 0
    for skill_dir in sorted(skills_src.iterdir()):
        if not skill_dir.is_dir() or skill_dir.name.startswith("."):
            continue
        if skill_dir.name == "_shared":
            dst = skills_dst / "_shared"
            if not dry_run:
                dst.mkdir(parents=True, exist_ok=True)
                for f in skill_dir.glob("*.md"):
                    target_f = dst / f.name
                    if target_f.exists() and os.path.samefile(f, target_f):
                        continue
                    shutil.copy2(f, target_f)
            ok(f"_shared/ ({len(list(skill_dir.glob('*.md')))} files)")
            continue

        skill_file = skill_dir / "SKILL.md"
        if not skill_file.exists():
            continue

        target = skills_dst / f"{prefix}-{skill_dir.name}"
        if dry_run:
            print(f"  [DRY] {skill_dir.name} → {prefix}-{skill_dir.name}")
        else:
            target.mkdir(parents=True, exist_ok=True)
            content = skill_file.read_text()
            content = _reprefix(content, prefix)
            (target / "SKILL.md").write_text(content)
        installed += 1

    # Install rendered heartbeat skill (from templates/)
    hb_rendered = REPO_ROOT / "templates" / "heartbeat-skill.md"
    if not hb_rendered.exists():
        hb_rendered = REPO_ROOT / "templates" / "heartbeat-skill.md.tpl"
    if hb_rendered.exists():
        hb_dst = skills_dst / f"{prefix}-heartbeat" / "SKILL.md"
        if not dry_run:
            hb_dst.parent.mkdir(parents=True, exist_ok=True)
            content = hb_rendered.read_text()
            content = _reprefix(content, prefix)
            hb_dst.write_text(content)
        ok(f"Heartbeat skill (rendered) → {prefix}-heartbeat")

    ok(f"{installed} skills instaladas com prefixo {prefix}-")
    return True


# ─── Phase 4: CLAUDE.md + Config + Memory ───

def phase_identity(cfg, dry_run):
    header("4/8  CLAUDE.md + Config + Memory + Onboarding")
    edge = Path(cfg["edge_home_expanded"])

    # CLAUDE.md → ~/.claude/CLAUDE.md
    # Rendered CLAUDE.md — edge-render generates from config/CLAUDE.md.tpl
    claude_src = REPO_ROOT / "config" / "CLAUDE.md"
    if not claude_src.exists():
        claude_src = REPO_ROOT / "templates" / "CLAUDE.md"  # fallback
    claude_dst = Path.home() / ".claude" / "CLAUDE.md"
    if claude_src.exists():
        if not dry_run:
            shutil.copy2(claude_src, claude_dst)
        ok(f"CLAUDE.md → {claude_dst}")
    elif dry_run:
        ok(f"[DRY] CLAUDE.md → {claude_dst} (será gerado pelo render)")
    else:
        fail("templates/CLAUDE.md não encontrado — rode edge-render primeiro")
        return False

    # Config files → edge_home/config/ (skip if same dir)
    config_files = ["pre-skill.md", "post-skill.md", "strategy.md",
                    "interests.md", "features.yaml", "branding.yaml",
                    "paths.py", "paths.sh", "branding.py"]
    config_src = REPO_ROOT / "config"
    config_dst = edge / "config"
    if config_src.resolve() != config_dst.resolve():
        for f in config_files:
            src = config_src / f
            if src.exists() and not dry_run:
                config_dst.mkdir(parents=True, exist_ok=True)
                shutil.copy2(src, config_dst / f)
        ok(f"Config → {config_dst}")
    else:
        ok("Config: repo = edge_home (in-place)")

    # Memory → ~/.claude/projects/{project}/memory/ (only if not exists)
    mem_dst = Path.home() / ".claude" / "projects" / cfg["memory_project_dir"] / "memory"
    mem_files = ["personality.md", "rules-core.md", "metodo.md",
                 "debugging.md", "knowledge-design.md"]
    created = 0
    for f in mem_files:
        src = REPO_ROOT / "memory" / f
        dst = mem_dst / f
        if src.exists() and not dst.exists() and not dry_run:
            mem_dst.mkdir(parents=True, exist_ok=True)
            shutil.copy2(src, dst)
            created += 1
    ok(f"Memory: {created} novos (existentes preservados) → {mem_dst}")

    # Onboarding files → edge_home/
    for onb in ["onboarding.md", "onboarding_checklist.md"]:
        src = REPO_ROOT / "templates" / onb
        dst = edge / onb
        if src.exists() and not dst.exists() and not dry_run:
            shutil.copy2(src, dst)
    for tmpl in ["quick_win_archetypes.md", "self_intro_template.md"]:
        src = REPO_ROOT / "templates" / tmpl
        dst = edge / "templates" / tmpl
        if src.exists() and not dry_run:
            if src.resolve() != dst.resolve():
                (edge / "templates").mkdir(parents=True, exist_ok=True)
                shutil.copy2(src, dst)
    ok("Onboarding templates copiados")

    # Autonomy files
    auto_src = REPO_ROOT / "autonomy"
    auto_dst = edge / "autonomy"
    if auto_src.exists() and auto_src.resolve() != auto_dst.resolve():
        if not dry_run:
            auto_dst.mkdir(parents=True, exist_ok=True)
            for f in auto_src.glob("*.md"):
                shutil.copy2(f, auto_dst / f.name)
        ok("Autonomy files copiados")

    return True


# ─── Phase 5: Blog venv ───

def phase_venv(cfg, dry_run, skip_venv=False):
    header("5a/8  Blog (venv + files)")
    if skip_venv:
        warn("--skip-venv: pulando")
        return True

    edge = Path(cfg["edge_home_expanded"])
    blog_dst = edge / "blog"
    venv_dir = blog_dst / ".venv"

    # Copy blog app files (if repo != edge_home)
    blog_src = REPO_ROOT / "blog"
    if blog_src.resolve() != blog_dst.resolve():
        if not dry_run:
            for f in blog_src.glob("*.py"):
                shutil.copy2(f, blog_dst / f.name)
            for f in blog_src.glob("*.sh"):
                dst = blog_dst / f.name
                shutil.copy2(f, dst)
                dst.chmod(0o755)
            for d in ["templates", "static"]:
                src_d = blog_src / d
                dst_d = blog_dst / d
                if src_d.exists():
                    shutil.copytree(src_d, dst_d, dirs_exist_ok=True)
        ok("Blog files copiados")
    else:
        ok("Blog: repo = edge_home (in-place)")

    # Create venv
    if venv_dir.exists() and (venv_dir / "bin" / "python3").exists():
        ok("venv já existe")
        return True

    if dry_run:
        print(f"  [DRY] python3 -m venv {venv_dir}")
        return True

    result = run(f"python3 -m venv {venv_dir}")
    if result.returncode != 0:
        fail(f"python3 -m venv falhou: {result.stderr.strip()}")
        warn("Tente: sudo apt install python3-venv")
        return False

    pip = venv_dir / "bin" / "pip"
    result = run(f"{pip} install -q flask flask-compress markdown pyyaml sqlite-vec")
    if result.returncode != 0:
        fail(f"pip install falhou: {result.stderr.strip()}")
        return False

    ok("venv criado + deps instaladas")
    return True


# ─── Phase 5b: Tools venv ───

def phase_tools_venv(cfg, dry_run, skip_venv=False):
    header("5b/8  Tools venv (edge-consult, review-gate, etc.)")
    if skip_venv:
        warn("--skip-venv: pulando")
        return True

    edge = Path(cfg["edge_home_expanded"])
    tools_dir = edge / "tools"
    venv_dir = tools_dir / ".venv"
    reqs = tools_dir / "requirements.txt"

    # Also check in REPO_ROOT
    if not reqs.exists():
        reqs = REPO_ROOT / "tools" / "requirements.txt"
    if not reqs.exists():
        warn("tools/requirements.txt não encontrado — pulando venv de tools")
        return True

    if venv_dir.exists() and (venv_dir / "bin" / "python3").exists():
        ok("tools venv já existe")
        return True

    if dry_run:
        print(f"  [DRY] python3 -m venv {venv_dir}")
        print(f"  [DRY] pip install -r {reqs}")
        return True

    result = run(f"python3 -m venv {venv_dir}")
    if result.returncode != 0:
        fail(f"python3 -m venv falhou: {result.stderr.strip()}")
        warn("Tente: sudo apt install python3-venv")
        return False

    pip = venv_dir / "bin" / "pip"
    result = run(f"{pip} install -q -r {reqs}")
    if result.returncode != 0:
        fail(f"pip install falhou: {result.stderr.strip()}")
        return False

    # Update shebangs in ALL Python tools to use venv (not just *.py)
    for tool in tools_dir.iterdir():
        if not tool.is_file() or tool.name.startswith("."):
            continue
        try:
            content = tool.read_text()
        except (UnicodeDecodeError, PermissionError):
            continue
        if content.startswith("#!/usr/bin/env python3"):
            content = content.replace(
                "#!/usr/bin/env python3",
                f"#!{venv_dir}/bin/python3",
                1
            )
            tool.write_text(content)

    ok("tools venv criado + deps instaladas + shebangs atualizados")
    return True


# ─── Phase 6: Systemd ───

def phase_systemd(cfg, dry_run):
    header("6/8  Systemd")
    if platform.system() != "Linux":
        warn(f"Plataforma {platform.system()} — pulando systemd")
        return True

    service_dir = Path.home() / ".config" / "systemd" / "user"

    units = {
        "agent-heartbeat.service": "agent-heartbeat.service",
        "agent-heartbeat.timer": "agent-heartbeat.timer",
        "blog-server.service": "blog-server.service",
    }

    if not dry_run:
        service_dir.mkdir(parents=True, exist_ok=True)

    for src_name, dst_name in units.items():
        src = REPO_ROOT / "systemd" / src_name
        # Try rendered (without .tpl) first, then original
        if not src.exists():
            src = REPO_ROOT / "systemd" / (src_name + ".tpl")
        if src.exists():
            if not dry_run:
                shutil.copy2(src, service_dir / dst_name)
            ok(dst_name)
        else:
            warn(f"{src_name} não encontrado")

    # Install heartbeat.sh wrapper to ~/.local/bin/
    hb_src = REPO_ROOT / "config" / "heartbeat.sh"
    if not hb_src.exists():
        hb_src = REPO_ROOT / "config" / "heartbeat.sh.tpl"  # fallback to template
    local_bin = Path.home() / ".local" / "bin"
    if hb_src.exists() and not dry_run:
        local_bin.mkdir(parents=True, exist_ok=True)
        shutil.copy2(hb_src, local_bin / "heartbeat.sh")
        (local_bin / "heartbeat.sh").chmod(0o755)
        ok("heartbeat.sh → ~/.local/bin/")
    elif not hb_src.exists():
        warn("config/heartbeat.sh não encontrado")

    if not dry_run:
        run("systemctl --user daemon-reload")
        run("systemctl --user enable blog-server.service")
        run("systemctl --user restart blog-server.service")
    ok("systemd daemon-reload + blog-server enabled + started")
    return True


# ─── Phase 7: Tools ───

def phase_tools(cfg, dry_run):
    header("7/8  Tools + Symlinks")
    edge = Path(cfg["edge_home_expanded"])
    tools_src = REPO_ROOT / "tools"
    tools_dst = edge / "tools"
    local_bin = Path.home() / ".local" / "bin"

    if not tools_src.exists():
        warn("tools/ não encontrado")
        return True

    if not dry_run:
        tools_dst.mkdir(parents=True, exist_ok=True)
        local_bin.mkdir(parents=True, exist_ok=True)

    # Copy tools (if repo != edge_home)
    count = 0
    if tools_src.resolve() != tools_dst.resolve():
        for tool in tools_src.iterdir():
            if tool.name.startswith(".") or tool.name.startswith("__") or tool.is_dir():
                continue
            if not dry_run:
                dst = tools_dst / tool.name
                shutil.copy2(tool, dst)
                dst.chmod(0o755)
            count += 1
        ok(f"{count} tools copiados → {tools_dst}")
    else:
        count = len([f for f in tools_src.iterdir() if f.is_file() and not f.name.startswith(".")])
        # Just ensure executable
        if not dry_run:
            for tool in tools_src.iterdir():
                if tool.is_file() and not tool.name.startswith("."):
                    tool.chmod(0o755)
        ok(f"Tools: repo = edge_home (in-place, {count} tools)")

    # Symlink ALL tools to ~/.local/bin/ (not just a hardcoded list)
    linked = 0
    for tool in tools_dst.iterdir():
        if tool.name.startswith(".") or tool.name.startswith("__") or tool.is_dir():
            continue
        if tool.suffix in (".md", ".yaml", ".yml", ".txt", ".css", ".svg", ".json"):
            continue  # skip non-executables
        if not dry_run:
            # Link name: strip .py suffix (edge-consult.py → edge-consult)
            link_name = tool.stem if tool.suffix == ".py" else tool.name
            link = local_bin / link_name
            link.unlink(missing_ok=True)
            link.symlink_to(tool.resolve())
            linked += 1
    # Also link consolidate-state from blog/
    cs = edge / "blog" / "consolidate-state.sh"
    if cs.exists() and not dry_run:
        link = local_bin / "consolidate-state"
        link.unlink(missing_ok=True)
        link.symlink_to(cs.resolve())
        linked += 1
    ok(f"{linked} symlinks em ~/.local/bin/")

    # Copy search tools
    search_src = REPO_ROOT / "search"
    search_dst = edge / "search"
    if search_src.exists() and search_src.resolve() != search_dst.resolve():
        if not dry_run:
            search_dst.mkdir(parents=True, exist_ok=True)
            for f in search_src.glob("*.py"):
                shutil.copy2(f, search_dst / f.name)
        ok("Search tools copiados")

    # Create search venv (sqlite-vec, openai for embeddings)
    search_venv = search_dst / ".venv"
    search_reqs = search_dst / "requirements.txt"
    if not search_reqs.exists():
        search_reqs = REPO_ROOT / "search" / "requirements.txt"
    if search_reqs.exists() and not (search_venv / "bin" / "python3").exists():
        if not dry_run:
            result = run(f"python3 -m venv {search_venv}")
            if result.returncode == 0:
                pip = search_venv / "bin" / "pip"
                run(f"{pip} install -q -r {search_reqs}")
                ok("Search venv criado")
            else:
                warn("Search venv falhou")
    elif (search_venv / "bin" / "python3").exists():
        ok("Search venv já existe")

    # Create edge-index and edge-search wrappers (load secrets for API keys)
    if not dry_run:
        for wrapper_name, script in [("edge-index", "ingest.py"), ("edge-search", "search.py")]:
            wrapper = local_bin / wrapper_name
            wrapper.write_text(
                f'#!/bin/bash\n'
                f'EDGE_DIR="{edge}"\n'
                f'cd "$EDGE_DIR"\n'
                f'[ -f "$EDGE_DIR/secrets/keys.env" ] && set -a && source "$EDGE_DIR/secrets/keys.env" && set +a\n'
                f'"{search_dst / ".venv" / "bin" / "python3"}" "{search_dst / script}" "$@"\n'
            )
            wrapper.chmod(0o755)
        ok("edge-index + edge-search wrappers criados (com secrets)")

    # Create SQLite database if missing
    sqlite_db = edge / "edge-memory.db"
    if not sqlite_db.exists() and not dry_run:
        result = run(f'sqlite3 "{sqlite_db}" "CREATE TABLE IF NOT EXISTS _init(ts TEXT); INSERT INTO _init VALUES(datetime(\'now\')); DROP TABLE _init;"')
        if result.returncode == 0:
            ok("SQLite database created")
        else:
            warn("SQLite database creation failed")

    # Configure git identity (needed for consolidate-state commits)
    if not dry_run:
        name = cfg.get("name", "agent")
        run(f'git config --global user.name "{name}"')
        run(f'git config --global user.email "{name}@edge-of-chaos"')
        ok(f"Git identity: {name}")

    # Generate per-tool .env files from keys.env
    # Tools expect secrets/openai.env, secrets/x-api.env etc.
    keys_env = edge / "secrets" / "keys.env"
    if keys_env.exists() and not dry_run:
        keys = {}
        for line in keys_env.read_text().splitlines():
            if "=" in line and not line.startswith("#"):
                k, v = line.split("=", 1)
                keys[k.strip()] = v.strip()

        env_map = {
            "openai.env": ["OPENAI_API_KEY"],
            "exa.env": ["EXA_API_KEY"],
            "xai.env": ["XAI_API_KEY"],
            "cloudflare.env": ["CLOUDFLARE_ACCOUNT_ID", "CLOUDFLARE_API_TOKEN"],
            "x-api.env": ["X_API_KEY", "X_API_SECRET", "X_ACCESS_TOKEN",
                          "X_ACCESS_TOKEN_SECRET", "X_BEARER_TOKEN"],
            "moltbook.env": ["MOLTBOOK_API_KEY", "MOLTBOOK_USERNAME", "MOLTBOOK_AGENT_ID"],
        }
        generated = 0
        for filename, key_names in env_map.items():
            lines = [f"{k}={keys[k]}" for k in key_names if k in keys and keys[k]]
            if lines:
                env_file = edge / "secrets" / filename
                env_file.write_text("\n".join(lines) + "\n")
                env_file.chmod(0o600)
                generated += 1
        if generated:
            ok(f"{generated} per-tool .env files gerados de keys.env")

    # Ensure .bashrc has PATH
    bashrc = Path.home() / ".bashrc"
    if not dry_run:
        bashrc_content = bashrc.read_text() if bashrc.exists() else ""
        additions = []
        if ".local/bin" not in bashrc_content:
            additions.append('export PATH="$HOME/.local/bin:$PATH"')
        if "EDGE_DIR" not in bashrc_content:
            additions.append(f'export EDGE_DIR="{edge}"')
        if additions:
            with open(bashrc, "a") as f:
                f.write("\n" + "\n".join(additions) + "\n")
            ok(f".bashrc atualizado ({len(additions)} linhas)")
        else:
            ok(".bashrc já configurado")

    # Copy bin/ (health scripts)
    bin_src = REPO_ROOT / "bin"
    bin_dst = edge / "bin"
    if bin_src.exists() and bin_src.resolve() != bin_dst.resolve():
        if not dry_run:
            bin_dst.mkdir(parents=True, exist_ok=True)
            for f in bin_src.glob("*.sh"):
                dst = bin_dst / f.name
                shutil.copy2(f, dst)
                dst.chmod(0o755)
        ok("Health scripts copiados")

    return True


# ─── Phase 8b: Avatar generation ───

def phase_avatar(cfg, dry_run):
    header("8b/9  Avatar")
    edge = Path(cfg["edge_home_expanded"])
    avatar_path = edge / "blog" / "static" / "avatar.png"

    if avatar_path.exists() and avatar_path.stat().st_size > 0:
        ok(f"Avatar already exists ({avatar_path.stat().st_size // 1024}K)")
        return True

    if dry_run:
        print(f"  [DRY] Would generate avatar for {cfg.get('name', 'agent')}")
        return True

    name = cfg.get("name", "agent")
    mission = cfg.get("mission", "")
    sketch = cfg.get("character_sketch", cfg.get("voice", ""))
    prompt = f"Create a minimalist, professional avatar icon for an AI agent named '{name}'. Mission: {mission}. Character: {sketch}. Clean vector-style illustration suitable as a 256x256 profile picture. No text, no letters, no words in the image."

    # Try OpenAI first
    keys_env = edge / "secrets" / "keys.env"
    openai_key = ""
    xai_key = ""
    if keys_env.exists():
        for line in keys_env.read_text().splitlines():
            if line.startswith("OPENAI_API_KEY=") and "=" in line:
                openai_key = line.split("=", 1)[1].strip()
            if line.startswith("XAI_API_KEY=") and "=" in line:
                xai_key = line.split("=", 1)[1].strip()

    # Also check env files
    if not openai_key:
        oai_env = edge / "secrets" / "openai.env"
        if oai_env.exists():
            for line in oai_env.read_text().splitlines():
                if line.startswith("OPENAI_API_KEY="):
                    openai_key = line.split("=", 1)[1].strip()
    if not xai_key:
        xai_env = edge / "secrets" / "xai.env"
        if xai_env.exists():
            for line in xai_env.read_text().splitlines():
                if line.startswith("XAI_API_KEY="):
                    xai_key = line.split("=", 1)[1].strip()

    generated = False

    # Write prompt to temp file to avoid shell quoting issues
    prompt_file = edge / ".avatar-prompt.txt"
    prompt_file.write_text(prompt)

    if openai_key:
        try:
            script = f'''
import urllib.request, json, base64, sys, pathlib
prompt = pathlib.Path("{prompt_file}").read_text().strip()
data = json.dumps({{"model": "gpt-image-1", "prompt": prompt, "n": 1, "size": "1024x1024", "quality": "low"}}).encode()
req = urllib.request.Request("https://api.openai.com/v1/images/generations",
    data=data, headers={{"Authorization": "Bearer {openai_key}", "Content-Type": "application/json"}})
resp = urllib.request.urlopen(req, timeout=60)
result = json.loads(resp.read())
img_data = result["data"][0]
if "b64_json" in img_data:
    img_bytes = base64.b64decode(img_data["b64_json"])
elif "url" in img_data:
    img_bytes = urllib.request.urlopen(img_data["url"], timeout=30).read()
else:
    sys.exit("No image data")
pathlib.Path("{avatar_path}").write_bytes(img_bytes)
print("OK")
'''
            result = run(f'python3 -c {repr(script)}')
            if result.returncode == 0 and avatar_path.exists():
                ok(f"Avatar generated via OpenAI ({avatar_path.stat().st_size // 1024}K)")
                generated = True
            else:
                warn(f"OpenAI avatar generation failed: {result.stderr.strip()[:100]}")
        except Exception as e:
            warn(f"OpenAI avatar failed: {e}")

    if not generated and xai_key:
        try:
            script = f'''
import urllib.request, json, base64, sys, pathlib
prompt = pathlib.Path("{prompt_file}").read_text().strip()
data = json.dumps({{"model": "grok-2-image", "prompt": prompt, "n": 1}}).encode()
req = urllib.request.Request("https://api.x.ai/v1/images/generations",
    data=data, headers={{"Authorization": "Bearer {xai_key}", "Content-Type": "application/json"}})
resp = urllib.request.urlopen(req, timeout=60)
result = json.loads(resp.read())
img_data = result["data"][0]
if "b64_json" in img_data:
    img_bytes = base64.b64decode(img_data["b64_json"])
elif "url" in img_data:
    img_bytes = urllib.request.urlopen(img_data["url"], timeout=30).read()
else:
    sys.exit("No image data")
pathlib.Path("{avatar_path}").write_bytes(img_bytes)
print("OK")
'''
            result = run(f'python3 -c {repr(script)}')
            if result.returncode == 0 and avatar_path.exists():
                ok(f"Avatar generated via xAI ({avatar_path.stat().st_size // 1024}K)")
                generated = True
            else:
                warn(f"xAI avatar generation failed: {result.stderr.strip()[:100]}")
        except Exception as e:
            warn(f"xAI avatar failed: {e}")

    if not generated:
        # Fallback: DiceBear API (free, no key needed)
        try:
            result = run(f'curl -sL -o "{avatar_path}" "https://api.dicebear.com/9.x/bottts/png?seed={name}&size=256"')
            if result.returncode == 0 and avatar_path.exists() and avatar_path.stat().st_size > 0:
                ok(f"Avatar generated via DiceBear fallback ({avatar_path.stat().st_size // 1024}K)")
                generated = True
        except Exception:
            pass

    if not generated:
        warn("No avatar generated (no API keys and DiceBear unavailable)")

    prompt_file.unlink(missing_ok=True)
    return True


# ─── Phase 9: Seed content ───

def phase_seed(cfg, dry_run):
    header("9/10  Seed content")
    edge = Path(cfg["edge_home_expanded"])
    signals_dir = edge / "state" / "signals"
    name = cfg.get("name", "agent")
    mission = cfg.get("mission", "")
    goal = cfg.get("short_term_goal", "")
    interests = cfg.get("interests", [])
    sketch = cfg.get("character_sketch", cfg.get("voice", ""))
    today = datetime.now().strftime("%Y-%m-%d")
    now = datetime.now().strftime("%Y-%m-%d %H:%M")

    if dry_run:
        print(f"  [DRY] Would generate seed content for {name}")
        return True

    seeded = 0

    # --- signals/strategy.md ---
    sf = signals_dir / "strategy.md"
    if not sf.exists() or sf.stat().st_size == 0:
        lines = []
        if goal:
            lines.append(f"- [{now} | seed] Short-term goal: {goal}")
        for i in interests:
            area = i.get("area", "") if isinstance(i, dict) else str(i)
            conn = i.get("connection", "") if isinstance(i, dict) else ""
            if area:
                lines.append(f"- [{now} | seed] Interest: {area}" + (f" — {conn}" if conn else ""))
        if lines:
            sf.write_text("\n".join(lines) + "\n")
            seeded += 1

    # --- signals/autonomy.md ---
    af = signals_dir / "autonomy.md"
    if not af.exists() or af.stat().st_size == 0:
        lines = []
        keys_env = edge / "secrets" / "keys.env"
        if keys_env.exists():
            content = keys_env.read_text()
            if "OPENAI_API_KEY=" not in content or content.split("OPENAI_API_KEY=")[1].split("\n")[0].strip() == "":
                lines.append(f"- [{now} | seed] !OPENAI_API_KEY missing — adversarial review, avatar, embeddings unavailable")
            if "EXA_API_KEY=" not in content or content.split("EXA_API_KEY=")[1].split("\n")[0].strip() == "":
                lines.append(f"- [{now} | seed] ?EXA_API_KEY missing — external source search limited")
            if "XAI_API_KEY=" not in content:
                lines.append(f"- [{now} | seed] ?XAI_API_KEY missing — no second adversarial opinion (Grok)")
        else:
            lines.append(f"- [{now} | seed] !No keys.env found — all external integrations unavailable")
        if lines:
            af.write_text("\n".join(lines) + "\n")
            seeded += 1

    # --- signals/serendipity.md ---
    sf2 = signals_dir / "serendipity.md"
    if not sf2.exists() or sf2.stat().st_size == 0:
        sf2.write_text(f"- [{now} | seed] Fresh install — clean slate, all possibilities open\n")
        seeded += 1

    # --- signals/friction.md ---
    ff = signals_dir / "friction.md"
    if not ff.exists() or ff.stat().st_size == 0:
        ff.write_text(f"- [{now} | seed] No friction observed yet — first heartbeat will surface real issues\n")
        seeded += 1

    # --- config/interests.md ---
    interests_file = edge / "config" / "interests.md"
    if interests and (not interests_file.exists() or "TBD" in interests_file.read_text()):
        lines = [
            "# Interests",
            "",
            f"> Seed interests for {name}. Updated by the agent as it learns.",
            "",
            "| Area | Connection |",
            "|------|-----------|",
        ]
        for i in interests:
            area = i.get("area", "") if isinstance(i, dict) else str(i)
            conn = i.get("connection", "") if isinstance(i, dict) else ""
            lines.append(f"| {area} | {conn} |")
        lines.append("")
        interests_file.write_text("\n".join(lines))
        seeded += 1

    # --- memory/reflection-log.md ---
    rl = Path.home() / ".claude" / "projects"
    # Find the memory dir
    mem_dir = None
    for d in rl.iterdir() if rl.exists() else []:
        mem_candidate = d / "memory"
        if mem_candidate.exists():
            mem_dir = mem_candidate
            break
    if mem_dir is None:
        mem_dir = edge / "memory"

    ref_log = mem_dir / "reflection-log.md"
    if not ref_log.exists() or ref_log.stat().st_size == 0:
        ref_log.write_text("# Reflection — Execution Log\n\n---\n\n_Initialized on install. First reflection will populate this._\n")
        seeded += 1

    # --- discoverys.md ---
    disc = edge / "discoverys.md" if (edge / "discoverys.md").exists() else edge / "memory" / "discoverys.md"
    if not disc.exists() or disc.stat().st_size < 20:
        disc = edge / "discoverys.md"
        disc.write_text(f"# Discoveries — Registry\n\n---\n\n_No discoveries yet. First heartbeat will start exploring._\n")
        seeded += 1

    # --- state/first-steps.json ---
    first_steps = cfg.get("first_steps", [])
    fs_file = edge / "state" / "first-steps.json"
    if first_steps and not fs_file.exists():
        steps = []
        for i, step in enumerate(first_steps):
            steps.append({"id": i + 1, "task": step.strip(), "status": "pending"})
        fs_file.write_text(json.dumps(steps, indent=2, ensure_ascii=False) + "\n")
        seeded += 1

    if seeded > 0:
        ok(f"{seeded} seed files generated from agent.yaml")
    else:
        ok("Seed files already exist — skipping")

    return True


# ─── Main ───

def main():
    parser = argparse.ArgumentParser(description="Provision agent from agent.yaml")
    parser.add_argument("--config", "-c", default="agent.yaml")
    parser.add_argument("--dry-run", "-n", action="store_true")
    parser.add_argument("--skip-venv", action="store_true")
    args = parser.parse_args()

    config_path = Path(args.config).resolve()
    if not config_path.exists():
        print(f"{RED}✗{RESET} {config_path} não encontrado")
        print(f"  Copie agent.yaml.example → agent.yaml e preencha")
        sys.exit(1)

    cfg = load_config(config_path)
    name = cfg.get("name", "?")
    codename = cfg.get("codename", "?")

    print(f"\n{BOLD}edge-apply: {name} ({codename}){RESET}")
    print(f"  edge_home: {cfg['edge_home_expanded']}")
    print(f"  blog: {cfg.get('blog_host', 'auto')}:{cfg.get('blog_port', 8766)}")
    print(f"  skills: {cfg.get('skill_prefix', codename)}-*")
    print(f"  onboarding: {'ON' if cfg.get('onboarding_mode') else 'OFF'}")
    if args.dry_run:
        print(f"  {YELLOW}[DRY RUN]{RESET}")

    results = []
    results.append(("Render", phase_render(str(config_path), args.dry_run)))
    results.append(("Dirs", phase_dirs(cfg, args.dry_run)))
    results.append(("Skills", phase_skills(cfg, args.dry_run)))
    results.append(("Identity", phase_identity(cfg, args.dry_run)))
    results.append(("Blog", phase_venv(cfg, args.dry_run, args.skip_venv)))
    results.append(("Tools venv", phase_tools_venv(cfg, args.dry_run, args.skip_venv)))
    results.append(("Systemd", phase_systemd(cfg, args.dry_run)))
    results.append(("Tools", phase_tools(cfg, args.dry_run)))
    results.append(("Avatar", phase_avatar(cfg, args.dry_run)))
    results.append(("Seed", phase_seed(cfg, args.dry_run)))

    passed = sum(1 for _, r in results if r)
    failed = sum(1 for _, r in results if not r)
    color = GREEN if failed == 0 else RED

    print(f"\n{color}━━━  {passed}/{len(results)} fases OK  ━━━{RESET}")

    if failed == 0:
        prefix = cfg.get("skill_prefix", codename)
        print(f"\n{GREEN}✓{RESET} Instalação concluída. Próximos passos:")
        print(f"  1. Verificar:  python3 tools/edge-doctor --config agent.yaml")
        print(f"  2. Blog:       systemctl --user enable --now blog-server")
        print(f"  3. Heartbeat:  systemctl --user enable --now agent-heartbeat.timer")
        print(f"  4. Testar:     claude -p '/{prefix}-heartbeat'")
        print(f"  5. Doctor:     python3 tools/edge-doctor --config agent.yaml")
    else:
        print(f"\n{RED}✗{RESET} {failed} fase(s) falharam.")

    sys.exit(0 if failed == 0 else 1)


if __name__ == "__main__":
    main()
