#!/usr/bin/env python3
"""edge-apply: Provision host from agent.yaml. Idempotent.

Replaces install.sh. Reads everything from agent.yaml, renders templates,
provisions host. Safe to run multiple times.

Usage:
    edge-apply                         # uses ./agent.yaml
    edge-apply --config path/to.yaml   # explicit config
    edge-apply --dry-run               # show what would be done
    edge-apply --skip-venv             # skip Python venv creation
"""

import argparse
import os
import platform
import re
import shutil
import subprocess
import sys
from pathlib import Path

import yaml

REPO_ROOT = Path(__file__).resolve().parent.parent
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
BOLD = "\033[1m"
RESET = "\033[0m"


def _reprefix(content: str, prefix: str) -> str:
    """Replace ed- prefix with the target prefix in skill content.

    Handles: /ed-research, name: ed-research, `ed-research`, "ed-research"
    Does NOT touch words like 'described', 'used', 'based' (no slash/quote before ed-).
    """
    content = re.sub(r'/ed-', f'/{prefix}-', content)
    content = re.sub(r'(?<=name: )ed-', f'{prefix}-', content)
    content = re.sub(r'`ed-', f'`{prefix}-', content)
    content = re.sub(r'"ed-', f'"{prefix}-', content)
    content = content.replace("/PREFIX-", f"/{prefix}-")
    return content


def ok(msg): print(f"  {GREEN}✓{RESET} {msg}")
def warn(msg): print(f"  {YELLOW}⚠{RESET} {msg}")
def fail(msg): print(f"  {RED}✗{RESET} {msg}")
def header(msg): print(f"\n{BOLD}━━━  {msg}  ━━━{RESET}\n")


def load_config(path: Path) -> dict:
    with open(path) as f:
        cfg = yaml.safe_load(f)
    cfg.setdefault("codename", cfg.get("name", "agent"))
    cfg.setdefault("skill_prefix", cfg["codename"])
    if not cfg.get("skill_prefix"):
        cfg["skill_prefix"] = cfg["codename"]
    cfg.setdefault("edge_home", f"~/{cfg['codename']}")
    cfg.setdefault("blog_port", 8766)
    cfg.setdefault("blog_host", "auto")
    cfg.setdefault("idioma", "pt-BR")
    cfg.setdefault("heartbeat_interval", "2h")
    cfg.setdefault("onboarding_mode", True)
    cfg["edge_home_expanded"] = os.path.expanduser(cfg["edge_home"])
    interval_map = {"30min": "30min", "1h": "1h", "2h": "2h", "24h": "24h"}
    cfg["systemd_interval"] = interval_map.get(cfg["heartbeat_interval"], "2h")
    cfg["memory_project_dir"] = cfg["edge_home_expanded"].rstrip("/").replace("/", "-").lstrip("-")
    return cfg


def run(cmd, **kwargs):
    return subprocess.run(cmd, shell=True, capture_output=True, text=True, **kwargs)


# ─── Phase 1: Render ───

def phase_render(config_path, dry_run):
    header("1/8  Render templates")
    cmd = f"python3 {REPO_ROOT / 'tools' / 'edge-render'} --config {config_path}"
    if dry_run:
        cmd += " --dry-run"
    result = run(cmd)
    print(result.stdout.rstrip())
    if result.returncode != 0:
        print(result.stderr)
        fail("edge-render falhou")
        return False
    ok("Templates renderizados")
    return True


# ─── Phase 2: Dirs ───

def phase_dirs(cfg, dry_run):
    header("2/8  Diretórios")
    edge = Path(cfg["edge_home_expanded"])
    dirs = [
        edge / "blog" / "entries", edge / "blog" / "diffs",
        edge / "reports", edge / "meta-reports", edge / "logs",
        edge / "notes", edge / "threads", edge / "state",
        edge / "state-snapshots", edge / "scratchpads",
        edge / "secrets", edge / "search",
        edge / "health" / "raw", edge / "health" / "last_success",
        edge / "autonomy", edge / "config", edge / "templates",
        Path.home() / ".claude",
    ]
    for d in dirs:
        if not dry_run:
            d.mkdir(parents=True, exist_ok=True)
    ok(f"{len(dirs)} diretórios garantidos")
    return True


# ─── Phase 3: Skills ───

def phase_skills(cfg, dry_run):
    header("3/8  Skills")
    prefix = cfg["skill_prefix"]
    skills_src = REPO_ROOT / "skills"
    skills_dst = Path.home() / ".claude" / "skills"

    if not skills_src.exists():
        warn(f"skills/ não encontrado em {REPO_ROOT}")
        return True

    installed = 0
    for skill_dir in sorted(skills_src.iterdir()):
        if not skill_dir.is_dir() or skill_dir.name.startswith("."):
            continue
        if skill_dir.name == "_shared":
            dst = skills_dst / "_shared"
            if not dry_run:
                dst.mkdir(parents=True, exist_ok=True)
                for f in skill_dir.glob("*.md"):
                    shutil.copy2(f, dst / f.name)
            ok(f"_shared/ ({len(list(skill_dir.glob('*.md')))} files)")
            continue

        skill_file = skill_dir / "SKILL.md"
        if not skill_file.exists():
            continue

        target = skills_dst / f"{prefix}-{skill_dir.name}"
        if dry_run:
            print(f"  [DRY] {skill_dir.name} → {prefix}-{skill_dir.name}")
        else:
            target.mkdir(parents=True, exist_ok=True)
            content = skill_file.read_text()
            content = _reprefix(content, prefix)
            (target / "SKILL.md").write_text(content)
        installed += 1

    # Install rendered heartbeat skill (from templates/)
    hb_rendered = REPO_ROOT / "templates" / "heartbeat-skill.md"
    if not hb_rendered.exists():
        hb_rendered = REPO_ROOT / "templates" / "heartbeat-skill.md.tpl"
    if hb_rendered.exists():
        hb_dst = skills_dst / f"{prefix}-heartbeat" / "SKILL.md"
        if not dry_run:
            hb_dst.parent.mkdir(parents=True, exist_ok=True)
            content = hb_rendered.read_text()
            content = _reprefix(content, prefix)
            hb_dst.write_text(content)
        ok(f"Heartbeat skill (rendered) → {prefix}-heartbeat")

    ok(f"{installed} skills instaladas com prefixo {prefix}-")
    return True


# ─── Phase 4: CLAUDE.md + Config + Memory ───

def phase_identity(cfg, dry_run):
    header("4/8  CLAUDE.md + Config + Memory + Onboarding")
    edge = Path(cfg["edge_home_expanded"])

    # CLAUDE.md → ~/.claude/CLAUDE.md
    claude_src = REPO_ROOT / "templates" / "CLAUDE.md"
    claude_dst = Path.home() / ".claude" / "CLAUDE.md"
    if claude_src.exists():
        if not dry_run:
            shutil.copy2(claude_src, claude_dst)
        ok(f"CLAUDE.md → {claude_dst}")
    elif dry_run:
        ok(f"[DRY] CLAUDE.md → {claude_dst} (será gerado pelo render)")
    else:
        fail("templates/CLAUDE.md não encontrado — rode edge-render primeiro")
        return False

    # Config files → edge_home/config/ (skip if same dir)
    config_files = ["pre-skill.md", "post-skill.md", "strategy.md",
                    "interests.md", "features.yaml", "branding.yaml",
                    "paths.py", "paths.sh", "branding.py"]
    config_src = REPO_ROOT / "config"
    config_dst = edge / "config"
    if config_src.resolve() != config_dst.resolve():
        for f in config_files:
            src = config_src / f
            if src.exists() and not dry_run:
                config_dst.mkdir(parents=True, exist_ok=True)
                shutil.copy2(src, config_dst / f)
        ok(f"Config → {config_dst}")
    else:
        ok("Config: repo = edge_home (in-place)")

    # Memory → ~/.claude/projects/{project}/memory/ (only if not exists)
    mem_dst = Path.home() / ".claude" / "projects" / cfg["memory_project_dir"] / "memory"
    mem_files = ["personality.md", "rules-core.md", "metodo.md",
                 "debugging.md", "knowledge-design.md"]
    created = 0
    for f in mem_files:
        src = REPO_ROOT / "memory" / f
        dst = mem_dst / f
        if src.exists() and not dst.exists() and not dry_run:
            mem_dst.mkdir(parents=True, exist_ok=True)
            shutil.copy2(src, dst)
            created += 1
    ok(f"Memory: {created} novos (existentes preservados) → {mem_dst}")

    # Onboarding files → edge_home/
    for onb in ["onboarding.md", "onboarding_checklist.md"]:
        src = REPO_ROOT / "templates" / onb
        dst = edge / onb
        if src.exists() and not dst.exists() and not dry_run:
            shutil.copy2(src, dst)
    for tmpl in ["quick_win_archetypes.md", "self_intro_template.md"]:
        src = REPO_ROOT / "templates" / tmpl
        dst = edge / "templates" / tmpl
        if src.exists() and not dry_run:
            if src.resolve() != dst.resolve():
                (edge / "templates").mkdir(parents=True, exist_ok=True)
                shutil.copy2(src, dst)
    ok("Onboarding templates copiados")

    # Autonomy files
    auto_src = REPO_ROOT / "autonomy"
    auto_dst = edge / "autonomy"
    if auto_src.exists() and auto_src.resolve() != auto_dst.resolve():
        if not dry_run:
            auto_dst.mkdir(parents=True, exist_ok=True)
            for f in auto_src.glob("*.md"):
                shutil.copy2(f, auto_dst / f.name)
        ok("Autonomy files copiados")

    return True


# ─── Phase 5: Blog venv ───

def phase_venv(cfg, dry_run, skip_venv=False):
    header("5a/8  Blog (venv + files)")
    if skip_venv:
        warn("--skip-venv: pulando")
        return True

    edge = Path(cfg["edge_home_expanded"])
    blog_dst = edge / "blog"
    venv_dir = blog_dst / ".venv"

    # Copy blog app files (if repo != edge_home)
    blog_src = REPO_ROOT / "blog"
    if blog_src.resolve() != blog_dst.resolve():
        if not dry_run:
            for f in blog_src.glob("*.py"):
                shutil.copy2(f, blog_dst / f.name)
            for f in blog_src.glob("*.sh"):
                dst = blog_dst / f.name
                shutil.copy2(f, dst)
                dst.chmod(0o755)
            for d in ["templates", "static"]:
                src_d = blog_src / d
                dst_d = blog_dst / d
                if src_d.exists():
                    shutil.copytree(src_d, dst_d, dirs_exist_ok=True)
        ok("Blog files copiados")
    else:
        ok("Blog: repo = edge_home (in-place)")

    # Create venv
    if venv_dir.exists() and (venv_dir / "bin" / "python3").exists():
        ok("venv já existe")
        return True

    if dry_run:
        print(f"  [DRY] python3 -m venv {venv_dir}")
        return True

    result = run(f"python3 -m venv {venv_dir}")
    if result.returncode != 0:
        fail(f"python3 -m venv falhou: {result.stderr.strip()}")
        warn("Tente: sudo apt install python3-venv")
        return False

    pip = venv_dir / "bin" / "pip"
    result = run(f"{pip} install -q flask flask-compress markdown pyyaml sqlite-vec")
    if result.returncode != 0:
        fail(f"pip install falhou: {result.stderr.strip()}")
        return False

    ok("venv criado + deps instaladas")
    return True


# ─── Phase 5b: Tools venv ───

def phase_tools_venv(cfg, dry_run, skip_venv=False):
    header("5b/8  Tools venv (edge-consult, review-gate, etc.)")
    if skip_venv:
        warn("--skip-venv: pulando")
        return True

    edge = Path(cfg["edge_home_expanded"])
    tools_dir = edge / "tools"
    venv_dir = tools_dir / ".venv"
    reqs = tools_dir / "requirements.txt"

    # Also check in REPO_ROOT
    if not reqs.exists():
        reqs = REPO_ROOT / "tools" / "requirements.txt"
    if not reqs.exists():
        warn("tools/requirements.txt não encontrado — pulando venv de tools")
        return True

    if venv_dir.exists() and (venv_dir / "bin" / "python3").exists():
        ok("tools venv já existe")
        return True

    if dry_run:
        print(f"  [DRY] python3 -m venv {venv_dir}")
        print(f"  [DRY] pip install -r {reqs}")
        return True

    result = run(f"python3 -m venv {venv_dir}")
    if result.returncode != 0:
        fail(f"python3 -m venv falhou: {result.stderr.strip()}")
        warn("Tente: sudo apt install python3-venv")
        return False

    pip = venv_dir / "bin" / "pip"
    result = run(f"{pip} install -q -r {reqs}")
    if result.returncode != 0:
        fail(f"pip install falhou: {result.stderr.strip()}")
        return False

    # Update shebangs in Python tools to use venv
    for tool in tools_dir.glob("*.py"):
        content = tool.read_text()
        if content.startswith("#!/usr/bin/env python3"):
            content = content.replace(
                "#!/usr/bin/env python3",
                f"#!{venv_dir}/bin/python3",
                1
            )
            tool.write_text(content)

    ok("tools venv criado + deps instaladas + shebangs atualizados")
    return True


# ─── Phase 6: Systemd ───

def phase_systemd(cfg, dry_run):
    header("6/8  Systemd")
    if platform.system() != "Linux":
        warn(f"Plataforma {platform.system()} — pulando systemd")
        return True

    service_dir = Path.home() / ".config" / "systemd" / "user"

    units = {
        "agent-heartbeat.service": "agent-heartbeat.service",
        "agent-heartbeat.timer": "agent-heartbeat.timer",
        "blog-server.service": "blog-server.service",
    }

    if not dry_run:
        service_dir.mkdir(parents=True, exist_ok=True)

    for src_name, dst_name in units.items():
        src = REPO_ROOT / "systemd" / src_name
        # Try rendered (without .tpl) first, then original
        if not src.exists():
            src = REPO_ROOT / "systemd" / (src_name + ".tpl")
        if src.exists():
            if not dry_run:
                shutil.copy2(src, service_dir / dst_name)
            ok(dst_name)
        else:
            warn(f"{src_name} não encontrado")

    if not dry_run:
        run("systemctl --user daemon-reload")
        run("systemctl --user enable blog-server.service")
        run("systemctl --user restart blog-server.service")
    ok("systemd daemon-reload + blog-server enabled + started")
    return True


# ─── Phase 7: Tools ───

def phase_tools(cfg, dry_run):
    header("7/8  Tools + Symlinks")
    edge = Path(cfg["edge_home_expanded"])
    tools_src = REPO_ROOT / "tools"
    tools_dst = edge / "tools"
    local_bin = Path.home() / ".local" / "bin"

    if not tools_src.exists():
        warn("tools/ não encontrado")
        return True

    if not dry_run:
        tools_dst.mkdir(parents=True, exist_ok=True)
        local_bin.mkdir(parents=True, exist_ok=True)

    # Copy tools (if repo != edge_home)
    count = 0
    if tools_src.resolve() != tools_dst.resolve():
        for tool in tools_src.iterdir():
            if tool.name.startswith(".") or tool.name.startswith("__") or tool.is_dir():
                continue
            if not dry_run:
                dst = tools_dst / tool.name
                shutil.copy2(tool, dst)
                dst.chmod(0o755)
            count += 1
        ok(f"{count} tools copiados → {tools_dst}")
    else:
        count = len([f for f in tools_src.iterdir() if f.is_file() and not f.name.startswith(".")])
        # Just ensure executable
        if not dry_run:
            for tool in tools_src.iterdir():
                if tool.is_file() and not tool.name.startswith("."):
                    tool.chmod(0o755)
        ok(f"Tools: repo = edge_home (in-place, {count} tools)")

    # Symlink key tools to ~/.local/bin/
    key_tools = ["edge-render", "edge-apply", "edge-doctor",
                 "edge-sources", "edge-consult.py", "edge-digest",
                 "edge-event", "edge-task", "edge-scratch"]
    linked = 0
    for name in key_tools:
        src = tools_dst / name
        if not src.exists():
            src = tools_src / name
        if src.exists() and not dry_run:
            link = local_bin / name
            link.unlink(missing_ok=True)
            link.symlink_to(src.resolve())
            linked += 1
    ok(f"{linked} symlinks em ~/.local/bin/")

    # Copy search tools
    search_src = REPO_ROOT / "search"
    search_dst = edge / "search"
    if search_src.exists() and search_src.resolve() != search_dst.resolve():
        if not dry_run:
            search_dst.mkdir(parents=True, exist_ok=True)
            for f in search_src.glob("*.py"):
                shutil.copy2(f, search_dst / f.name)
        ok("Search tools copiados")

    # Create search venv (sqlite-vec, openai for embeddings)
    search_venv = search_dst / ".venv"
    search_reqs = search_dst / "requirements.txt"
    if not search_reqs.exists():
        search_reqs = REPO_ROOT / "search" / "requirements.txt"
    if search_reqs.exists() and not (search_venv / "bin" / "python3").exists():
        if not dry_run:
            result = run(f"python3 -m venv {search_venv}")
            if result.returncode == 0:
                pip = search_venv / "bin" / "pip"
                run(f"{pip} install -q -r {search_reqs}")
                ok("Search venv criado")
            else:
                warn("Search venv falhou")
    elif (search_venv / "bin" / "python3").exists():
        ok("Search venv já existe")

    # Create edge-index and edge-search wrappers (load secrets for API keys)
    if not dry_run:
        for wrapper_name, script in [("edge-index", "ingest.py"), ("edge-search", "search.py")]:
            wrapper = local_bin / wrapper_name
            wrapper.write_text(
                f'#!/bin/bash\n'
                f'EDGE_DIR="{edge}"\n'
                f'cd "$EDGE_DIR"\n'
                f'[ -f "$EDGE_DIR/secrets/keys.env" ] && set -a && source "$EDGE_DIR/secrets/keys.env" && set +a\n'
                f'"{search_dst / ".venv" / "bin" / "python3"}" "{search_dst / script}" "$@"\n'
            )
            wrapper.chmod(0o755)
        ok("edge-index + edge-search wrappers criados (com secrets)")

    # Configure git identity (needed for consolidar-status commits)
    if not dry_run:
        name = cfg.get("name", "agent")
        run(f'git config --global user.name "{name}"')
        run(f'git config --global user.email "{name}@edge-of-chaos"')
        ok(f"Git identity: {name}")

    # Ensure .bashrc has PATH
    bashrc = Path.home() / ".bashrc"
    if not dry_run:
        bashrc_content = bashrc.read_text() if bashrc.exists() else ""
        additions = []
        if ".local/bin" not in bashrc_content:
            additions.append('export PATH="$HOME/.local/bin:$PATH"')
        if "EDGE_DIR" not in bashrc_content:
            additions.append(f'export EDGE_DIR="{edge}"')
        if additions:
            with open(bashrc, "a") as f:
                f.write("\n" + "\n".join(additions) + "\n")
            ok(f".bashrc atualizado ({len(additions)} linhas)")
        else:
            ok(".bashrc já configurado")

    # Copy bin/ (health scripts)
    bin_src = REPO_ROOT / "bin"
    bin_dst = edge / "bin"
    if bin_src.exists() and bin_src.resolve() != bin_dst.resolve():
        if not dry_run:
            bin_dst.mkdir(parents=True, exist_ok=True)
            for f in bin_src.glob("*.sh"):
                dst = bin_dst / f.name
                shutil.copy2(f, dst)
                dst.chmod(0o755)
        ok("Health scripts copiados")

    return True


# ─── Main ───

def main():
    parser = argparse.ArgumentParser(description="Provision agent from agent.yaml")
    parser.add_argument("--config", "-c", default="agent.yaml")
    parser.add_argument("--dry-run", "-n", action="store_true")
    parser.add_argument("--skip-venv", action="store_true")
    args = parser.parse_args()

    config_path = Path(args.config).resolve()
    if not config_path.exists():
        print(f"{RED}✗{RESET} {config_path} não encontrado")
        print(f"  Copie agent.yaml.example → agent.yaml e preencha")
        sys.exit(1)

    cfg = load_config(config_path)
    name = cfg.get("name", "?")
    codename = cfg.get("codename", "?")

    print(f"\n{BOLD}edge-apply: {name} ({codename}){RESET}")
    print(f"  edge_home: {cfg['edge_home_expanded']}")
    print(f"  blog: {cfg.get('blog_host', 'auto')}:{cfg.get('blog_port', 8766)}")
    print(f"  skills: {cfg.get('skill_prefix', codename)}-*")
    print(f"  onboarding: {'ON' if cfg.get('onboarding_mode') else 'OFF'}")
    if args.dry_run:
        print(f"  {YELLOW}[DRY RUN]{RESET}")

    results = []
    results.append(("Render", phase_render(str(config_path), args.dry_run)))
    results.append(("Dirs", phase_dirs(cfg, args.dry_run)))
    results.append(("Skills", phase_skills(cfg, args.dry_run)))
    results.append(("Identity", phase_identity(cfg, args.dry_run)))
    results.append(("Blog", phase_venv(cfg, args.dry_run, args.skip_venv)))
    results.append(("Tools venv", phase_tools_venv(cfg, args.dry_run, args.skip_venv)))
    results.append(("Systemd", phase_systemd(cfg, args.dry_run)))
    results.append(("Tools", phase_tools(cfg, args.dry_run)))

    passed = sum(1 for _, r in results if r)
    failed = sum(1 for _, r in results if not r)
    color = GREEN if failed == 0 else RED

    print(f"\n{color}━━━  {passed}/{len(results)} fases OK  ━━━{RESET}")

    if failed == 0:
        prefix = cfg.get("skill_prefix", codename)
        print(f"\n{GREEN}✓{RESET} Instalação concluída. Próximos passos:")
        print(f"  1. Verificar:  python3 tools/edge-doctor --config agent.yaml")
        print(f"  2. Blog:       systemctl --user enable --now blog-server")
        print(f"  3. Heartbeat:  systemctl --user enable --now agent-heartbeat.timer")
        print(f"  4. Testar:     claude -p '/{prefix}-heartbeat'")
        print(f"  5. Doctor:     python3 tools/edge-doctor --config agent.yaml")
    else:
        print(f"\n{RED}✗{RESET} {failed} fase(s) falharam.")

    sys.exit(0 if failed == 0 else 1)


if __name__ == "__main__":
    main()
