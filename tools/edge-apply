        )
        wf_created += 1
    if wf_created:
        ok(f"{wf_created} seed workflow entries created")
        seeded += wf_created

    if seeded > 0:
        ok(f"{seeded} seed files generated from agent.yaml")
    else:
        ok("Seed files already exist — skipping")

    return True


# ─── Phase 11: Routines (operator-authored workflows via LLM) ───

def phase_routines(cfg, dry_run):
    """Render `routines:` free-form prose into operator-authored workflow entries.

    Closes #90 (feature) and #91 (claude -p preferred over OpenAI).

    For each prose string in `agent.yaml:routines`, converts it via LLM
    (Claude Code CLI → OpenAI fallback → defer) into a blog entry with
    frontmatter status:approved, authored_by:operator. Idempotent via
    source_hash in the generated frontmatter — re-runs skip unchanged prose.

    If both LLM providers are unavailable, the prose is appended to
    state/pending-routines.yaml for the first heartbeat to pick up — install
    never blocks on routine rendering.
    """
    header("11/11 Routines (operator-authored workflows)")

    routines = cfg.get("routines", [])
    if not isinstance(routines, list):
        warn("agent.yaml `routines:` is not a list — skipping")
        return True
    routines = [r for r in routines if isinstance(r, str) and r.strip()]
    if not routines:
        ok("No routines declared in agent.yaml — skipping")
        return True

    if dry_run:
        ok(f"[DRY RUN] Would render {len(routines)} routine(s)")
        return True

    edge = Path(cfg["edge_home_expanded"])
    entries_dir = edge / "blog" / "entries"
    entries_dir.mkdir(parents=True, exist_ok=True)
    today = datetime.now().strftime("%Y-%m-%d")

    # Index existing entries by source_hash (from frontmatter) to detect
    # idempotent skips and operator-edits (hash mismatch means someone edited
    # the generated file — we leave it alone and log the friction).
    existing_by_hash: dict[str, Path] = {}
    for entry in entries_dir.glob("*-workflow-*.md"):
        try:
            text = entry.read_text(encoding="utf-8")
        except OSError:
            continue
        m = re.search(r'^source_hash:\s*"([^"]+)"', text, re.MULTILINE)
        if m:
            existing_by_hash[m.group(1)] = entry

    rendered = 0
    skipped = 0
    deferred: list[dict] = []
    operator_edited = 0

    for idx, prose in enumerate(routines):
        h = source_hash(prose)
        if h in existing_by_hash:
            skipped += 1
            continue

        parsed, provider = render_routine(prose)
        if parsed is None:
            deferred.append({
                "prose": prose,
                "source_hash": h,
                "index": idx,
                "added_at": datetime.now().isoformat(timespec="seconds"),
            })
            continue

        slug = slugify_title(parsed["title"])
        filename = f"{today}-workflow-{slug}.md"
        entry_path = entries_dir / filename

        # Slug collision: if a file with the same slug exists but different
        # hash, it means the operator edited the yaml prose and we need to
        # regenerate. Preserve citation history by reusing the same slug.
        if entry_path.exists():
            existing_text = entry_path.read_text(encoding="utf-8")
            existing_hash_m = re.search(r'^source_hash:\s*"([^"]+)"', existing_text, re.MULTILINE)
            if existing_hash_m and existing_hash_m.group(1) != h:
                # Check if there's a hash at all in the existing — if not,
                # the operator may have hand-edited; respect that.
                pass  # fall through to overwrite (regeneration path)
            elif not existing_hash_m:
                operator_edited += 1
                warn(f"Routine {idx}: {filename} exists without source_hash — operator-edited, skipping to avoid overwrite")
                continue

        markdown = build_entry_markdown(
            prose=prose,
            parsed=parsed,
            source_hash_value=h,
            index=idx,
            date_str=today,
            provider=provider or "unknown",
        )
        entry_path.write_text(markdown, encoding="utf-8")
        rendered += 1

    # Write defer file if any routines couldn't be rendered
    pending_file = edge / "state" / "pending-routines.yaml"
    if deferred:
        pending_file.parent.mkdir(parents=True, exist_ok=True)
        # If pending file exists, merge (avoid duplicates by hash)
        existing_pending = []
        if pending_file.exists():
            try:
                existing_pending = yaml.safe_load(pending_file.read_text()) or []
            except yaml.YAMLError:
                existing_pending = []
        existing_hashes = {d.get("source_hash") for d in existing_pending if isinstance(d, dict)}
        for d in deferred:
            if d["source_hash"] not in existing_hashes:
                existing_pending.append(d)
        pending_file.write_text(
            yaml.safe_dump(existing_pending, allow_unicode=True, sort_keys=False),
            encoding="utf-8",
        )
        warn(
            f"{len(deferred)} routine(s) deferred to {pending_file.relative_to(edge)} — "
            f"no LLM provider available (install `claude` CLI or set OPENAI_API_KEY). "
            f"First heartbeat will render them."
        )
    elif pending_file.exists():
        # All routines rendered successfully — clean up stale pending entries
        # whose hashes we just rendered.
        try:
            existing_pending = yaml.safe_load(pending_file.read_text()) or []
            rendered_hashes = {source_hash(r) for r in routines}
            remaining = [d for d in existing_pending if isinstance(d, dict) and d.get("source_hash") not in rendered_hashes]
            if remaining:
                pending_file.write_text(
                    yaml.safe_dump(remaining, allow_unicode=True, sort_keys=False),
                    encoding="utf-8",
                )
            else:
                pending_file.unlink()
        except yaml.YAMLError:
            pass

    parts = []
    if rendered:
        parts.append(f"{rendered} rendered")
    if skipped:
        parts.append(f"{skipped} skipped (unchanged)")
    if operator_edited:
        parts.append(f"{operator_edited} operator-edited")
    if deferred:
        parts.append(f"{len(deferred)} deferred")
    ok(f"Routines: {', '.join(parts) if parts else 'nothing to do'}")
    return True


# ─── Main ───

def main():
    parser = argparse.ArgumentParser(description="Provision agent from agent.yaml")
    parser.add_argument("--config", "-c", default="agent.yaml")
    parser.add_argument("--dry-run", "-n", action="store_true")
    parser.add_argument("--skip-venv", action="store_true")
    args = parser.parse_args()

    config_path = Path(args.config).resolve()
    if not config_path.exists():
        print(f"{RED}✗{RESET} {config_path} not found")
        print(f"  Copy agent.yaml.example → agent.yaml and fill in")
        sys.exit(1)

    cfg = load_config(config_path)
    name = cfg.get("name", "?")
    codename = cfg.get("codename", "?")

    print(f"\n{BOLD}edge-apply: {name} ({codename}){RESET}")
    print(f"  edge_home: {cfg['edge_home_expanded']}")
    print(f"  blog: {cfg.get('blog_host', 'auto')}:{cfg.get('blog_port', 8766)}")
    print(f"  skills: {cfg.get('skill_prefix', codename)}-*")
    print(f"  onboarding: {'ON' if cfg.get('onboarding_mode') else 'OFF'}")
    if args.dry_run:
        print(f"  {YELLOW}[DRY RUN]{RESET}")

    results = []
    results.append(("Render", phase_render(str(config_path), args.dry_run)))
    results.append(("Dirs", phase_dirs(cfg, args.dry_run)))
    results.append(("Skills", phase_skills(cfg, args.dry_run)))
    results.append(("Identity", phase_identity(cfg, args.dry_run)))
    results.append(("Blog", phase_venv(cfg, args.dry_run, args.skip_venv)))
    results.append(("Tools venv", phase_tools_venv(cfg, args.dry_run, args.skip_venv)))
    results.append(("Systemd", phase_systemd(cfg, args.dry_run)))
    results.append(("Tools", phase_tools(cfg, args.dry_run)))
    results.append(("Avatar", phase_avatar(cfg, args.dry_run)))
    results.append(("Seed", phase_seed(cfg, args.dry_run)))
    results.append(("Routines", phase_routines(cfg, args.dry_run)))

    passed = sum(1 for _, r in results if r)
    failed = sum(1 for _, r in results if not r)
    color = GREEN if failed == 0 else RED

    print(f"\n{color}━━━  {passed}/{len(results)} phases OK  ━━━{RESET}")

    if failed > 0:
        print(f"\n{RED}✗{RESET} {failed} phase(s) failed.")
        sys.exit(1)

    # --- Run edge-doctor as infrastructure baseline (#111) ---
    prefix = cfg.get("skill_prefix", codename)
    edge = Path(cfg["edge_home_expanded"])

    header("Health baseline: edge-doctor")
    if not args.dry_run:
        doctor_result = subprocess.run(
            ["bash", str(edge / "bin" / "edge-check.sh")],
            capture_output=True, text=True, timeout=60,
            cwd=str(edge),
            env={**os.environ, "EDGE_DIR": str(edge), "HEALTH_DIR": str(edge / "health")},
        )
        if (edge / "health" / "current.json").exists():
            try:
                health = json.load(open(edge / "health" / "current.json"))
                score = health.get("score", "?")
                status = health.get("status", "?")
                ok(f"Health baseline: score={score} status={status}")
            except Exception:
                ok("Health baseline: current.json written")
        else:
            warn("edge-check.sh ran but current.json not created")
    else:
        print(f"  {YELLOW}[DRY RUN] would run edge-check.sh{RESET}")

    # --- Final phase: run first_steps as batch + enable heartbeat (#103 #104) ---
    fs_file = edge / "state" / "first-steps.json"

    if fs_file.exists():
        try:
            steps = json.load(open(fs_file))
            pending = [s for s in steps if s.get("status") == "pending"]
        except Exception:
            pending = []

        if pending:
            header("Bootstrap: first_steps")
            # Check if claude CLI is available (running inside Claude Code)
            claude_available = shutil.which("claude") is not None
            if claude_available:
                print(f"  Running {len(pending)} first_steps as batch (claude CLI detected)...")
                for step in pending:
                    step_id = step.get("id", "?")
                    task = step.get("task", "")
                    print(f"\n  [{step_id}] {task[:80]}...")
                    if args.dry_run:
                        print(f"  {YELLOW}[DRY RUN] would execute via claude -p{RESET}")
                        continue
                    try:
                        prompt = (
                            f"You are running a first_step during bootstrap. "
                            f"Follow the FULL standard pipeline:\n"
                            f"1. Read required context (memory/rules-core.md, memory/personality.md, "
                            f"memory/metodo.md, memory/debugging.md, config/pre-skill.md, config/strategy.md)\n"
                            f"2. Execute the step\n"
                            f"3. If the step produces a report or blog entry, it MUST go through "
                            f"edge-consult (adversarial review) AND review-gate before publishing. "
                            f"No exceptions — this is the first output the operator will see.\n"
                            f"4. Run post-skill.md procedures after completion\n"
                            f"5. Mark as done when complete, or blocked if you cannot proceed.\n\n"
                            f"Step: {task}"
                        )
                        result = subprocess.run(
                            ["claude", "-p", prompt],
                            capture_output=True, text=True, timeout=1800,
                            cwd=str(edge),
                        )
                        # Mark as done
                        step["status"] = "done"
                        step["completed_at"] = datetime.now().isoformat()
                        if result.returncode != 0:
                            step["status"] = "blocked"
                            step["blocked_reason"] = result.stderr[:200] if result.stderr else "non-zero exit"
                            print(f"  {YELLOW}⚠ blocked: {step.get('blocked_reason', '?')[:80]}{RESET}")
                        else:
                            print(f"  {GREEN}✓{RESET} done")
                    except subprocess.TimeoutExpired:
                        step["status"] = "blocked"
                        step["blocked_reason"] = "timeout (10min)"
                        print(f"  {YELLOW}⚠ blocked: timeout{RESET}")
                    except Exception as exc:
                        step["status"] = "blocked"
                        step["blocked_reason"] = str(exc)[:200]
                        print(f"  {YELLOW}⚠ blocked: {exc}{RESET}")

                # Save updated steps
                if not args.dry_run:
                    fs_file.write_text(json.dumps(steps, indent=2, ensure_ascii=False) + "\n")
                done = sum(1 for s in steps if s.get("status") == "done")
                blocked = sum(1 for s in steps if s.get("status") == "blocked")
                print(f"\n  Bootstrap: {done} done, {blocked} blocked, {len(pending)} total")
            else:
                print(f"\n  {YELLOW}⚠ claude CLI not found — first_steps deferred to first heartbeat{RESET}")
                print(f"  Run manually: claude -p '/{prefix}-heartbeat'")

    # Enable heartbeat timer
    print(f"\n{GREEN}✓{RESET} Installation complete.")
    print(f"  Heartbeat timer enabling...")
    if not args.dry_run:
        subprocess.run(
            ["systemctl", "--user", "enable", "--now", "agent-heartbeat.timer"],
            capture_output=True,
        )
    print(f"  {GREEN}✓{RESET} Heartbeat timer active — autonomous operation started.")

    sys.exit(0)


if __name__ == "__main__":
    main()
