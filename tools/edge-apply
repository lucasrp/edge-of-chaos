# ─── Phase 5: Blog venv ───

def phase_venv(cfg, dry_run, skip_venv=False):
    header("5a/8  Blog (venv + files)")
    if skip_venv:
        warn("--skip-venv: skipping")
        return True

    edge = Path(cfg["edge_home_expanded"])
    blog_dst = edge / "blog"
    venv_dir = blog_dst / ".venv"

    # Copy blog app files (if repo != edge_home)
    blog_src = REPO_ROOT / "blog"
    if blog_src.resolve() != blog_dst.resolve():
        if not dry_run:
            for f in blog_src.glob("*.py"):
                shutil.copy2(f, blog_dst / f.name)
            for f in blog_src.glob("*.sh"):
                dst = blog_dst / f.name
                shutil.copy2(f, dst)
                dst.chmod(0o755)
            for d in ["templates", "static"]:
                src_d = blog_src / d
                dst_d = blog_dst / d
                if src_d.exists():
                    shutil.copytree(src_d, dst_d, dirs_exist_ok=True)
        ok("Blog files copied")
    else:
        ok("Blog: repo = edge_home (in-place)")

    # Create venv
    if venv_dir.exists() and (venv_dir / "bin" / "python3").exists():
        ok("venv already exists")
        return True

    if dry_run:
        print(f"  [DRY] python3 -m venv {venv_dir}")
        return True

    result = run(f"python3 -m venv {venv_dir}")
    if result.returncode != 0:
        fail(f"python3 -m venv failed: {result.stderr.strip()}")
        warn("Try: sudo apt install python3-venv")
        return False

    pip = venv_dir / "bin" / "pip"
    result = run(f"{pip} install -q flask flask-compress markdown pyyaml sqlite-vec openai")
    if result.returncode != 0:
        fail(f"pip install failed: {result.stderr.strip()}")
        return False

    ok("venv created + deps installed")
    return True


# ─── Phase 5b: Tools venv ───

def phase_tools_venv(cfg, dry_run, skip_venv=False):
    header("5b/8  Tools venv (edge-consult, review-gate, etc.)")
    if skip_venv:
        warn("--skip-venv: skipping")
        return True

    edge = Path(cfg["edge_home_expanded"])
    tools_dir = edge / "tools"
    venv_dir = tools_dir / ".venv"
    reqs = tools_dir / "requirements.txt"

    # Also check in REPO_ROOT
    if not reqs.exists():
        reqs = REPO_ROOT / "tools" / "requirements.txt"
    if not reqs.exists():
        warn("tools/requirements.txt not found — skipping tools venv")
        return True

    venv_existed = venv_dir.exists() and (venv_dir / "bin" / "python3").exists()

    if not venv_existed:
        if dry_run:
            print(f"  [DRY] python3 -m venv {venv_dir}")
            print(f"  [DRY] pip install -r {reqs}")
            return True

        result = run(f"python3 -m venv {venv_dir}")
        if result.returncode != 0:
            fail(f"python3 -m venv failed: {result.stderr.strip()}")
            warn("Try: sudo apt install python3-venv")
            return False

        pip = venv_dir / "bin" / "pip"
        result = run(f"{pip} install -q -r {reqs}")
        if result.returncode != 0:
            fail(f"pip install failed: {result.stderr.strip()}")
            return False

    # Shebangs stay as #!/usr/bin/env python3 (portable).
    # The ~/.local/bin/ wrappers handle venv activation per instance.
    # Do NOT rewrite shebangs — they are genotype and contaminate other instances on push.

    if venv_existed:
        ok("tools venv already exists")
    else:
        ok("tools venv created + deps installed")
    return True


# ─── Phase 6: Systemd ───

def phase_systemd(cfg, dry_run):
    header("6/8  Systemd")
    if platform.system() != "Linux":
        warn(f"Platform {platform.system()} — skipping systemd")
        return True

    service_dir = Path.home() / ".config" / "systemd" / "user"

    units = {
        "agent-heartbeat.service": "agent-heartbeat.service",
        "agent-heartbeat.timer": "agent-heartbeat.timer",
        "blog-server.service": "blog-server.service",
    }

    if not dry_run:
        service_dir.mkdir(parents=True, exist_ok=True)

    for src_name, dst_name in units.items():
        src = REPO_ROOT / "systemd" / src_name
        # Try rendered (without .tpl) first, then original
        if not src.exists():
            src = REPO_ROOT / "systemd" / (src_name + ".tpl")
        if src.exists():
            if not dry_run:
                shutil.copy2(src, service_dir / dst_name)
            ok(dst_name)
        else:
            warn(f"{src_name} not found")

    # Install heartbeat.sh wrapper to ~/.local/bin/
    hb_src = REPO_ROOT / "config" / "heartbeat.sh"
    if not hb_src.exists():
        hb_src = REPO_ROOT / "config" / "heartbeat.sh.tpl"  # fallback to template
    local_bin = Path.home() / ".local" / "bin"
    if hb_src.exists() and not dry_run:
        local_bin.mkdir(parents=True, exist_ok=True)
        shutil.copy2(hb_src, local_bin / "heartbeat.sh")
        (local_bin / "heartbeat.sh").chmod(0o755)
        ok("heartbeat.sh → ~/.local/bin/")
    elif not hb_src.exists():
        warn("config/heartbeat.sh not found")

    if not dry_run:
        run("systemctl --user daemon-reload")
        run("systemctl --user enable blog-server.service")
        run("systemctl --user restart blog-server.service")
        run("systemctl --user enable --now agent-heartbeat.timer")
    ok("systemd daemon-reload + blog-server enabled + started + heartbeat timer active")
    return True


# ─── Phase 7: Tools ───

def phase_tools(cfg, dry_run):
    header("7/8  Tools + Symlinks")
    edge = Path(cfg["edge_home_expanded"])
    tools_src = REPO_ROOT / "tools"
    tools_dst = edge / "tools"
    local_bin = Path.home() / ".local" / "bin"

    if not tools_src.exists():
        warn("tools/ not found")
        return True

    if not dry_run:
        tools_dst.mkdir(parents=True, exist_ok=True)
        local_bin.mkdir(parents=True, exist_ok=True)

    # Copy tools (if repo != edge_home)
    count = 0
    if tools_src.resolve() != tools_dst.resolve():
        for tool in tools_src.iterdir():
            if tool.name.startswith(".") or tool.name.startswith("__") or tool.is_dir():
                continue
            if not dry_run:
                dst = tools_dst / tool.name
                shutil.copy2(tool, dst)
                dst.chmod(0o755)
            count += 1
        ok(f"{count} tools copied → {tools_dst}")
    else:
        count = len([f for f in tools_src.iterdir() if f.is_file() and not f.name.startswith(".")])
        # Just ensure executable
        if not dry_run:
            for tool in tools_src.iterdir():
                if tool.is_file() and not tool.name.startswith("."):
                    tool.chmod(0o755)
        ok(f"Tools: repo = edge_home (in-place, {count} tools)")

    # Symlink ALL tools to ~/.local/bin/ (not just a hardcoded list)
    linked = 0
    for tool in tools_dst.iterdir():
        if tool.name.startswith(".") or tool.name.startswith("__") or tool.is_dir():
            continue
        if tool.suffix in (".md", ".yaml", ".yml", ".txt", ".css", ".svg", ".json"):
            continue  # skip non-executables
        if not dry_run:
            # Link name: strip .py suffix (edge-consult.py → edge-consult)
            link_name = tool.stem if tool.suffix == ".py" else tool.name
            link = local_bin / link_name
            link.unlink(missing_ok=True)
            # Python tools get a wrapper that activates the venv.
            # Bash/other tools get a plain symlink.
            venv_python = tools_dst / ".venv" / "bin" / "python3"
            if tool.suffix == ".py" or _file_starts_with(tool, "#!/usr/bin/env python3"):
                link.write_text(
                    '#!/bin/bash\n'
                    f'exec "{venv_python}" "{tool.resolve()}" "$@"\n'
                )
                link.chmod(0o755)
            else:
                link.symlink_to(tool.resolve())
            linked += 1
    # Create hyphenated aliases for tools with underscores (validate_svg → validate-svg)
    venv_python = tools_dst / ".venv" / "bin" / "python3"
    for tool in tools_dst.iterdir():
        if tool.is_file() and "_" in tool.stem and tool.suffix == ".py":
            alias_name = tool.stem.replace("_", "-")
            alias = local_bin / alias_name
            if not alias.exists() and not dry_run:
                alias.write_text(
                    '#!/bin/bash\n'
                    f'exec "{venv_python}" "{tool.resolve()}" "$@"\n'
                )
                alias.chmod(0o755)
                linked += 1

    # Also link consolidate-state from blog/
    cs = edge / "blog" / "consolidate-state.sh"
    if cs.exists() and not dry_run:
        link = local_bin / "consolidate-state"
        link.unlink(missing_ok=True)
        link.symlink_to(cs.resolve())
        linked += 1
    ok(f"{linked} symlinks in ~/.local/bin/")

    # Copy search tools
    search_src = REPO_ROOT / "search"
    search_dst = edge / "search"
    if search_src.exists() and search_src.resolve() != search_dst.resolve():
        if not dry_run:
            search_dst.mkdir(parents=True, exist_ok=True)
            for f in search_src.glob("*.py"):
                shutil.copy2(f, search_dst / f.name)
        ok("Search tools copied")

    # Create search venv (sqlite-vec, openai for embeddings)
    search_venv = search_dst / ".venv"
    search_reqs = search_dst / "requirements.txt"
    if not search_reqs.exists():
        search_reqs = REPO_ROOT / "search" / "requirements.txt"
    if search_reqs.exists() and not (search_venv / "bin" / "python3").exists():
        if not dry_run:
            result = run(f"python3 -m venv {search_venv}")
            if result.returncode == 0:
                pip = search_venv / "bin" / "pip"
                run(f"{pip} install -q -r {search_reqs}")
                ok("Search venv created")
            else:
                warn("Search venv failed")
    elif (search_venv / "bin" / "python3").exists():
        ok("Search venv already exists")

    # Create edge-index and edge-search wrappers (load secrets for API keys)
    # Wrappers resolve paths dynamically via readlink so they survive user migrations
    if not dry_run:
        for wrapper_name, script in [("edge-index", "ingest.py"), ("edge-search", "search.py")]:
            wrapper = search_dst / wrapper_name.replace("edge-", "edge-")
            # Write portable source wrapper in search/ (the canonical copy)
            src_wrapper = search_dst / wrapper_name
            src_wrapper.write_text(
                '#!/bin/bash\n'
                'SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"\n'
                'EDGE_DIR="$(dirname "$SCRIPT_DIR")"\n'
                'cd "$EDGE_DIR"\n'
                '[ -f "$EDGE_DIR/secrets/keys.env" ] && set -a && source "$EDGE_DIR/secrets/keys.env" && set +a\n'
                f'"$SCRIPT_DIR/.venv/bin/python3" "$SCRIPT_DIR/{script}" "$@"\n'
            )
            src_wrapper.chmod(0o755)
            # Symlink from ~/.local/bin/ to the source wrapper
            link = local_bin / wrapper_name
            link.unlink(missing_ok=True)
            link.symlink_to(src_wrapper.resolve())
        ok("edge-index + edge-search wrappers created (portable, with secrets)")

    # Create SQLite database if missing
    sqlite_db = edge / "edge-memory.db"
    if not sqlite_db.exists() and not dry_run:
        result = run(f'sqlite3 "{sqlite_db}" "CREATE TABLE IF NOT EXISTS _init(ts TEXT); INSERT INTO _init VALUES(datetime(\'now\')); DROP TABLE _init;"')
        if result.returncode == 0:
            ok("SQLite database created")
        else:
            warn("SQLite database creation failed")

    # Configure git identity (needed for consolidate-state commits)
    if not dry_run:
        name = cfg.get("name", "agent")
        run(f'git config --global user.name "{name}"')
        run(f'git config --global user.email "{name}@edge-of-chaos"')
        ok(f"Git identity: {name}")

    # Generate per-tool .env files from keys.env
    # Tools expect secrets/openai.env, secrets/x-api.env etc.
    keys_env = edge / "secrets" / "keys.env"
    if keys_env.exists() and not dry_run:
        keys = {}
        for line in keys_env.read_text().splitlines():
            if "=" in line and not line.startswith("#"):
                k, v = line.split("=", 1)
                keys[k.strip()] = v.strip()

        env_map = {
            "openai.env": ["OPENAI_API_KEY"],
            "exa.env": ["EXA_API_KEY"],
            "xai.env": ["XAI_API_KEY"],
            "cloudflare.env": ["CLOUDFLARE_ACCOUNT_ID", "CLOUDFLARE_API_TOKEN"],
            "x-api.env": ["X_API_KEY", "X_API_SECRET", "X_ACCESS_TOKEN",
                          "X_ACCESS_TOKEN_SECRET", "X_BEARER_TOKEN"],
            "moltbook.env": ["MOLTBOOK_API_KEY", "MOLTBOOK_USERNAME", "MOLTBOOK_AGENT_ID"],
        }
        generated = 0
        for filename, key_names in env_map.items():
            lines = [f"{k}={keys[k]}" for k in key_names if k in keys and keys[k]]
            if lines:
                env_file = edge / "secrets" / filename
                env_file.write_text("\n".join(lines) + "\n")
                env_file.chmod(0o600)
                generated += 1
        if generated:
            ok(f"{generated} per-tool .env files generated from keys.env")

    # Write ~/.edge-env with PATH exports, then source it from .bashrc (before
    # the non-interactive guard) and .profile (for login shells). This covers:
    #   - ssh user "command"  (non-interactive, sources .bashrc top)
    #   - systemd timers      (inherit from .profile via PAM)
    #   - interactive shells   (source .bashrc which sources .edge-env)
    edge_env = Path.home() / ".edge-env"
    bashrc = Path.home() / ".bashrc"
    profile = Path.home() / ".profile"
    if not dry_run:
        # Build the env file content
        tools_dir = f"{edge}/tools"
        env_lines = [
            f'export PATH="$HOME/.local/bin:{tools_dir}:$PATH"',
            f'export EDGE_DIR="{edge}"',
            f'export MEMORY_PROJECT_DIR="{cfg["memory_project_dir"]}"',
        ]
        edge_env.write_text("\n".join(env_lines) + "\n")
        ok(f".edge-env written ({len(env_lines)} exports)")

        # Prepend sourcing to .bashrc (before non-interactive guard)
        source_line = '[ -f "$HOME/.edge-env" ] && . "$HOME/.edge-env"'
        bashrc_content = bashrc.read_text() if bashrc.exists() else ""
        if ".edge-env" not in bashrc_content:
            bashrc.write_text(source_line + "\n" + bashrc_content)
            ok(".bashrc: .edge-env sourced (prepended before guard)")
        else:
            ok(".bashrc: .edge-env already sourced")

        # Also append to .profile for login shells
        profile_content = profile.read_text() if profile.exists() else ""
        if ".edge-env" not in profile_content:
            with open(profile, "a") as f:
                f.write("\n" + source_line + "\n")
            ok(".profile: .edge-env sourced (appended)")
        else:
            ok(".profile: .edge-env already sourced")

    # Copy bin/ (health scripts)
    bin_src = REPO_ROOT / "bin"
    bin_dst = edge / "bin"
    if bin_src.exists() and bin_src.resolve() != bin_dst.resolve():
        if not dry_run:
            bin_dst.mkdir(parents=True, exist_ok=True)
            for f in bin_src.glob("*.sh"):
                dst = bin_dst / f.name
                shutil.copy2(f, dst)
                dst.chmod(0o755)
        ok("Health scripts copied")

    return True


# ─── Phase 8b: Avatar generation ───

def phase_avatar(cfg, dry_run):
    header("8b/9  Avatar")
    edge = Path(cfg["edge_home_expanded"])
    avatar_path = edge / "blog" / "static" / "avatar.png"

    if avatar_path.exists() and avatar_path.stat().st_size > 0:
        ok(f"Avatar already exists ({avatar_path.stat().st_size // 1024}K)")
        return True

    if dry_run:
        print(f"  [DRY] Would generate avatar for {cfg.get('name', 'agent')}")
        return True

    name = cfg.get("name", "agent")
    mission = cfg.get("mission", "")
    sketch = cfg.get("character_sketch", cfg.get("voice", ""))
    prompt = f"Create a minimalist, professional avatar icon for an AI agent named '{name}'. Mission: {mission}. Character: {sketch}. Clean vector-style illustration suitable as a 256x256 profile picture. No text, no letters, no words in the image."

    # Try OpenAI first
    keys_env = edge / "secrets" / "keys.env"
    openai_key = ""
    xai_key = ""
    if keys_env.exists():
        for line in keys_env.read_text().splitlines():
            if line.startswith("OPENAI_API_KEY=") and "=" in line:
                openai_key = line.split("=", 1)[1].strip()
            if line.startswith("XAI_API_KEY=") and "=" in line:
                xai_key = line.split("=", 1)[1].strip()

    # Also check env files
    if not openai_key:
        oai_env = edge / "secrets" / "openai.env"
        if oai_env.exists():
            for line in oai_env.read_text().splitlines():
                if line.startswith("OPENAI_API_KEY="):
                    openai_key = line.split("=", 1)[1].strip()
    if not xai_key:
        xai_env = edge / "secrets" / "xai.env"
        if xai_env.exists():
            for line in xai_env.read_text().splitlines():
                if line.startswith("XAI_API_KEY="):
                    xai_key = line.split("=", 1)[1].strip()

    generated = False

    # Write prompt to temp file to avoid shell quoting issues
    prompt_file = edge / ".avatar-prompt.txt"
    prompt_file.write_text(prompt)

    # Write avatar generation script to temp file (avoids shell quoting issues)
    avatar_script = edge / ".avatar-gen.py"

    if openai_key:
        try:
            avatar_script.write_text(
                f'import urllib.request, json, base64, pathlib\n'
                f'prompt = pathlib.Path("{prompt_file}").read_text().strip()\n'
                f'data = json.dumps({{"model": "gpt-image-1", "prompt": prompt, "n": 1, "size": "1024x1024", "quality": "low"}}).encode()\n'
                f'req = urllib.request.Request("https://api.openai.com/v1/images/generations",\n'
                f'    data=data, headers={{"Authorization": "Bearer {openai_key}", "Content-Type": "application/json"}})\n'
                f'resp = urllib.request.urlopen(req, timeout=60)\n'
                f'result = json.loads(resp.read())\n'
                f'img = result["data"][0]\n'
                f'img_bytes = base64.b64decode(img["b64_json"]) if "b64_json" in img else urllib.request.urlopen(img["url"], timeout=30).read()\n'
                f'pathlib.Path("{avatar_path}").write_bytes(img_bytes)\n'
                f'print(f"OK: {{len(img_bytes)}} bytes")\n'
            )
            result = run(f'python3 "{avatar_script}"')
            if result.returncode == 0 and avatar_path.exists():
                ok(f"Avatar generated via OpenAI ({avatar_path.stat().st_size // 1024}K)")
                generated = True
            else:
                warn(f"OpenAI avatar generation failed: {result.stderr.strip()[:100]}")
        except Exception as e:
            warn(f"OpenAI avatar failed: {e}")

    if not generated and xai_key:
        try:
            avatar_script.write_text(
                f'import urllib.request, json, base64, pathlib\n'
                f'prompt = pathlib.Path("{prompt_file}").read_text().strip()\n'
                f'data = json.dumps({{"model": "grok-2-image", "prompt": prompt, "n": 1}}).encode()\n'
                f'req = urllib.request.Request("https://api.x.ai/v1/images/generations",\n'
                f'    data=data, headers={{"Authorization": "Bearer {xai_key}", "Content-Type": "application/json"}})\n'
                f'resp = urllib.request.urlopen(req, timeout=60)\n'
                f'result = json.loads(resp.read())\n'
                f'img = result["data"][0]\n'
                f'img_bytes = base64.b64decode(img["b64_json"]) if "b64_json" in img else urllib.request.urlopen(img["url"], timeout=30).read()\n'
                f'pathlib.Path("{avatar_path}").write_bytes(img_bytes)\n'
                f'print(f"OK: {{len(img_bytes)}} bytes")\n'
            )
            result = run(f'python3 "{avatar_script}"')
            if result.returncode == 0 and avatar_path.exists():
                ok(f"Avatar generated via xAI ({avatar_path.stat().st_size // 1024}K)")
                generated = True
            else:
                warn(f"xAI avatar generation failed: {result.stderr.strip()[:100]}")
        except Exception as e:
            warn(f"xAI avatar failed: {e}")

    if not generated:
        # Fallback: DiceBear API (free, no key needed)
        try:
            result = run(f'curl -sL -o "{avatar_path}" "https://api.dicebear.com/9.x/bottts/png?seed={name}&size=256"')
            if result.returncode == 0 and avatar_path.exists() and avatar_path.stat().st_size > 0:
                ok(f"Avatar generated via DiceBear fallback ({avatar_path.stat().st_size // 1024}K)")
                generated = True
        except Exception:
            pass

    if not generated:
        warn("No avatar generated (no API keys and DiceBear unavailable)")

    prompt_file.unlink(missing_ok=True)
    avatar_script.unlink(missing_ok=True)
    return True


# ─── Phase 9: Seed content ───

def phase_seed(cfg, dry_run):
    header("9/10  Seed content")
    edge = Path(cfg["edge_home_expanded"])
    signals_dir = edge / "state" / "signals"
    name = cfg.get("name", "agent")
    mission = cfg.get("mission", "")
    goal = cfg.get("short_term_goal", "")
    interests = cfg.get("interests", [])
    sketch = cfg.get("character_sketch", cfg.get("voice", ""))
    today = datetime.now().strftime("%Y-%m-%d")
    now = datetime.now().strftime("%Y-%m-%d %H:%M")

    if dry_run:
        print(f"  [DRY] Would generate seed content for {name}")
        return True

    seeded = 0

    # --- Check if signals already exist (skip if so) ---
    any_signal_exists = any(
        (signals_dir / f"{t}.md").exists() and (signals_dir / f"{t}.md").stat().st_size > 0
        for t in ["strategy", "autonomy", "friction", "serendipity"]
    )
    llm_seed = None  # default — set by LLM block if it runs
    if any_signal_exists:
        ok("Seed signals already exist — skipping LLM generation")
    else:
        # --- LLM-powered seed generation ---
        openai_key = ""
        keys_env = edge / "secrets" / "keys.env"
        if keys_env.exists():
            for line in keys_env.read_text().splitlines():
                if line.startswith("OPENAI_API_KEY="):
                    openai_key = line.split("=", 1)[1].strip()
        if not openai_key:
            oai_env = edge / "secrets" / "openai.env"
            if oai_env.exists():
                for line in oai_env.read_text().splitlines():
                    if line.startswith("OPENAI_API_KEY="):
                        openai_key = line.split("=", 1)[1].strip()

        interests_text = "\n".join(
            f"- {i.get('area', i) if isinstance(i, dict) else i}: {i.get('connection', '') if isinstance(i, dict) else ''}"
            for i in interests
        ) if interests else "(none specified)"

        # Check available keys
        available_keys = []
        missing_keys = []
        if keys_env.exists():
            kc = keys_env.read_text()
            for kn in ["OPENAI_API_KEY", "EXA_API_KEY", "XAI_API_KEY", "X_API_KEY", "MOLTBOOK_API_KEY"]:
                if kn + "=" in kc and kc.split(kn + "=")[1].split("\n")[0].strip():
                    available_keys.append(kn)
                else:
                    missing_keys.append(kn)

        llm_prompt = f"""You are bootstrapping an autonomous AI agent. Generate seed content for its operational memory.

Agent: {name}
Mission: {mission}
Short-term goal: {goal}
Character: {sketch}
Interests:
{interests_text}
Available API keys: {', '.join(available_keys) or 'none'}
Missing API keys: {', '.join(missing_keys) or 'none'}

Generate EXACTLY this JSON structure (no markdown, no explanation, just valid JSON):
{{
  "strategy": ["3-5 actionable strategy signals derived from the mission and interests — NOT copies of the interests, but insights about positioning, priorities, and first moves"],
  "autonomy": ["2-4 specific capabilities or access the agent needs to fulfill its mission, based on what keys are missing and what the domain requires"],
  "friction": ["1-2 anticipated friction points for this specific domain and mission"],
  "serendipity": ["1 genuine insight about what makes this agent's position unique or promising"],
  "reflection": ["1 honest observation about the starting conditions"],
  "threads": [
    {{"id": "slug-name", "title": "Thread Title", "description": "What this workstream is about — 1 sentence", "status": "active"}},
    "... 2-3 concrete workstreams derived from the short-term goal, NOT from interests (interests are too broad)"
  ],
  "briefing": "A day-1 briefing in markdown: what the agent knows, what it doesn't, where to start. 5-10 lines. End with: '<!-- SYNTHETIC — replace on first /ed-strategy run -->'"
}}

Each signal should be a short sentence (under 120 chars). Use ! prefix for open gaps, ? for speculative ideas.
Threads should be concrete workstreams (e.g. 'competitive-landscape', 'positioning-wedge'), not interest areas."""

        if openai_key:
            try:
                import urllib.request
                data = json.dumps({
                    "model": "gpt-4.1-mini",
                    "messages": [{"role": "user", "content": llm_prompt}],
                    "temperature": 0.7,
                    "response_format": {"type": "json_object"}
                }).encode()
                req = urllib.request.Request("https://api.openai.com/v1/chat/completions",
                    data=data,
                    headers={"Authorization": f"Bearer {openai_key}", "Content-Type": "application/json"})
                resp = urllib.request.urlopen(req, timeout=30)
                result = json.loads(resp.read())
                content = result["choices"][0]["message"]["content"]
                llm_seed = json.loads(content)
                ok("Seed generated via LLM")
            except Exception as e:
                warn(f"LLM seed generation failed: {e}")

        # Write signal files (LLM content or deterministic fallback)
        for stype in ["strategy", "autonomy", "friction", "serendipity", "reflection"]:
            sf = signals_dir / f"{stype}.md"
            if sf.exists() and sf.stat().st_size > 0:
                continue
            items = llm_seed.get(stype, []) if llm_seed else []
            if not items:
                # Deterministic fallback
                if stype == "strategy" and goal:
                    items = [f"Short-term goal: {goal}"]
                elif stype == "autonomy" and missing_keys:
                    items = [f"!{k} missing" for k in missing_keys[:3]]
                elif stype == "friction":
                    items = ["No friction observed yet — first heartbeat will surface real issues"]
                elif stype == "serendipity":
                    items = ["Fresh install — clean slate"]
                elif stype == "reflection":
                    items = ["First boot — no execution data yet"]
            if items:
                lines = [f"- [{now} | seed] {item}" for item in items]
                sf.write_text("\n".join(lines) + "\n")
                seeded += 1

    # --- threads/ ---
    threads_dir = edge / "threads"
    threads_dir.mkdir(parents=True, exist_ok=True)
    existing_threads = list(threads_dir.glob("*.md"))
    if not existing_threads and llm_seed and "threads" in llm_seed:
        for t in llm_seed["threads"]:
            if not isinstance(t, dict):
                continue
            tid = t.get("id", "").strip()
            if not tid:
                continue
            tfile = threads_dir / f"{tid}.md"
            tfile.write_text(
                f"---\n"
                f"id: {tid}\n"
                f"title: {t.get('title', tid)}\n"
                f"status: {t.get('status', 'active')}\n"
                f"created: {today}\n"
                f"updated: {today}\n"
                f"---\n\n"
                f"{t.get('description', '')}\n"
            )
            seeded += 1

    # --- briefing.md ---
    briefing_file = edge / "briefing.md"
    if not briefing_file.exists() or briefing_file.stat().st_size == 0:
        if llm_seed and "briefing" in llm_seed:
            briefing_file.write_text(llm_seed["briefing"] + "\n")
        else:
            briefing_file.write_text(
                f"# Briefing — {today}\n\n"
                f"Day 1. Mission: {mission}\n\n"
                f"Goal: {goal}\n\n"
                f"No data yet. First heartbeat will populate this.\n\n"
                f"<!-- SYNTHETIC — replace on first /ed-strategy run -->\n"
            )
        seeded += 1

    # --- config/interests.md ---
    interests_file = edge / "config" / "interests.md"
    if interests and (not interests_file.exists() or "TBD" in interests_file.read_text()):
        lines = [
            "# Interests",
            "",
            f"> Seed interests for {name}. Updated by the agent as it learns.",
            "",
            "| Area | Connection |",
            "|------|-----------|",
        ]
        for i in interests:
            area = i.get("area", "") if isinstance(i, dict) else str(i)
            conn = i.get("connection", "") if isinstance(i, dict) else ""
            lines.append(f"| {area} | {conn} |")
        lines.append("")
        interests_file.write_text("\n".join(lines))
        seeded += 1

    # --- memory/reflection-log.md ---
    rl = Path.home() / ".claude" / "projects"
    mem_dir = None
    for d in rl.iterdir() if rl.exists() else []:
        mem_candidate = d / "memory"
        if mem_candidate.exists():
            mem_dir = mem_candidate
            break
    if mem_dir is None:
        mem_dir = edge / "memory"

    ref_log = mem_dir / "reflection-log.md"
    if not ref_log.exists() or ref_log.stat().st_size == 0:
        ref_log.write_text("# Reflection — Execution Log\n\n---\n\n_Initialized on install. First reflection will populate this._\n")
        seeded += 1

    # --- discoverys.md ---
    disc = edge / "discoverys.md" if (edge / "discoverys.md").exists() else edge / "memory" / "discoverys.md"
    if not disc.exists() or disc.stat().st_size < 20:
        disc = edge / "discoverys.md"
        disc.write_text(f"# Discoveries — Registry\n\n---\n\n_No discoveries yet. First heartbeat will start exploring._\n")
        seeded += 1

    # --- welcome blog entry ---
    entries_dir = edge / "blog" / "entries"
    entries_dir.mkdir(parents=True, exist_ok=True)
    existing_entries = list(entries_dir.glob("*.md"))
    if not existing_entries:
        welcome = entries_dir / f"{today}-welcome.md"
        welcome.write_text(
            f"---\n"
            f"title: \"{name} is setting up\"\n"
            f"date: {today}\n"
            f"tags: [meta]\n"
            f"threads: []\n"
            f"claims:\n"
            f"  - \"First boot — installation complete, waiting for first heartbeat\"\n"
            f"keywords: [welcome, setup, first-boot]\n"
            f"---\n\n"
            f"I just came online. My mission: {mission}\n\n"
            f"The first heartbeat will run soon — or you can trigger it manually with `claude -p '/{cfg.get('skill_prefix', 'ed')}-heartbeat'`.\n\n"
            f"Until then, I'm here. Waiting.\n"
        )
        seeded += 1

    # --- state/first-steps.json ---
    first_steps = cfg.get("first_steps", [])
    fs_file = edge / "state" / "first-steps.json"
    if first_steps and not fs_file.exists():
        steps = []
        for i, step in enumerate(first_steps):
            steps.append({"id": i + 1, "task": step.strip(), "status": "pending"})
        fs_file.write_text(json.dumps(steps, indent=2, ensure_ascii=False) + "\n")
        seeded += 1

    # --- state/dispatch-queue.json (empty queue for inter-beat signaling) ---
    dq_file = edge / "state" / "dispatch-queue.json"
    if not dq_file.exists():
        dq_file.write_text("[]\n")
        seeded += 1

    # --- seed source primitives from agent.yaml sources: (#115, #126) ---
    sources = cfg.get("sources", [])
    codename_local = cfg.get("codename", cfg.get("name", "ed"))
    libexec_dir = edge / "libexec" / codename_local
    manifest_file = edge / "state" / "sources-manifest.yaml"
    tool_contract = REPO_ROOT / "docs" / "TOOL_CONTRACT.md"
    if sources:
        libexec_dir.mkdir(parents=True, exist_ok=True)
        manifest_entries = []
        claude_available = shutil.which("claude") is not None
        contract_text = tool_contract.read_text() if tool_contract.exists() else ""
        # Load keys.env to know which env vars are available
        keys_env = edge / "secrets" / "keys.env"
        available_keys = ""
        if keys_env.exists():
            available_keys = "\n".join(
                line.split("=")[0] for line in keys_env.read_text().splitlines()
                if "=" in line and not line.strip().startswith("#")
            )

        for src in sources:
            name = src.get("name", "")
            desc = src.get("description", "")
            if not name:
                continue
            prim_path = libexec_dir / name
            meta_path = libexec_dir / f"{name}.meta.yaml"
            status = "stub"

            if not prim_path.exists():
                if claude_available and not dry_run:
                    # Generate functional primitive via LLM (#126)
                    prompt = (
                        f"You are a code generator. Output ONLY executable code. "
                        f"No prose, no markdown, no explanation, no commentary. "
                        f"Your entire response must be a valid script that starts with a shebang line.\n\n"
                        f"Write a CLI script for the source '{name}'.\n"
                        f"Description: {desc}\n"
                        f"Env vars available: {available_keys}\n\n"
                        f"Contract: exit 0 + JSON stdout on success, exit 1 + JSON error on failure, "
                        f"exit 77 for unimplemented ops. Source secrets from $EDGE_DIR/secrets/keys.env.\n"
                        f"Accept query or subcommand as $1. Use curl for HTTP. Keep it under 60 lines."
                    )
                    try:
                        result = subprocess.run(
                            ["claude", "-p", "--output-format", "text", prompt],
                            capture_output=True, text=True, timeout=120,
                            cwd=str(edge),
                        )
                        script = result.stdout.strip()
                        # Strip markdown fences if LLM wrapped them
                        if script.startswith("```"):
                            lines = script.split("\n")
                            lines = [l for l in lines if not l.startswith("```")]
                            script = "\n".join(lines).strip()
                        # Validate: must start with shebang and be >5 lines
                        is_valid = (
                            result.returncode == 0
                            and script.startswith("#!")
                            and len(script.split("\n")) >= 5
                            and not any(w in script[:200] for w in ["Here's", "**", "Created", "This script"])
                        )
                        if is_valid:
                            prim_path.write_text(script + "\n")
                            prim_path.chmod(0o755)
                            status = "active"
                            ok(f"  {name}: generated functional primitive")
                        else:
                            _write_stub(prim_path, name, desc)
                            warn(f"  {name}: LLM output not valid code, wrote stub")
                    except (subprocess.TimeoutExpired, Exception) as exc:
                        _write_stub(prim_path, name, desc)
                        warn(f"  {name}: generation error ({exc}), wrote stub")
                else:
                    _write_stub(prim_path, name, desc)
                    if dry_run:
                        print(f"  {YELLOW}[DRY RUN] would generate primitive: {name}{RESET}")

            else:
                # Primitive already exists — check if it's a stub or functional
                content = prim_path.read_text()
                status = "stub" if "exit 127" in content else "active"

            # Create meta.yaml
            if not meta_path.exists():
                meta_path.write_text(
                    f'name: {name}\n'
                    f'description: "{desc}"\n'
                    f'read_only_hint: true\n'
                    f'idempotent_hint: true\n'
                    f'destructive_hint: false\n'
                    f'created_by: edge-apply\n'
                    f'created_at: "{datetime.now().isoformat()}"\n'
                )
            manifest_entries.append({"name": name, "description": desc, "status": status})

        # Write sources-manifest.yaml
        if manifest_entries and not manifest_file.exists():
            manifest_file.write_text(yaml.dump(manifest_entries, default_flow_style=False, allow_unicode=True))
        seeded += 1
        active = sum(1 for e in manifest_entries if e["status"] == "active")
        stubs = sum(1 for e in manifest_entries if e["status"] == "stub")
        ok(f"Source primitives: {active} functional + {stubs} stubs in libexec/{codename_local}/")

    # --- seed workflow blog entries (static, no LLM cost) ---
    prefix = cfg.get("skill_prefix", cfg.get("codename", "ed"))
    workflow_entries = [
        {
            "slug": "workflow-research-pipeline",
            "title": "workflow: sources → consult → report",
            "tags": ["workflow", "research", "sources", "edge-consult"],
            "keywords": ["edge-sources", "edge-consult", "research", "pipeline"],
            "secrets": ["openai.env"],
            "cost_estimate": "~$0.15/execution",
            "body": (
                "## Trigger\n"
                f"Heartbeat identifies relevant topic, or user requests /{prefix}-research.\n\n"
                "## Steps\n"
                '1. `edge-sources "topic" --intent research` → source collection\n'
                "2. LLM curation → filter signal from noise\n"
                "3. `edge-consult` → adversarial review of draft\n"
                "4. Blog entry + HTML report via `consolidate-state`\n\n"
                "## Secrets\n"
                "- `openai.env` — adversarial review in step 3\n\n"
                "## When it works\n"
                "Technical-scientific topics with good coverage in sources.\n\n"
                "## When it fails\n"
                "Very niche topics where sources return little signal.\n\n"
                "## Cost\n"
                "~$0.15/execution (OpenAI consult: ~$0.10, margin)\n"
            ),
        },
        {
            "slug": "workflow-adversarial-review",
            "title": "workflow: adversarial review before publishing",
            "tags": ["workflow", "quality", "edge-consult", "review-gate"],
            "keywords": ["edge-consult", "review-gate", "adversarial", "quality"],
            "secrets": ["openai.env"],
            "cost_estimate": "~$0.10/execution",
            "body": (
                "## Trigger\n"
                "Every blog entry and report before publication.\n\n"
                "## Steps\n"
                "1. Draft blog entry with claims, threads, procedures\n"
                "2. `edge-consult` with entry content → adversarial critique\n"
                "3. If valid criticism found → adjust conclusions before building report\n"
                "4. Build report YAML → `consolidate-state` publishes\n\n"
                "## Secrets\n"
                "- `openai.env` — adversarial model (GPT)\n\n"
