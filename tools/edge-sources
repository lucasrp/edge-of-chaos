def fetch_json(url, timeout=15):
    req = Request(url, headers={"User-Agent": "edge-sources/1.0"})
    return json.loads(urlopen(req, timeout=timeout).read())


# --- Source functions: each returns list of {title, url, source, detail, score} ---

def search_x(topic):
    """Call edge-x subprocess."""
    try:
        r = subprocess.run(
            [sys.executable, str(TOOLS_DIR / "edge-x"), topic, "--json", "--max", "10", "--light"],
            capture_output=True, text=True, timeout=30
        )
        if r.returncode != 0:
            return [{"title": f"edge-x error: {r.stderr[:100]}", "url": "", "source": "X", "detail": "", "score": 0}]
        tweets = json.loads(r.stdout) if r.stdout.strip() else []
        results = []
        for t in tweets[:10]:
            results.append({
                "title": f"@{t.get('username', '?')} ({t.get('followers', 0):,} fol)",
                "url": t.get("url", ""),
                "source": "X",
                "detail": t.get("text", "")[:200].replace("\n", " "),
                "score": t.get("likes", 0) + t.get("rts", 0) * 3 + t.get("replies", 0) * 2,
            })
        return results
    except Exception as e:
        return [{"title": f"X error: {e}", "url": "", "source": "X", "detail": "", "score": 0}]


def search_hn(topic):
    """Call edge-hn subprocess."""
    try:
        r = subprocess.run(
            [sys.executable, str(TOOLS_DIR / "edge-hn"), topic, "--json", "--max", "10"],
            capture_output=True, text=True, timeout=30
        )
        if r.returncode != 0:
            return [{"title": f"edge-hn error: {r.stderr[:100]}", "url": "", "source": "HN", "detail": "", "score": 0}]
        data = json.loads(r.stdout) if r.stdout.strip() else {}
        stories = data.get("stories", [])
        results = []
        for s in stories[:10]:
            results.append({
                "title": s.get("title", ""),
                "url": s.get("url", "") or s.get("hn_url", ""),
                "source": "HN",
                "detail": f"{s.get('points', 0)}pts, {s.get('comments', 0)} comments",
                "score": s.get("points", 0),
            })
        return results
    except Exception as e:
        return [{"title": f"HN error: {e}", "url": "", "source": "HN", "detail": "", "score": 0}]


def search_arxiv(topic):
    """Search ArXiv API."""
    try:
        query = f'all:"{topic}"'
        url = f"http://export.arxiv.org/api/query?search_query={quote(query)}&start=0&max_results=8&sortBy=submittedDate&sortOrder=descending"
        resp = urlopen(Request(url), timeout=15)
        root = ET.fromstring(resp.read())
        ns = {'a': 'http://www.w3.org/2005/Atom'}
        results = []
        for entry in root.findall('a:entry', ns):
            title = entry.find('a:title', ns).text.strip().replace('\n', ' ')
            published = entry.find('a:published', ns).text[:10]
            summary = entry.find('a:summary', ns).text.strip()[:200].replace('\n', ' ')
            link = entry.find('a:id', ns).text
            authors = [a.find('a:name', ns).text for a in entry.findall('a:author', ns)]
            results.append({
                "title": f"[{published}] {title}",
                "url": link,
                "source": "ArXiv",
                "detail": f"{', '.join(authors[:3])}. {summary}",
                "score": 5,  # ArXiv has no engagement metrics
            })
        return results
    except Exception as e:
        return [{"title": f"ArXiv error: {e}", "url": "", "source": "ArXiv", "detail": "", "score": 0}]


def search_semantic_scholar(topic):
    """Search Semantic Scholar API."""
    try:
        fields = 'title,year,citationCount,influentialCitationCount,authors,url,tldr'
        url = f"https://api.semanticscholar.org/graph/v1/paper/search?query={quote(topic)}&limit=8&fields={fields}"
        data = fetch_json(url)
        results = []
        for paper in (data or {}).get('data', []) or []:
            if not paper:
                continue
            title = paper.get('title', '') or ''
            year = paper.get('year') or '?'
            cites = paper.get('citationCount') or 0
            influential = paper.get('influentialCitationCount') or 0
            authors_list = paper.get('authors') or []
            authors = ', '.join(a.get('name', '') for a in authors_list[:3] if a)
            tldr_obj = paper.get('tldr')
            tldr = (tldr_obj.get('text', '') if isinstance(tldr_obj, dict) else '')[:150]
            paper_url = paper.get('url') or ''
            results.append({
                "title": f"[{year}, {cites}c, {influential}i] {title}",
                "url": paper_url,
                "source": "SemanticScholar",
                "detail": f"{authors}. {tldr}" if tldr else authors,
                "score": influential * 10 + cites,
            })
        return results
    except Exception as e:
        return [{"title": f"SemanticScholar error: {e}", "url": "", "source": "SemanticScholar", "detail": "", "score": 0}]


def search_reddit(topic):
    """Search Reddit JSON API."""
    try:
        subreddits = ['MachineLearning', 'LocalLLaMA', 'ClaudeAI']
        results = []
        for sub in subreddits:
            url = f"https://www.reddit.com/r/{sub}/search.json?q={quote(topic)}&restrict_sr=1&sort=relevance&t=month&limit=5"
            req = Request(url, headers={'User-Agent': 'edge-sources/1.0'})
            data = json.loads(urlopen(req, timeout=10).read())
            for post in data.get('data', {}).get('children', []):
                d = post['data']
                results.append({
                    "title": d.get('title', '')[:120],
                    "url": f"https://www.reddit.com{d.get('permalink', '')}",
                    "source": f"Reddit r/{sub}",
                    "detail": f"{d.get('score', 0)}pts, {d.get('num_comments', 0)} comments",
                    "score": d.get('score', 0),
                })
        results.sort(key=lambda x: x['score'], reverse=True)
        return results[:10]
    except Exception as e:
        return [{"title": f"Reddit error: {e}", "url": "", "source": "Reddit", "detail": "", "score": 0}]


def search_github(topic):
    """Search GitHub via gh CLI."""
    try:
        r = subprocess.run(
            ["gh", "search", "repos", topic, "--sort", "stars", "--limit", "5",
             "--json", "name,owner,description,stargazersCount,url,updatedAt"],
            capture_output=True, text=True, timeout=15
        )
        repos = json.loads(r.stdout) if r.returncode == 0 and r.stdout.strip() else []
        results = []
        for repo in repos:
            results.append({
                "title": f"{repo.get('owner', {}).get('login', '?')}/{repo.get('name', '?')} ({repo.get('stargazersCount', 0)} stars)",
                "url": repo.get("url", ""),
                "source": "GitHub",
                "detail": (repo.get("description") or "")[:150],
                "score": repo.get("stargazersCount", 0),
            })
        return results
    except Exception as e:
        return [{"title": f"GitHub error: {e}", "url": "", "source": "GitHub", "detail": "", "score": 0}]


def search_hf_papers(topic):
    """Search HuggingFace daily papers. Topic used for client-side filter."""
    try:
        url = "https://huggingface.co/api/daily_papers"
        data = fetch_json(url)
        if not isinstance(data, list):
            return []
        topic_lower = topic.lower()
        keywords = topic_lower.split()
        results = []
        for item in data:
            paper = item.get('paper', {}) or {}
            title = paper.get('title', '')
            paper_id = paper.get('id', '')
            authors = paper.get('authors', []) or []
            author_str = ', '.join(
                a.get('name', '') for a in authors[:3]
                if isinstance(a, dict) and a.get('name')
            )
            upvotes = item.get('paper', {}).get('upvotes', 0) or 0
            title_lower = title.lower()
            match = any(kw in title_lower for kw in keywords)
            results.append({
                "title": title,
                "url": f"https://huggingface.co/papers/{paper_id}" if paper_id else "",
                "source": "HF Papers",
                "detail": author_str,
                "score": upvotes + (50 if match else 0),
                "_match": match,
            })
        results.sort(key=lambda x: x['score'], reverse=True)
        matched = [r for r in results if r.pop('_match', False)][:5]
        trending = [r for r in results if r not in matched][:3]
        return matched + trending
    except Exception as e:
        return [{"title": f"HF Papers error: {e}", "url": "", "source": "HF Papers", "detail": "", "score": 0}]


def search_exa(topic):
    """Search Exa API (semantic web search)."""
    try:
        api_key = load_exa_api_key()
        if not api_key:
            return [{"title": "Exa: no API key", "url": "", "source": "Exa", "detail": "Set EXA_API_KEY in secrets/exa.env", "score": 0}]
        body = json.dumps({
            "query": topic,
            "type": "auto",
            "numResults": 10,
            "contents": {"text": {"maxCharacters": 300}},
        }).encode()
        req = Request(
            "https://api.exa.ai/search",
            data=body,
            headers={"x-api-key": api_key, "Content-Type": "application/json", "User-Agent": "edge-sources/1.0"},
            method="POST",
        )
        data = json.loads(urlopen(req, timeout=15).read())
        results = []
        for r in (data.get("results") or []):
            text = (r.get("text") or "")[:200].replace("\n", " ")
            score_val = int(float(r.get("score", 0)) * 100) if r.get("score") else 5
            results.append({
                "title": r.get("title", "")[:150],
                "url": r.get("url", ""),
                "source": "Exa",
                "detail": text,
                "score": score_val,
            })
        return results
    except Exception as e:
        return [{"title": f"Exa error: {e}", "url": "", "source": "Exa", "detail": "", "score": 0}]


