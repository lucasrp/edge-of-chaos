}


def pick_wildcard(selected_sources):
    """Pick one source NOT in the selected set (forced serendipity).

    `corpus` is excluded — it is mandatory by design, not serendipitous.
    """
    candidates = [s for s in ALL_SOURCES if s not in selected_sources and s != 'corpus']
    return random.choice(candidates) if candidates else None


def _primary_search_sources_from_manifest():
    if yaml is None or not SOURCES_MANIFEST_FILE.exists():
        return []
    try:
        manifest = yaml.safe_load(SOURCES_MANIFEST_FILE.read_text(encoding="utf-8")) or {}
    except Exception:
        return []
    items = manifest.get("sources") if isinstance(manifest, dict) else []
    if not isinstance(items, list):
        return []
    selected = []
    for item in items:
        if not isinstance(item, dict) or not item.get("primary"):
            continue
        name = str(item.get("name") or "").strip()
        roles = [str(role).strip() for role in (item.get("roles") or []) if str(role).strip()]
        if name in SOURCE_FN and (not roles or "search" in roles):
            selected.append(name)
    return selected


def select_sources_for_intent(intent, *, override=""):
    if override:
        return [s.strip() for s in override.split(",") if s.strip() in SOURCE_FN], "override"
    route = ROUTING.get(intent, ROUTING['research'])
    primary_sources = _primary_search_sources_from_manifest()
    if primary_sources:
        selected = primary_sources + [src for src in route['secondary'] if src not in primary_sources]
        return selected, "manifest_primary"
    return [MANAGED_CLAUDE_SOURCE], "managed_claude_default"


def run_sources(topic, sources, max_workers=6, *, run_id="", intent="", wildcard_src=None):
    """Run multiple sources concurrently."""
    import time as _time
    all_results = {}
    with ThreadPoolExecutor(max_workers=max_workers) as pool:
        futures = {}
        start_by_src = {}
        for src in sources:
            fn = SOURCE_FN.get(src)
            if fn:
                futures[pool.submit(fn, topic)] = src
                start_by_src[src] = _time.monotonic()
        for future in as_completed(futures):
            src = futures[future]
            dt_ms = int((_time.monotonic() - start_by_src.get(src, _time.monotonic())) * 1000)
            try:
                items = future.result()
                all_results[src] = items
                ok = bool(items) and not (len(items) == 1 and "error" in str(items[0].get("title", "")).lower())
                log_primitive_call(src, ok=ok, latency_ms=dt_ms, notes={"topic": topic[:80], "n": len(items)})
                source_id = f"source.{src}"
                for index, item in enumerate(items or [], 1):
                    result_kind = "error" if "error" in str(item.get("title") or "").lower() else "source_result"
                    odi_id = make_odi_id(
                        source_id,
                        run_id,
                        topic,
                        item.get("url") or "",
                        item.get("title") or "",
                        index,
                    )
                    item["odi_id"] = odi_id
                    item["source_id"] = source_id
                    item["rank"] = index
                    item["result_kind"] = result_kind
                    item["wildcard"] = src == wildcard_src
                    item["latency_ms"] = dt_ms
                    log_odi_observed(
                        odi_id,
                        source_id=source_id,
                        primitive="edge-sources",
                        context=intent or "research",
                        query=topic,
                        run_id=run_id,
                        title=str(item.get("title") or "")[:240],
                        url=str(item.get("url") or ""),
                        rank=index,
                        score=item.get("score"),
                        result_kind=result_kind,
                        metadata={
                            "source_label": item.get("source") or src,
                            "detail": str(item.get("detail") or "")[:300],
                            "wildcard": src == wildcard_src,
                            "latency_ms": dt_ms,
                        },
                    )
            except Exception as e:
                all_results[src] = [{"title": f"{src} error: {e}", "url": "", "source": src, "detail": "", "score": 0}]
                log_primitive_call(src, ok=False, latency_ms=dt_ms, notes={"topic": topic[:80], "err": str(e)[:120]})
                source_id = f"source.{src}"
                odi_id = make_odi_id(source_id, run_id, topic, "exception", str(e)[:120])
                all_results[src][0]["odi_id"] = odi_id
                all_results[src][0]["source_id"] = source_id
                all_results[src][0]["rank"] = 1
                all_results[src][0]["result_kind"] = "error"
                all_results[src][0]["wildcard"] = src == wildcard_src
                all_results[src][0]["latency_ms"] = dt_ms
                log_odi_observed(
                    odi_id,
                    source_id=source_id,
                    primitive="edge-sources",
                    context=intent or "research",
                    query=topic,
                    run_id=run_id,
                    title=f"{src} error: {e}"[:240],
                    rank=1,
                    score=0,
                    result_kind="error",
                    metadata={"error": str(e)[:300], "wildcard": src == wildcard_src, "latency_ms": dt_ms},
                )
    return all_results


def _has_usable_results(items):
    usable = [
        item for item in items or []
        if item.get("url") and "error" not in str(item.get("title", "")).lower()
    ]
    return bool(usable)


def _maybe_unlock_builtin_web_search(topic, sources, results_by_source):
    policy = load_search_policy()
    provider = str(policy.get("web_provider") or "").strip().lower()
    if bool(policy.get("builtin_web_search")) or provider != "exa":
        clear_builtin_web_search_allowance()
        return None
    if "exa" not in sources:
        return None

    exa_items = results_by_source.get("exa") or []
    if _has_usable_results(exa_items):
        clear_builtin_web_search_allowance()
        return None

    allowance = write_builtin_web_search_allowance(
        "provider_failed_or_empty",
        query=topic,
        provider="exa",
        source="edge-sources",
        details={
            "selected_sources": list(sources),
            "exa_result_count": len(exa_items),
            "exa_preview": [str(item.get("title") or "")[:160] for item in exa_items[:3]],
        },
    )
    return allowance


def _source_error(item):
    return "error" in str(item.get("title", "")).lower() or str(item.get("result_kind") or "") == "error"


def summarize_results(results_by_source, selected_sources, wildcard_src=None):
    per_source = {}
    total_results = 0
    ok_sources = 0
    failed_sources = 0
    useful_odi_ids = []
    error_odi_ids = []

    for src in selected_sources:
        items = list(results_by_source.get(src) or [])
        errors = [item for item in items if _source_error(item)]
        usable = [
            item for item in items
            if not _source_error(item) and (item.get("url") or item.get("detail") or item.get("title"))
        ]
        total_results += len(usable)
        if errors:
            failed_sources += 1
        else:
            ok_sources += 1

        useful_ids = [str(item.get("odi_id") or "") for item in usable if item.get("odi_id")]
        error_ids = [str(item.get("odi_id") or "") for item in errors if item.get("odi_id")]
        useful_odi_ids.extend(useful_ids[:5])
        error_odi_ids.extend(error_ids[:5])
        per_source[src] = {
            "source_id": f"source.{src}",
            "selected": True,
            "wildcard": src == wildcard_src,
            "result_count": len(items),
            "usable_count": len(usable),
            "error_count": len(errors),
            "latency_ms": max([int(item.get("latency_ms") or 0) for item in items] or [0]),
            "top_odi_ids": useful_ids[:5],
            "error_odi_ids": error_ids[:5],
        }

    return {
        "source_count": len(selected_sources),
        "ok_sources": ok_sources,
        "failed_sources": failed_sources,
        "total_results": total_results,
        "per_source": per_source,
        "useful_odi_ids": useful_odi_ids[:20],
        "error_odi_ids": error_odi_ids[:20],
    }


def format_markdown(topic, intent, results_by_source, wildcard_src=None, run_id=""):
    """Format results as structured markdown."""
    lines = [f"## External Sources — \"{topic}\" (intent: {intent})\n"]
    if run_id:
        lines.append(f"Run: `{run_id}`\n")

    # Corpus section (issue #381) — surfaced first so prior internal knowledge
    # is read before any external source. If corpus was queried but returned
    # nothing, the section says so explicitly so the report can record that.
    corpus_items = results_by_source.get('corpus') or []
    corpus_clean = [item for item in corpus_items if 'error' not in item.get('title', '').lower()]
    if 'corpus' in results_by_source:
        lines.append("### Corpus (internal)\n")
        if corpus_clean:
            for item in corpus_clean:
                lines.append(f"- **[{item['source']}]** {item['title']}")
                if item.get('detail'):
                    lines.append(f"  {item['detail'][:200]}")
                if item.get('url'):
                    lines.append(f"  Path: {item['url']}")
                lines.append("")
        else:
            lines.append("- _No prior corpus matches — record \"Corpus: not consulted before this run\" in the report only if edge-search itself failed; an empty corpus is a valid finding._\n")

    # External: flatten everything except corpus and sort by score
    all_items = []
    for src, items in results_by_source.items():
        if src == 'corpus':
            continue
        for item in items:
            if item.get("url") or not _source_error(item):
                all_items.append(item)
    all_items.sort(key=lambda x: x.get('score', 0), reverse=True)

    # Top results
    top = [i for i in all_items if i.get('score', 0) > 0][:15]
    rest = [i for i in all_items if i not in top and 'error' not in i.get('title', '').lower()][:10]

    if top:
        lines.append("### High Relevance\n")
        for item in top:
            lines.append(f"- **[{item['source']}]** {item['title']}")
            if item.get('detail'):
                lines.append(f"  {item['detail'][:200]}")
            if item.get('url'):
                lines.append(f"  URL: {item['url']}")
            lines.append("")

    if rest:
        lines.append("### Complementary\n")
        for item in rest:
            lines.append(f"- **[{item['source']}]** {item['title']}")
            if item.get('url'):
                lines.append(f"  URL: {item['url']}")
        lines.append("")

    # Errors
    errors = []
    for src, items in results_by_source.items():
        for item in items:
            if _source_error(item):
                errors.append(f"  - {item['title']}")
    if errors:
        lines.append("### Errors\n")
        lines.extend(errors)
        lines.append("")

    # Source summary
    lines.append("### Sources Consulted\n")
    for src, items in results_by_source.items():
        ok_count = len([i for i in items if not _source_error(i)])
        wc = " (WILDCARD)" if src == wildcard_src else ""
        lines.append(f"- {src}: {ok_count} results{wc}")
    lines.append("")

    # Note about builtin web search policy
    lines.append("### Note")
    lines.append("Use this tool before Claude WebSearch. Runtime may unlock builtin WebSearch only after the primary web provider fails or returns nothing useful. WebFetch remains valid for URLs already surfaced by sources.\n")

    return "\n".join(lines)


def format_json(results_by_source, wildcard_src=None):
    """Format results as JSON."""
    output = {}
    for src, items in results_by_source.items():
        output[src] = {
            "results": items,
            "wildcard": src == wildcard_src,
        }
    return json.dumps(output, indent=2, ensure_ascii=False)


def format_feedback_json(
    results_by_source,
    *,
    topic,
    intent,
    selected_sources,
    wildcard_src=None,
    run_id="",
    episode_id="",
    pattern_id="",
    pattern_note="",
    route_mode="intent",
    builtin_web_allowance=None,
):
    """Format a stable feedback contract for source/signal curation."""
    summary = summarize_results(results_by_source, selected_sources, wildcard_src)
    payload = {
        "schema_version": 2,
        "kind": "edge_sources_feedback_episode",
        "run": {
            "run_id": run_id,
            "episode_id": episode_id or run_id,
            "pattern_id": pattern_id,
            "pattern_note": pattern_note,
            "query": topic,
            "intent": intent,
        },
        "route": {
            "mode": route_mode,
            "selected_sources": selected_sources,
            "wildcard_source": wildcard_src,
            "corpus_included": "corpus" in selected_sources,
            "builtin_web_fallback_unlocked": bool(builtin_web_allowance),
        },
        "summary": summary,
        "results_by_source": results_by_source,
        "source_playbook": {
            "corpus": corpus_playbook(),
        },
        "feedback_contract": {
            "grade_command": "edge-affordance evaluate <source_id> --affordance <affordance> --score <1-5> --context <intent/context> --query <query> --reason <reason> --odi <odi_id> --episode-id <episode_id>",
            "grade_atomic_sources": True,
            "recommended_affordances": [
                "novelty",
                "confirmation",
                "continuity",
                "operational_signal",
                "implementation_pattern",
                "primary_source",
                "counterexample",
            ],
        },
    }
    return json.dumps(payload, indent=2, ensure_ascii=False)


def front_page():
    """Headlines-only mode for heartbeat: HN front page."""
    try:
        r = subprocess.run(
            [sys.executable, str(TOOLS_DIR / "edge-hn"), "--front-page", "--json"],
            capture_output=True, text=True, timeout=15
        )
        if r.returncode == 0 and r.stdout.strip():
            data = json.loads(r.stdout)
            fp = data.get("front_page", [])
            return {"hn": [{
                "title": s.get("title", ""),
                "url": s.get("url", ""),
                "source": "HN",
                "detail": f"{s.get('points', 0)}pts",
                "score": s.get("points", 0),
            } for s in fp[:10]]}
    except Exception:
        pass
    return {"hn": [{"title": "HN front page: fetch failed", "url": "", "source": "HN", "detail": "", "score": 0}]}


def main():
    parser = argparse.ArgumentParser(
        description="Unified external source search",
        epilog="Intents: research, discovery, heartbeat, planner, report"
    )
    parser.add_argument("topic", nargs="?", default="", help="Search topic")
    parser.add_argument("--intent", "-i", default="research", choices=list(ROUTING.keys()),
                        help="Search intent (default: research)")
    parser.add_argument("--sources", "-s", default="", help="Comma-separated source override (e.g. x,hn,arxiv)")
    parser.add_argument("--front-page", action="store_true", help="Headlines-only mode (HN front page)")
    parser.add_argument("--json", action="store_true", help="JSON output")
    parser.add_argument("--feedback-json", action="store_true",
                        help="JSON v2 with run metadata, route summary, ODIs, and feedback contract")
    parser.add_argument("--episode-id", default="",
                        help="Group multiple source runs into one curation/test episode")
    parser.add_argument("--pattern-id", default="",
                        help="Label the query/source pattern being tested")
    parser.add_argument("--pattern-note", default="",
                        help="Short note describing the pattern variant")
    parser.add_argument("--no-wildcard", action="store_true", help="Skip wildcard source")
    parser.add_argument("--no-corpus", action="store_true",
                        help="Skip the mandatory internal corpus (edge-search) source — issue #381")
    args = parser.parse_args()

    if args.front_page:
        results = front_page()
        run_id = f"sources:{uuid.uuid4().hex[:8]}"
        episode_id = args.episode_id or run_id
        if args.feedback_json:
            print(format_feedback_json(
                results,
                topic="headlines",
                intent="heartbeat",
                selected_sources=["hn"],
                run_id=run_id,
                episode_id=episode_id,
                pattern_id=args.pattern_id,
                pattern_note=args.pattern_note,
                route_mode="front_page",
            ))
        elif args.json:
            print(format_json(results))
        else:
            print(format_markdown("headlines", "heartbeat", results, run_id=run_id))
        return

    if not args.topic:
        parser.error("topic is required (unless --front-page)")

    # Select sources. A source marked `primary: true` in agent.yaml is
    # materialized into state/sources-manifest.yaml by render/apply and wins.
    # Without an explicit primary source, open-web search uses Claude WebSearch
    # only through this wrapper so telemetry still records the route.
    sources, route_mode = select_sources_for_intent(args.intent, override=args.sources)
    if not sources:
        parser.error(f"No valid sources. Available: {', '.join(SOURCE_FN.keys())}")

    # Corpus is always queried first unless explicitly opted out (issue #381).
    # This removes the possibility of skipping prior knowledge before going
    # external — the failure mode that triggered #381.
    if not args.no_corpus and 'corpus' not in sources:
        sources = ['corpus'] + sources

    # Wildcard: one random source outside the routing (forced serendipity)
    wildcard_src = None
    if not args.no_wildcard and not args.sources and route_mode != "managed_claude_default":
        wildcard_src = pick_wildcard(sources)
        if wildcard_src:
            sources.append(wildcard_src)

    run_id = f"sources:{uuid.uuid4().hex[:8]}"
    episode_id = args.episode_id or run_id
    log_run_step(
        "edge-sources",
        "fanout",
        "started",
        run_id=run_id,
        intent=args.intent,
        source_count=len(sources),
        episode_id=episode_id,
        pattern_id=args.pattern_id,
    )
    log_source_query(
        args.topic,
        intent=args.intent,
        status="started",
        sources=sources,
        wildcard_source=wildcard_src,
        run_id=run_id,
        episode_id=episode_id,
        pattern_id=args.pattern_id,
        pattern_note=args.pattern_note,
        route_mode=route_mode,
    )

    try:
        # Execute
        print(f"Querying {len(sources)} sources for \"{args.topic}\" (intent: {args.intent})...", file=sys.stderr)
        results = run_sources(args.topic, sources, run_id=run_id, intent=args.intent, wildcard_src=wildcard_src)
        allowance = _maybe_unlock_builtin_web_search(args.topic, sources, results)
        if allowance is not None:
            print(
                "Exa failed or returned no usable hits; unlocked Claude WebSearch fallback temporarily.",
                file=sys.stderr,
            )

        ok_sources = 0
        total_results = 0
        for items in results.values():
            has_error = any('error' in item.get('title', '').lower() for item in items)
            if not has_error:
                ok_sources += 1
            total_results += len([
                item for item in items
                if item.get("url") or "error" not in item.get("title", "").lower()
            ])

        log_source_query(
            args.topic,
            intent=args.intent,
            status="completed",
            sources=sources,
            total_results=total_results,
            ok_sources=ok_sources,
            failed_sources=max(0, len(sources) - ok_sources),
            wildcard_source=wildcard_src,
            run_id=run_id,
            episode_id=episode_id,
            pattern_id=args.pattern_id,
            pattern_note=args.pattern_note,
            route_mode=route_mode,
        )
        log_run_step(
            "edge-sources",
            "fanout",
            "completed",
            run_id=run_id,
            total_results=total_results,
            ok_sources=ok_sources,
            failed_sources=max(0, len(sources) - ok_sources),
            episode_id=episode_id,
            pattern_id=args.pattern_id,
        )

        # Output
        if args.feedback_json:
            print(format_feedback_json(
                results,
                topic=args.topic,
                intent=args.intent,
                selected_sources=sources,
                wildcard_src=wildcard_src,
                run_id=run_id,
                episode_id=episode_id,
                pattern_id=args.pattern_id,
                pattern_note=args.pattern_note,
                route_mode=route_mode,
                builtin_web_allowance=allowance,
            ))
        elif args.json:
            print(format_json(results, wildcard_src))
        else:
            print(format_markdown(args.topic, args.intent, results, wildcard_src, run_id=run_id))
    except Exception as exc:
        log_source_query(
            args.topic,
            intent=args.intent,
            status="failed",
            sources=sources,
            wildcard_source=wildcard_src,
            run_id=run_id,
            error=str(exc),
            episode_id=episode_id,
            pattern_id=args.pattern_id,
            pattern_note=args.pattern_note,
            route_mode=route_mode,
        )
        log_run_step(
            "edge-sources",
            "fanout",
            "failed",
            run_id=run_id,
            error=str(exc),
            episode_id=episode_id,
            pattern_id=args.pattern_id,
        )
        raise


if __name__ == "__main__":
    main()
