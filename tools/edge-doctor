#!/usr/bin/env python3
"""edge-doctor: Validate agent runtime and installation health.

Usage:
    edge-doctor                        # uses rendered runtime config
    edge-doctor --config agent.yaml    # bootstrap verification
"""

import argparse
import hashlib
import json
import os
import shutil
import socket
import subprocess
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path

import yaml

sys.path.insert(0, str(Path(__file__).resolve().parent / "_shared"))

CHECKS_PASSED = 0
CHECKS_WARNED = 0
CHECKS_FAILED = 0
CURRENT_SECTION = ""


def _slug(value: str) -> str:
    return "".join(ch.lower() if ch.isalnum() else "-" for ch in value).strip("-")


def _ensure_install_context(cfg: dict) -> str:
    codename = str(cfg.get("codename", "agent"))
    edge_home = Path(os.path.expanduser(cfg.get("edge_home", f"~/{codename}")))
    os.environ.setdefault("EDGE_CODENAME", codename)
    os.environ.setdefault("EDGE_STATE_DIR", str(edge_home))
    cycle_id = os.environ.get("EDGE_CYCLE_ID")
    if cycle_id:
        return cycle_id
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    cycle_id = f"install:{codename}:{stamp}-{uuid.uuid4().hex[:6]}"
    os.environ["EDGE_CYCLE_ID"] = cycle_id
    return cycle_id


def _repo_root() -> Path:
    return Path(os.environ.get("EDGE_REPO_DIR", Path(__file__).resolve().parent.parent)).resolve()


def _load_runtime_cfg(repo_root: Path) -> tuple[dict | None, Path]:
    branding_path = repo_root / "config" / "branding.yaml"
    if not branding_path.exists():
        return None, branding_path
    try:
        branding = yaml.safe_load(branding_path.read_text(encoding="utf-8")) or {}
    except Exception:
        return None, branding_path
    if not isinstance(branding, dict):
        return None, branding_path

    blog_cfg = branding.get("blog") or {}
    if not isinstance(blog_cfg, dict):
        blog_cfg = {}

    edge_state_dir = str(branding.get("edge_state_dir") or repo_root)
    cfg = {
        "name": str(branding.get("agent_name") or branding.get("org_name") or branding.get("codename") or "agent"),
        "codename": str(branding.get("codename") or branding.get("skill_prefix") or "agent"),
        "skill_prefix": str(branding.get("skill_prefix") or branding.get("codename") or "agent"),
        "edge_home": edge_state_dir,
        "blog_port": int(blog_cfg.get("port", 8766)),
        "blog_host": str(blog_cfg.get("host", "127.0.0.1")),
    }
    return cfg, branding_path


def _record_check(check_id: str, status: str, detail: str, *, artifact: Path | str | None = None, **extra):
    from telemetry import log_install_check

    log_install_check(
        check_id,
        status,
        detail=detail,
        artifact=str(artifact) if artifact is not None else None,
        section=CURRENT_SECTION,
        **extra,
    )


def ok(msg):
    global CHECKS_PASSED
    CHECKS_PASSED += 1
    print(f"  \033[32m✓\033[0m {msg}")


def warn(msg):
    global CHECKS_WARNED
    CHECKS_WARNED += 1
    print(f"  \033[33m⚠\033[0m {msg}")


def fail(msg):
    global CHECKS_FAILED
    CHECKS_FAILED += 1
    print(f"  \033[31m✗\033[0m {msg}")


def check_file(path: Path, label: str):
    check_id = f"file:{_slug(label)}"
    if path.exists():
        ok(f"{label}: {path}")
        _record_check(check_id, "ok", f"{label}: {path}", artifact=path, label=label)
    else:
        fail(f"{label}: {path} — NÃO ENCONTRADO")
        _record_check(check_id, "fail", f"{label}: {path} — NÃO ENCONTRADO", artifact=path, label=label)


def check_dir(path: Path, label: str):
    check_id = f"dir:{_slug(label)}"
    if path.is_dir():
        ok(f"{label}: {path}")
        _record_check(check_id, "ok", f"{label}: {path}", artifact=path, label=label)
    else:
        fail(f"{label}: {path} — NÃO ENCONTRADO")
        _record_check(check_id, "fail", f"{label}: {path} — NÃO ENCONTRADO", artifact=path, label=label)


def check_command(cmd: str, label: str):
    """Resolve `cmd` via PATH first, then fall back to known install paths.

    Issue #376: when edge-apply has just installed symlinks to ~/.local/bin/
    but the current shell has not refreshed PATH (.edge-env not sourced yet),
    `shutil.which(cmd)` returns None and the install looks broken. Treat the
    binary as installed if it exists at a known location, but warn so the
    user knows to source ~/.edge-env or open a new shell.
    """
    check_id = f"command:{_slug(cmd)}"
    resolved = shutil.which(cmd)
    if resolved:
        ok(f"{label}: {cmd}")
        _record_check(check_id, "ok", f"{label}: {cmd}", artifact=resolved, label=label)
        return
    fallback_paths = [
        Path.home() / ".local" / "bin" / cmd,
        Path.home() / "bin" / cmd,
    ]
    for candidate in fallback_paths:
        if candidate.is_file() and os.access(candidate, os.X_OK):
            warn(f"{label}: {candidate} (encontrado, mas fora do PATH — rode `source ~/.edge-env` ou abra um novo shell)")
            _record_check(
                check_id,
                "warn",
                f"{label}: {candidate} fora do PATH",
                artifact=str(candidate),
                label=label,
                resolution="path_not_active",
            )
            return
    fail(f"{label}: {cmd} — NÃO INSTALADO")
    _record_check(check_id, "fail", f"{label}: {cmd} — NÃO INSTALADO", artifact=cmd, label=label)


def check_port(port: int, host: str = "127.0.0.1"):
    """Check if port is in use (blog running) or available."""
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(2)
    try:
        s.connect((host, port))
        s.close()
        ok(f"Blog respondendo em {host}:{port}")
        _record_check(
            f"port:{host}:{port}",
            "ok",
            f"Blog respondendo em {host}:{port}",
            artifact=f"{host}:{port}",
            host=host,
            port=port,
        )
    except (ConnectionRefusedError, OSError):
        warn(f"Blog NÃO respondendo em {host}:{port} — iniciar com systemctl --user start blog-server")
        _record_check(
            f"port:{host}:{port}",
            "warn",
            f"Blog NÃO respondendo em {host}:{port} — iniciar com systemctl --user start blog-server",
            artifact=f"{host}:{port}",
            host=host,
            port=port,
        )


def check_secret(env_file: Path, key: str, required: bool = True):
    check_id = f"secret:{_slug(key)}"
    if not env_file.exists():
        if required:
            fail(f"Secrets file não encontrado: {env_file}")
            _record_check(check_id, "fail", f"Secrets file não encontrado: {env_file}", artifact=env_file, key=key, required=required)
        else:
            warn(f"Secrets file não encontrado: {env_file}")
            _record_check(check_id, "warn", f"Secrets file não encontrado: {env_file}", artifact=env_file, key=key, required=required)
        return
    content = env_file.read_text()
    for line in content.splitlines():
        if line.startswith(f"{key}="):
            val = line.split("=", 1)[1].strip()
            if val.startswith('"') and val.endswith('"'):
                warn(f"{key}: valor com aspas literais — remover aspas de {env_file}")
                _record_check(check_id, "warn", f"{key}: valor com aspas literais — remover aspas de {env_file}", artifact=env_file, key=key, required=required)
            elif val:
                ok(f"{key}: configurado")
                _record_check(check_id, "ok", f"{key}: configurado", artifact=env_file, key=key, required=required)
            else:
                if required:
                    fail(f"{key}: vazio em {env_file}")
                    _record_check(check_id, "fail", f"{key}: vazio em {env_file}", artifact=env_file, key=key, required=required)
                else:
                    warn(f"{key}: vazio (opcional — funcionalidade degradada)")
                    _record_check(check_id, "warn", f"{key}: vazio (opcional — funcionalidade degradada)", artifact=env_file, key=key, required=required)
            return
    if required:
        warn(f"{key}: não encontrado em {env_file}")
        _record_check(check_id, "warn", f"{key}: não encontrado em {env_file}", artifact=env_file, key=key, required=required)
    else:
        warn(f"{key}: não encontrado (opcional)")
        _record_check(check_id, "warn", f"{key}: não encontrado (opcional)", artifact=env_file, key=key, required=required)


def check_residual_placeholders(path: Path, label: str):
    """Check for unrendered {{ PLACEHOLDER }} in a file."""
    check_id = f"placeholders:{_slug(label)}"
    if not path.exists():
        return
    content = path.read_text()
    import re
    residuals = re.findall(r"\{\{[^}]+\}\}", content)
    if residuals:
        fail(f"{label}: {len(residuals)} placeholder(s) não renderizados: {residuals[:3]}")
        _record_check(
            check_id,
            "fail",
            f"{label}: {len(residuals)} placeholder(s) não renderizados: {residuals[:3]}",
            artifact=path,
            label=label,
            residual_count=len(residuals),
        )
    else:
        ok(f"{label}: sem placeholders residuais")
        _record_check(check_id, "ok", f"{label}: sem placeholders residuais", artifact=path, label=label, residual_count=0)


def check_systemd_timer():
    """Check if heartbeat timer is enabled."""
    try:
        result = subprocess.run(
            ["systemctl", "--user", "is-enabled", "agent-heartbeat.timer"],
            capture_output=True, text=True, timeout=5
        )
        if result.stdout.strip() == "enabled":
            ok("Heartbeat timer: enabled")
            _record_check("systemd:agent-heartbeat.timer", "ok", "Heartbeat timer: enabled", artifact="agent-heartbeat.timer")
        else:
            warn(f"Heartbeat timer: {result.stdout.strip()} — habilitar com: systemctl --user enable --now agent-heartbeat.timer")
            _record_check(
                "systemd:agent-heartbeat.timer",
                "warn",
                f"Heartbeat timer: {result.stdout.strip()} — habilitar com: systemctl --user enable --now agent-heartbeat.timer",
                artifact="agent-heartbeat.timer",
            )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        warn("systemctl não disponível — verificar heartbeat manualmente")
        _record_check("systemd:agent-heartbeat.timer", "warn", "systemctl não disponível — verificar heartbeat manualmente", artifact="agent-heartbeat.timer")


def _hash_text(content: str) -> str:
    return f"sha256:{hashlib.sha256(content.encode('utf-8')).hexdigest()}"


def _hash_file(path: Path) -> str:
    return f"sha256:{hashlib.sha256(path.read_bytes()).hexdigest()}"


def _state_root(edge_home: Path, repo_root: Path | None = None) -> Path:
    branding_candidates = [edge_home / "config" / "branding.yaml"]
    if repo_root is not None:
        branding_candidates.append(repo_root / "config" / "branding.yaml")
    for branding_path in branding_candidates:
        if not branding_path.exists():
            continue
        try:
            branding = yaml.safe_load(branding_path.read_text(encoding="utf-8")) or {}
            edge_state_dir = branding.get("edge_state_dir")
            if edge_state_dir:
                return Path(os.path.expanduser(str(edge_state_dir)))
        except Exception:
            continue
    return edge_home


def _latest_install_event(state_events_file: Path, artifact: Path) -> dict | None:
    if not state_events_file.exists():
        return None
    latest = None
    artifact_str = str(artifact)
    for line in state_events_file.read_text(encoding="utf-8").splitlines():
        if not line.strip():
            continue
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        if event.get("type") != "InstallApplied":
            continue
        if str(event.get("artifact") or "") != artifact_str:
            continue
        if latest is None or str(event.get("ts") or "") >= str(latest.get("ts") or ""):
            latest = event
    return latest


def check_heartbeat_runtime_alignment(edge_home: Path, prefix: str, repo_root: Path):
    state_events_file = _state_root(edge_home, repo_root) / "state" / "events" / "log.jsonl"
    wrapper_installed = Path.home() / ".local" / "bin" / "heartbeat.sh"
    if wrapper_installed.exists():
        latest = _latest_install_event(state_events_file, wrapper_installed)
        actual_hash = _hash_file(wrapper_installed)
        if latest and (latest.get("payload") or {}).get("hash") == actual_hash:
            ok("heartbeat wrapper confere com o último InstallApplied")
            _record_check(
                "install:heartbeat-wrapper",
                "ok",
                "heartbeat wrapper confere com o último InstallApplied",
                artifact=wrapper_installed,
                expected_hash=(latest.get("payload") or {}).get("hash"),
                actual_hash=actual_hash,
            )
        elif latest:
            fail("heartbeat wrapper diverge do último InstallApplied")
            _record_check(
                "install:heartbeat-wrapper",
                "fail",
                "heartbeat wrapper diverge do último InstallApplied",
                artifact=wrapper_installed,
                expected_hash=(latest.get("payload") or {}).get("hash"),
                actual_hash=actual_hash,
            )
        else:
            warn("heartbeat wrapper sem InstallApplied correspondente no ledger")
            _record_check(
                "install:heartbeat-wrapper",
                "warn",
                "heartbeat wrapper sem InstallApplied correspondente no ledger",
                artifact=wrapper_installed,
                actual_hash=actual_hash,
            )

    skill_installed = Path.home() / ".claude" / "skills" / f"{prefix}-heartbeat" / "SKILL.md"
    if skill_installed.exists():
        latest = _latest_install_event(state_events_file, skill_installed)
        actual_hash = _hash_file(skill_installed)
        if latest and (latest.get("payload") or {}).get("hash") == actual_hash:
            ok("heartbeat skill confere com o último InstallApplied")
            _record_check(
                "install:heartbeat-skill",
                "ok",
                "heartbeat skill confere com o último InstallApplied",
                artifact=skill_installed,
                expected_hash=(latest.get("payload") or {}).get("hash"),
                actual_hash=actual_hash,
            )
        elif latest:
            fail("heartbeat skill diverge do último InstallApplied")
            _record_check(
                "install:heartbeat-skill",
                "fail",
                "heartbeat skill diverge do último InstallApplied",
                artifact=skill_installed,
                expected_hash=(latest.get("payload") or {}).get("hash"),
                actual_hash=actual_hash,
            )
        else:
            warn("heartbeat skill sem InstallApplied correspondente no ledger")
            _record_check(
                "install:heartbeat-skill",
                "warn",
                "heartbeat skill sem InstallApplied correspondente no ledger",
                artifact=skill_installed,
                actual_hash=actual_hash,
            )


def check_render_install_drift():
    """Build and summarize the render/install drift projection."""
    tool = Path(__file__).resolve().parent / "rollup-render-install-drift.py"
    if not tool.exists():
        warn("render/install drift projection tool não encontrado")
        _record_check("projection:render-install-drift", "warn", "render/install drift projection tool não encontrado", artifact=tool)
        return
    try:
        result = subprocess.run(
            [sys.executable, str(tool), "--json"],
            capture_output=True,
            text=True,
            timeout=15,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired) as exc:
        warn(f"render/install drift projection indisponível: {exc}")
        _record_check("projection:render-install-drift", "warn", f"render/install drift projection indisponível: {exc}", artifact=tool)
        return

    if result.returncode != 0:
        warn(f"render/install drift projection falhou: {result.stderr.strip() or result.stdout.strip()}")
        _record_check(
            "projection:render-install-drift",
            "warn",
            f"render/install drift projection falhou: {result.stderr.strip() or result.stdout.strip()}",
            artifact=tool,
        )
        return

    payload = json.loads(result.stdout) if result.stdout.strip() else {}
    summary = payload.get("summary", {}) or {}
    detail = (
        "render-install-drift: "
        f"rendered_without_install={summary.get('rendered_without_install', 0)}, "
        f"hash_mismatches={summary.get('hash_mismatches', 0)}, "
        f"missing_on_disk={summary.get('missing_on_disk', 0)}, "
        f"doctor_fail={summary.get('doctor_fail', 0)}"
    )
    artifact = payload.get("output_path") or tool
    if summary.get("hash_mismatches", 0) or summary.get("missing_on_disk", 0):
        fail(detail)
        _record_check("projection:render-install-drift", "fail", detail, artifact=artifact)
    elif summary.get("rendered_without_install", 0) or summary.get("doctor_fail", 0):
        warn(detail)
        _record_check("projection:render-install-drift", "warn", detail, artifact=artifact)
    else:
        ok(detail)
        _record_check("projection:render-install-drift", "ok", detail, artifact=artifact)


def check_primitives_status():
    tool = Path(__file__).resolve().parent / "edge-primitives"
    if not tool.exists():
        warn("primitive status tool não encontrado")
        _record_check("projection:primitives-status", "warn", "primitive status tool não encontrado", artifact=tool)
        return
    try:
        result = subprocess.run(
            [sys.executable, str(tool), "status", "--json"],
            capture_output=True,
            text=True,
            timeout=15,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired) as exc:
        warn(f"primitive status indisponível: {exc}")
        _record_check("projection:primitives-status", "warn", f"primitive status indisponível: {exc}", artifact=tool)
        return
    if result.returncode != 0:
        fail(f"primitive status falhou: {result.stderr.strip() or result.stdout.strip()}")
        _record_check(
            "projection:primitives-status",
            "fail",
            f"primitive status falhou: {result.stderr.strip() or result.stdout.strip()}",
            artifact=tool,
        )
        return
    payload = json.loads(result.stdout) if result.stdout.strip() else {}
    summary = payload.get("summary", {}) or {}
    detail = (
        "primitives-status: "
        f"declared={summary.get('declared_total', 0)}, "
        f"degraded={summary.get('degraded_total', 0)}, "
        f"active={summary.get('active_total', 0)}, "
        f"probed={summary.get('probed_total', 0)}, "
        f"broken={summary.get('broken_total', 0)}"
    )
    artifact = payload.get("output_path") or tool
    if summary.get("broken_total", 0):
        fail(detail)
        _record_check("projection:primitives-status", "fail", detail, artifact=artifact)
    elif summary.get("degraded_total", 0):
        warn(detail)
        _record_check("projection:primitives-status", "warn", detail, artifact=artifact)
    else:
        ok(detail)
        _record_check("projection:primitives-status", "ok", detail, artifact=artifact)


def main():
    global CURRENT_SECTION

    parser = argparse.ArgumentParser(description="Validate agent runtime and installation")
    parser.add_argument("--config", "-c", default="", help="Optional bootstrap config path. Defaults to rendered runtime config.")
    args = parser.parse_args()

    repo_root = _repo_root()
    config_mode = "runtime"
    if args.config:
        config_path = Path(args.config)
        if not config_path.exists():
            config_path = repo_root / args.config
        if not config_path.exists():
            print(f"Procurando agent.yaml em: {Path(args.config).resolve()}, {config_path.resolve()}")
            fail("agent.yaml não encontrado")
            _record_check("config:agent-yaml", "fail", "agent.yaml não encontrado", artifact=config_path)
            print(f"\nResultado: 0 ok, 0 warn, 1 fail")
            sys.exit(1)
        with open(config_path) as f:
            cfg = yaml.safe_load(f) or {}
        config_mode = "bootstrap"
    else:
        cfg, config_path = _load_runtime_cfg(repo_root)
        if cfg is None:
            print(f"Procurando runtime config em: {(repo_root / 'config' / 'branding.yaml').resolve()}")
            fail("runtime branding não encontrado")
            _record_check(
                "config:runtime-branding",
                "fail",
                "runtime branding não encontrado",
                artifact=repo_root / "config" / "branding.yaml",
            )
            print(f"\nResultado: 0 ok, 0 warn, 1 fail")
            sys.exit(1)

    cycle_id = _ensure_install_context(cfg)
    from telemetry import log_run_step

    name = cfg.get("name", "?")
    codename = cfg.get("codename", "?")
    edge_home = Path(os.path.expanduser(cfg.get("edge_home", f"~/{codename}")))
    blog_port = int(cfg.get("blog_port", 8766))
    blog_host = cfg.get("blog_host", "127.0.0.1")

    print(f"\n\033[1m━━━  edge-doctor: {name} ({codename})  ━━━\033[0m\n")
    log_run_step(
        "edge-doctor",
        "doctor",
        "started",
        run_id=cycle_id,
        config=str(config_path.resolve()),
        config_mode=config_mode,
    )

    # 1. Dependencies
    CURRENT_SECTION = "dependencies"
    print("\033[1m[1/8] Dependências\033[0m")
    check_command("claude", "Claude Code CLI")
    check_command("edge-runner", "Edge runner CLI")
    check_command("python3", "Python 3")
    check_command("git", "Git")
    check_command("gh", "GitHub CLI (opcional)")
    print()

    # 2. Directory structure
    CURRENT_SECTION = "directories"
    print("\033[1m[2/8] Diretórios\033[0m")
    check_dir(edge_home, "EDGE_STATE_DIR")
    check_dir(repo_root / "blog", "Blog code")
    check_dir(edge_home / "blog" / "entries", "Blog entries")
    check_dir(edge_home / "reports", "Reports")
    check_dir(repo_root / "tools", "Tools")
    check_dir(repo_root / "config", "Runtime config")
    check_dir(repo_root / "secrets", "Secrets")
    check_dir(edge_home / "logs", "Logs")
    print()

    # 3. Critical files
    CURRENT_SECTION = "critical_files"
    print("\033[1m[3/8] Arquivos críticos\033[0m")
    claude_md = Path.home() / ".claude" / "CLAUDE.md"
    check_file(claude_md, "CLAUDE.md")
    check_file(repo_root / "config" / "branding.yaml", "branding.yaml")
    check_file(repo_root / "config" / "runtime-routers.yaml", "runtime-routers.yaml")
    check_file(repo_root / "config" / "preflight.yaml", "preflight.yaml")
    check_file(repo_root / "config" / "postflight.yaml", "postflight.yaml")
    check_file(repo_root / "config" / "strategy.md", "strategy.md")
    check_residual_placeholders(claude_md, "CLAUDE.md")
    check_residual_placeholders(repo_root / "config" / "branding.yaml", "branding.yaml")
    print()

    # 4. Secrets
    CURRENT_SECTION = "secrets"
    print("\033[1m[4/8] Secrets\033[0m")
    keys_env = repo_root / "secrets" / "keys.env"
    # ANTHROPIC_API_KEY is NOT checked: Claude Code subscription is the expected auth path,
    # and MANIFEST.md / SETUP_GUIDE.md declare "empty is the expected state in most deploys".
    # Checking it emitted a warning that contradicted the docs and confused new users (see #84).
    check_secret(keys_env, "OPENAI_API_KEY", required=False)    # degrades: no review-gate/consult
    print()

    # 5. Venvs
    CURRENT_SECTION = "venvs"
    print("\033[1m[5/8] Python venvs\033[0m")
    blog_venv = repo_root / "blog" / ".venv" / "bin" / "python3"
    if blog_venv.exists():
        ok("Blog venv: instalado")
        _record_check("venv:blog", "ok", "Blog venv: instalado", artifact=blog_venv)
    else:
        fail("Blog venv: não encontrado — rodar edge-apply")
        _record_check("venv:blog", "fail", "Blog venv: não encontrado — rodar edge-apply", artifact=blog_venv)
    tools_venv = repo_root / "tools" / ".venv" / "bin" / "python3"
    if tools_venv.exists():
        ok("Tools venv: instalado (edge-consult, review-gate)")
        _record_check("venv:tools", "ok", "Tools venv: instalado (edge-consult, review-gate)", artifact=tools_venv)
    else:
        fail("Tools venv: não encontrado — edge-consult/review-gate/deepresearch QUEBRADOS")
