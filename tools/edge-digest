#!/usr/bin/env python3
"""edge-digest — gera briefing.md a partir de dados estruturados.

Determinístico. Zero tokens. Roda após blog-full-publish.
Lê: events.jsonl, threads/*.md, claims abertas, últimos beats, erros ativos.
Gera: ~/edge/briefing.md — o ÚNICO arquivo que sessões precisam ler.

Uso:
  edge-digest              # gerar briefing
  edge-digest --dry-run    # mostrar sem salvar
"""

import argparse
import json
import os
import re
import subprocess
import yaml
from datetime import datetime, timezone, timedelta
from pathlib import Path

HOME = Path.home()
EVENTS_FILE = HOME / "edge" / "logs" / "events.jsonl"
THREADS_DIR = HOME / "edge" / "threads"
BLOG_DIR = HOME / "edge" / "blog" / "entries"
HEARTBEAT_LOG = HOME / "edge" / "logs" / f"heartbeat-{datetime.now().strftime('%Y-%m-%d')}.log"
DEBUG_FILE = HOME / ".claude" / "projects" / "-home-vboxuser" / "memory" / "debugging.md"
INSIGHTS_FILE = HOME / ".claude" / "projects" / "-home-vboxuser" / "memory" / "insights.md"
OUTPUT_FILE = HOME / "edge" / "briefing.md"

TODAY = datetime.now().strftime("%Y-%m-%d")
NOW = datetime.now().strftime("%H:%M")


def read_threads():
    """Lê frontmatter de todos os threads."""
    threads = []
    if not THREADS_DIR.exists():
        return threads
    for f in sorted(THREADS_DIR.glob("*.md")):
        try:
            raw = f.read_text()
            parts = raw.split("---", 2)
            if len(parts) < 3:
                continue
            fm = yaml.safe_load(parts[1])
            if not fm:
                continue
            fm["_file"] = f.name
            fm["_id"] = fm.get("id", f.stem)
            threads.append(fm)
        except Exception:
            continue
    return threads


def read_events(limit=30):
    """Últimos N eventos."""
    if not EVENTS_FILE.exists():
        return []
    events = []
    with open(EVENTS_FILE) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                events.append(json.loads(line))
            except json.JSONDecodeError:
                continue
    return events[-limit:]


def read_open_claims():
    """Claims abertas (!) de todos os entries."""
    claims = []
    if not BLOG_DIR.exists():
        return claims
    for f in sorted(BLOG_DIR.glob("*.md"), reverse=True):
        try:
            raw = f.read_text()
            parts = raw.split("---", 2)
            if len(parts) < 3:
                continue
            fm = yaml.safe_load(parts[1])
            if not fm or "claims" not in fm:
                continue
            for c in fm.get("claims", []):
                # Normalize: accept str ("!claim") or dict ({claim, status})
                if isinstance(c, dict):
                    status = c.get("status", "").lower()
                    if status in ("unverified", "open", "disputed"):
                        claims.append({
                            "claim": c.get("claim", ""),
                            "source": fm.get("title", f.name),
                            "threads": fm.get("threads", []),
                        })
                elif isinstance(c, str) and c.startswith("!"):
                    claims.append({
                        "claim": c.lstrip("! "),
                        "source": fm.get("title", f.name),
                        "threads": fm.get("threads", []),
                    })
        except Exception:
            continue
    return claims


def read_beats():
    """Últimos beats de hoje."""
    if not HEARTBEAT_LOG.exists():
        return []
    lines = HEARTBEAT_LOG.read_text().strip().split("\n")
    return lines[-5:]  # últimos 5


def read_open_errors():
    """Erros abertos no debugging.md."""
    if not DEBUG_FILE.exists():
        return []
    content = DEBUG_FILE.read_text()
    errors = []
    for line in content.split("\n"):
        if re.search(r'status:\s*(aberto|open)|\[ \]', line, re.IGNORECASE):
            errors.append(line.strip()[:120])
    return errors[:5]


def read_unread_insights():
    """Insights sem [LIDO]."""
    if not INSIGHTS_FILE.exists():
        return []
    content = INSIGHTS_FILE.read_text()
    insights = []
    for line in content.split("\n"):
        if line.startswith("- ") and "[LIDO" not in line:
            insights.append(line[2:].strip()[:120])
    return insights[:5]


def count_blog_entries():
    """Contagem de entries com e sem claims."""
    if not BLOG_DIR.exists():
        return 0, 0
    total = 0
    with_claims = 0
    for f in BLOG_DIR.glob("*.md"):
        total += 1
        try:
            raw = f.read_text()
            parts = raw.split("---", 2)
            if len(parts) >= 3:
                fm = yaml.safe_load(parts[1])
                if fm and fm.get("claims"):
                    with_claims += 1
        except Exception:
            continue
    return total, with_claims


def generate_briefing():
    """Gera o briefing completo."""
    threads = read_threads()
    events = read_events(20)
    open_claims = read_open_claims()
    beats = read_beats()
    errors = read_open_errors()
    insights = read_unread_insights()
    total_entries, entries_with_claims = count_blog_entries()

    lines = []
    lines.append(f"# Briefing — {TODAY} {NOW}")
    lines.append(f"<!-- Gerado por edge-digest. NÃO editar manualmente. -->")
    lines.append("")

    # ── Fios para hoje ──
    resurface_threads = []
    active_threads = []
    waiting_threads = []
    for t in threads:
        status = t.get("status", "")
        resurface = str(t.get("resurface", ""))
        if status in ("active", "waiting") and resurface and resurface <= TODAY:
            resurface_threads.append(t)
        if status == "active":
            active_threads.append(t)
        elif status == "waiting":
            waiting_threads.append(t)

    if resurface_threads:
        lines.append("## Resurface HOJE")
        for t in resurface_threads:
            owner = t.get("owner", "?")
            title = t.get("title", t["_id"])
            status = t.get("status", "?")
            lines.append(f"- **{title}** [{status}] owner:{owner}")
        lines.append("")

    # ── Threads ativos ──
    lines.append(f"## Fios ({len(active_threads)} ativos, {len(waiting_threads)} esperando)")
    for t in active_threads:
        owner = t.get("owner", "?")
        title = t.get("title", t["_id"])
        resurface = str(t.get("resurface", "?"))
        updated = str(t.get("updated", "?"))
        lines.append(f"- [{t.get('status','')}] {title} (owner:{owner}, resurface:{resurface}, updated:{updated})")
    for t in waiting_threads:
        owner = t.get("owner", "?")
        title = t.get("title", t["_id"])
        lines.append(f"- [waiting] {title} (owner:{owner})")
    lines.append("")

    # ── O que não sei ──
    if open_claims:
        lines.append(f"## O que não sei ({len(open_claims)} gaps)")
        for c in open_claims[:7]:
            fios = ", ".join(c["threads"]) if c["threads"] else "sem fio"
            lines.append(f"- ? {c['claim']} ← {c['source']} ({fios})")
        lines.append("")

    # ── Últimos eventos ──
    if events:
        lines.append(f"## Últimos eventos ({len(events)})")
        for e in events[-10:]:
            ts = e.get("timestamp", "?")
            try:
                dt = datetime.fromisoformat(ts)
                ts_display = dt.strftime("%m-%d %H:%M")
            except (ValueError, AttributeError):
                ts_display = ts[:16]
            etype = e.get("type", "?")
            summary = e.get("summary", "")
            thread = e.get("thread_id", "")
            thread_str = f" fio:{thread}" if thread else ""
            lines.append(f"- [{ts_display}] {etype}{thread_str} — {summary}")
        lines.append("")

    # ── Beats de hoje ──
    if beats:
        lines.append(f"## Beats hoje ({len(beats)})")
        for b in beats:
            lines.append(f"- {b}")
        lines.append("")

    # ── Erros ativos ──
    if errors:
        lines.append(f"## Erros ativos ({len(errors)})")
        for e in errors:
            lines.append(f"- {e}")
        lines.append("")

    # ── Insights não lidos ──
    if insights:
        lines.append(f"## Insights novos ({len(insights)})")
        for i in insights:
            lines.append(f"- {i}")
        lines.append("")

    # ── Métricas ──
    lines.append("## Métricas")
    lines.append(f"- Entries: {total_entries} total, {entries_with_claims} com claims ({int(entries_with_claims/max(total_entries,1)*100)}%)")
    lines.append(f"- Threads: {len(active_threads)} ativos, {len(waiting_threads)} esperando")
    lines.append(f"- Gaps abertos: {len(open_claims)}")
    lines.append(f"- Erros ativos: {len(errors)}")
    lines.append("")

    return "\n".join(lines)


def main():
    parser = argparse.ArgumentParser(description="Gerar briefing.md a partir de dados estruturados")
    parser.add_argument("--dry-run", action="store_true", help="Mostrar sem salvar")
    args = parser.parse_args()

    briefing = generate_briefing()

    if args.dry_run:
        print(briefing)
    else:
        OUTPUT_FILE.write_text(briefing)
        lines = briefing.count("\n")
        print(f"OK: {OUTPUT_FILE} ({lines} linhas)")


if __name__ == "__main__":
    main()
