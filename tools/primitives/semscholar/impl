#!/usr/bin/env python3
"""semscholar primitive — search Semantic Scholar via public API.

Contract: JSON-over-stdout. See docs/TOOL_CONTRACT.md.
"""

import argparse
import json
import os
import sys
import time
import urllib.parse
import urllib.request
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "_shared"))
sys.path.insert(0, str(Path(__file__).resolve().parent))
try:
    from usage_log import log_invocation
except ImportError:
    def log_invocation(*args, **kwargs):
        pass


API_BASE = "https://api.semanticscholar.org/graph/v1/paper/search"
DEFAULT_FIELDS = ["paperId", "title", "authors", "year", "abstract", "citationCount", "url"]


def main() -> int:
    parser = argparse.ArgumentParser(description="Search Semantic Scholar")
    parser.add_argument("--query", required=True)
    parser.add_argument("--limit", type=int, default=20)
    parser.add_argument("--fields", nargs="*", default=DEFAULT_FIELDS)
    args = parser.parse_args()

    start_ts = time.time()
    log_invocation(
        "semscholar", "start",
        input_summary=f"query={args.query!r} limit={args.limit}",
    )

    params = urllib.parse.urlencode({
        "query": args.query,
        "limit": args.limit,
        "fields": ",".join(args.fields),
    })
    url = f"{API_BASE}?{params}"

    headers = {"User-Agent": "edge-of-chaos-primitives/1.0"}
    api_key = os.environ.get("SEMSCHOLAR_API_KEY", "")
    if api_key:
        headers["x-api-key"] = api_key

    req = urllib.request.Request(url, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            data = json.loads(resp.read())
    except Exception as exc:
        duration_ms = int((time.time() - start_ts) * 1000)
        print(json.dumps({"ok": False, "error": f"http fetch failed: {exc}", "code": 503}))
        print(f"Error: semscholar fetch failed: {exc}", file=sys.stderr)
        log_invocation("semscholar", "end", duration_ms=duration_ms, ok=False, error=str(exc))
        return 1

    results = data.get("data", [])
    duration_ms = int((time.time() - start_ts) * 1000)
    payload = {
        "ok": True,
        "query": args.query,
        "count": len(results),
        "results": results,
    }
    print(json.dumps(payload, ensure_ascii=False))
    log_invocation("semscholar", "end", duration_ms=duration_ms, ok=True, result_count=len(results))
    return 0


if __name__ == "__main__":
    sys.exit(main())
