#!/usr/bin/env python3
"""edge-preflight — deterministic dispatch preflight and request enrichment.

Usage:
  edge-preflight run
  edge-preflight run --profile heartbeat_default --skill research
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))
from _shared.dispatch_runtime import (  # noqa: E402
    enrich_dispatch_state,
    maybe_block_duplicate,
    read_dispatch_state,
    record_preflight,
    write_dispatch_state,
)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Run deterministic dispatch preflight")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_run = sub.add_parser("run", help="Refresh runtime context for the active cycle")
    p_run.add_argument("--profile", help="Override preflight profile")
    p_run.add_argument("--skill", help="Override skill for request enrichment")
    p_run.add_argument("--stage", default="preflight", help="Stage label for telemetry")
    return parser


def cmd_run(args: argparse.Namespace) -> int:
    state = read_dispatch_state()
    request = state.setdefault("request", {})
    state_block = state.setdefault("state", {})
    summary: dict[str, object] = {}
    try:
        summary = enrich_dispatch_state(
            state,
            skill=args.skill or request.get("skill"),
            stage=args.stage,
            profile=args.profile or request.get("preflight_profile"),
        )
        blocked, reason = maybe_block_duplicate(state)
        if blocked:
            state_block["preflight_status"] = "failed"
            state_block["phase"] = "preflight_failed"
            state_block["updated_at"] = state_block.get("preflight_checked_at") or state_block.get("updated_at")
            summary["duplicate_risk"] = "block"
            summary["blocked_reason"] = reason or "duplicate_risk_block"
            write_dispatch_state(state)
            record_preflight(state, summary, status="failed")
            print(json.dumps({"ok": False, "blocked": True, "reason": reason, "state": state, "summary": summary}, indent=2, ensure_ascii=False))
            return 2

        write_dispatch_state(state)
        record_preflight(state, summary, status="completed")
        print(json.dumps({"ok": True, "state": state, "summary": summary}, indent=2, ensure_ascii=False))
        return 0
    except Exception as exc:
        state_block["preflight_status"] = "failed"
        state_block["phase"] = "preflight_failed"
        summary = summary or {
            "skill": args.skill or request.get("skill"),
            "stage": args.stage,
            "profile": args.profile or request.get("preflight_profile") or "standard",
        }
        summary["error"] = str(exc)
        write_dispatch_state(state)
        record_preflight(state, summary, status="failed")
        print(json.dumps({"ok": False, "error": str(exc), "state": state, "summary": summary}, indent=2, ensure_ascii=False), file=sys.stderr)
        return 1


def main() -> int:
    args = build_parser().parse_args()
    if args.cmd == "run":
        return cmd_run(args)
    return 1


if __name__ == "__main__":
    sys.exit(main())
