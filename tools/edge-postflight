    if code != 0:
        detail = (stderr or stdout or f"exit={code}").splitlines()[-1]
        append_postskill_log("source_affordance_digest", "FAIL", detail)
        return {"ok": False, "detail": detail, "payload": {}}
    detail = (stdout or "source affordance digest refreshed").splitlines()[-1]
    append_postskill_log("source_affordance_digest", "OK", detail)
    return {"ok": True, "detail": detail, "payload": {"detail": detail}}


def refresh_curation_digest() -> dict[str, Any]:
    code, stdout, stderr = run_subprocess([sys.executable, str(EDGE_REPO_DIR / "tools" / "edge-curation"), "sync", "--json"])
    if code != 0:
        detail = (stderr or stdout or f"exit={code}").splitlines()[-1]
        append_postskill_log("curation_digest", "FAIL", detail)
        return {"ok": False, "status": "failed", "detail": detail, "payload": {}}
    payload = json.loads(stdout) if stdout else {}
    status = str(payload.get("status") or "ok")
    hot_state = payload.get("hot_state") or {}
    hot_threads = hot_state.get("threads") or {}
    hot_topics = hot_state.get("topics") or {}
    operator_pressure = payload.get("operator_pressure") or {}
    detail = (
        f"topics={((payload.get('topics') or {}).get('total', 0))} "
        f"candidates={((payload.get('procedures') or {}).get('candidate_total', 0))} "
        f"stale={((payload.get('corpus') or {}).get('stale_candidates', 0))} "
        f"threads_created={hot_threads.get('created_total', 0)} "
        f"topics_created={hot_topics.get('created_total', 0)} "
        f"operator_items={operator_pressure.get('items_total', 0)} "
        f"operator_threads_created={operator_pressure.get('threads_created', 0)} "
        f"operator_topics_created={operator_pressure.get('topics_created', 0)} "
        f"operator_workflows_created={operator_pressure.get('workflows_created', 0)} "
        f"operator_pre_skill_context={operator_pressure.get('pre_skill_context_total', 0)}"
    )
    append_postskill_log("curation_digest", "WARN" if status == "warning" else "OK", detail)
    return {
        "ok": status == "ok",
        "status": status,
        "detail": detail,
        "payload": payload,
    }


def refresh_capabilities_status(skill: str | None = None) -> dict[str, Any]:
    payload = build_capability_status(skill=skill)
    summary = payload.get("summary") or {}
    detail = (
        f"health={summary.get('health_status', 'unknown')} "
        f"available={summary.get('available_total', 0)} "
        f"degraded={summary.get('degraded_total', 0)} "
        f"broken={summary.get('broken_total', 0)}"
    )
    append_postskill_log("capabilities_status", "OK", detail)
    return {"ok": True, "detail": detail, "payload": payload}


def refresh_claims_status() -> dict[str, Any]:
    digest = _read_json_file(CLAIMS_DIGEST_FILE, {})
    orphans = _read_json_file(ORPHAN_CLAIMS_FILE, {})
    if not isinstance(digest, dict):
        digest = {}
    if not isinstance(orphans, dict):
        orphans = {}

    digest_cache = _projection_cache_status(CLAIMS_DIGEST_FILE)
    orphan_cache = _projection_cache_status(ORPHAN_CLAIMS_FILE)
    cache_status = _combined_claims_cache_status(digest_cache, orphan_cache)
    cache_age = digest_cache.get("projection_age_seconds")
    detail = (
        f"open={digest.get('open_total', 0)} "
        f"orphans={orphans.get('orphan_total', digest.get('unthreaded_count', 0))} "
        f"cache={cache_status}"
    )
    if cache_age is not None:
        detail += f" age={cache_age}s"

    status = "warning" if cache_status in {"partial_cached", "stale_cached", "unknown"} else "ok"
    append_postskill_log("claims_digest", "OK" if cache_status in {"cached", "missing"} else "WARN", detail)
    return {
        "ok": cache_status != "unknown",
        "status": status,
        "detail": detail,
        "payload": {
            "digest": digest,
            "orphans": orphans,
            "cache": {
                "status": cache_status,
                "claims_digest": {
                    "source_path": str(CLAIMS_DIGEST_FILE),
                    **digest_cache,
                },
                "orphan_claims": {
                    "source_path": str(ORPHAN_CLAIMS_FILE),
                    **orphan_cache,
                },
                "max_age_seconds": _claims_projection_max_age_seconds(),
            },
        },
    }


def refresh_pipeline_state(cycle_id: str | None = None) -> dict[str, Any]:
    code, stdout, stderr = run_subprocess([sys.executable, str(EDGE_REPO_DIR / "tools" / "rollup-pipeline-state.py"), "--json"])
    if code != 0:
        detail = (stderr or stdout or f"exit={code}").splitlines()[-1]
        append_postskill_log("pipeline_state", "FAIL", detail)
        return {"ok": False, "status": "failed", "detail": detail, "payload": {}, "current_attention": []}

    payload = json.loads(stdout) if stdout else {}
    summary = payload.get("summary") or {}
    counts = summary.get("counts_by_status") or {}
    attention = [
        item
        for item in (payload.get("attention_artifacts") or [])
        if cycle_id and item.get("cycle_id") == cycle_id
    ]
    detail = (
        f"artifacts={summary.get('artifacts_total', 0)} "
        f"attention={summary.get('artifacts_attention', 0)} "
        f"complete={counts.get('complete', 0)} "
        f"blocked={counts.get('blocked', 0)} "
        f"failed={counts.get('failed', 0)} "
        f"current_attention={len(attention)}"
    )
    ok = len(attention) == 0
    append_postskill_log("pipeline_state", "OK" if ok else "WARN", detail)
    return {
        "ok": ok,
        "status": "ok" if ok else "warning",
        "detail": detail,
        "payload": payload,
        "current_attention": attention[:5],
    }


def refresh_briefing() -> dict[str, Any]:
    code, stdout, stderr = run_subprocess([sys.executable, str(EDGE_REPO_DIR / "tools" / "edge-digest")])
    if code != 0:
        detail = (stderr or stdout or f"exit={code}").splitlines()[-1]
        append_postskill_log("briefing_digest", "FAIL", detail)
        return {"ok": False, "detail": detail}
    detail = (stdout or "briefing refreshed").splitlines()[-1]
    append_postskill_log("briefing_digest", "OK", detail)
    return {"ok": True, "detail": detail}


def compute_delta(
    before: dict[str, Any],
    *,
    claims: dict[str, Any],
    primitives: dict[str, Any],
    workflows: dict[str, Any],
    capabilities: dict[str, Any] | None = None,
) -> dict[str, Any]:
    digest = claims.get("digest") or {}
    orphans = claims.get("orphans") or {}
    primitives_summary = (primitives.get("summary") or {})
    workflow_summary = (workflows.get("summary") or {})
    capabilities_summary = ((capabilities or {}).get("summary") or {})
    return {
        "claims_open_delta": int(digest.get("open_total", 0) or 0) - before["claims_open_total"],
        "orphans_delta": int(orphans.get("orphan_total", 0) or 0) - before["orphans_total"],
        "primitive_broken_delta": int(primitives_summary.get("broken_total", 0) or 0) - before["primitive_broken_total"],
        "primitive_degraded_delta": int(primitives_summary.get("degraded_total", 0) or 0) - before["primitive_degraded_total"],
        "capability_broken_delta": int(capabilities_summary.get("broken_total", 0) or 0) - before["capability_broken_total"],
        "capability_degraded_delta": int(capabilities_summary.get("degraded_total", 0) or 0) - before["capability_degraded_total"],
        "workflow_broken_delta": int(workflow_summary.get("broken_total", 0) or 0) - before["workflow_broken_total"],
        "workflow_stale_delta": int(workflow_summary.get("stale_total", 0) or 0) - before["workflow_stale_total"],
    }


def _protocol_step(step: dict[str, Any], *, status: str, satisfied: bool, detail: str, extra: dict[str, Any] | None = None) -> dict[str, Any]:
    payload = {
        "id": step.get("id"),
        "kind": step.get("kind"),
        "status": status,
        "satisfied": satisfied,
        "detail": detail,
    }
    if step.get("note"):
        payload["note"] = step.get("note")
    if extra:
        payload.update(extra)
    return payload


def _execute_postflight_step(step: dict[str, Any], state: dict[str, Any]) -> dict[str, Any]:
    request = state.setdefault("request", {})
    kind = str(step.get("kind") or "")
    skill = str(request.get("skill") or "").strip()

    if kind == "validate.recent":
        ok, validate_status, validate_step = run_validate_recent()
        return _protocol_step(
            step,
            status="warning" if validate_status == "warning" else ("ok" if ok else "failed"),
            satisfied=ok,
            detail=str(validate_step.get("detail") or validate_status),
            extra={
                "step": validate_step.get("step"),
                "returncode": validate_step.get("returncode"),
                "fix_attempted": validate_step.get("fix_attempted", False),
                "payload": validate_step,
            },
        )

    if kind == "claims.refresh":
        refreshed = refresh_claims_status()
        refreshed_status = str(refreshed.get("status") or ("ok" if refreshed.get("ok") else "warning"))
        return _protocol_step(
            step,
            status=refreshed_status,
            satisfied=bool(refreshed.get("ok", False)),
            detail=str(refreshed.get("detail") or ""),
            extra={"payload": refreshed.get("payload") or {}},
        )

    if kind == "pipeline_state.refresh":
        refreshed = refresh_pipeline_state(cycle_id=state.get("cycle_id"))
        return _protocol_step(
            step,
            status=str(refreshed.get("status") or ("ok" if refreshed.get("ok") else "warning")),
            satisfied=bool(refreshed.get("ok", False)),
            detail=str(refreshed.get("detail") or ""),
            extra={
                "payload": refreshed.get("payload") or {},
                "current_attention": refreshed.get("current_attention") or [],
            },
        )

    if kind == "primitives.status":
        refreshed = refresh_primitives_status()
        return _protocol_step(step, status="ok" if refreshed.get("ok") else "failed", satisfied=bool(refreshed.get("ok", False)), detail=str(refreshed.get("detail") or ""), extra={"payload": refreshed.get("payload") or {}})

    if kind == "workflow.status":
        refreshed = refresh_workflow_status()
        return _protocol_step(step, status="ok", satisfied=True, detail=str(refreshed.get("detail") or ""), extra={"payload": refreshed.get("payload") or {}})

    if kind == "curation.digest":
        refreshed = refresh_curation_digest()
        refreshed_status = str(refreshed.get("status") or ("ok" if refreshed.get("ok") else "failed"))
        return _protocol_step(
            step,
            status=refreshed_status,
            satisfied=bool(refreshed.get("ok", False)),
            detail=str(refreshed.get("detail") or ""),
            extra={"payload": refreshed.get("payload") or {}},
        )

    if kind == "source_affordance.digest":
        refreshed = refresh_source_affordance_digest()
        return _protocol_step(
            step,
            status="ok" if refreshed.get("ok") else "failed",
            satisfied=bool(refreshed.get("ok", False)),
            detail=str(refreshed.get("detail") or ""),
            extra={"payload": refreshed.get("payload") or {}},
        )

    if kind == "capabilities.status":
        refreshed = refresh_capabilities_status(skill=skill)
        return _protocol_step(step, status="ok", satisfied=bool(refreshed.get("ok", False)), detail=str(refreshed.get("detail") or ""), extra={"payload": refreshed.get("payload") or {}})

    if kind == "briefing.refresh":
        refreshed = refresh_briefing()
        return _protocol_step(step, status="ok" if refreshed.get("ok") else "failed", satisfied=bool(refreshed.get("ok", False)), detail=str(refreshed.get("detail") or ""))

    if kind == "cycle_health.observe":
        observations = observe_cycle_health_events(state)
        return _protocol_step(
            step,
            status="ok",
            satisfied=True,
            detail=f"primitive_bypass={observations.get('primitive_bypass', 0)}",
            extra={"payload": observations},
        )

    if kind == "async_inbox.respond":
        result = acknowledge_captured_inbox(state)
        ok = bool(result.get("ok", False))
        status = "ok" if ok else "warning"
        append_postskill_log("async_inbox_response", "OK" if ok else "WARN", str(result.get("detail") or ""))
        return _protocol_step(
            step,
            status=status,
            satisfied=ok,
            detail=str(result.get("detail") or ""),
            extra={"payload": result},
        )

    if kind == "capability.probe":
        capability_name = str(step.get("capability") or "")
        try:
            result = probe_capability(capability_name, skill=skill)
            satisfied = result.returncode == 0
            return _protocol_step(
                step,
                status="ok" if satisfied else "failed",
                satisfied=satisfied,
                detail=f"{capability_name} exit={result.returncode}",
                extra={"capability": capability_name, "exit_code": int(result.returncode)},
            )
        except Exception as exc:
            return _protocol_step(step, status="failed", satisfied=False, detail=str(exc), extra={"capability": capability_name})

    if kind == "capability.invoke":
        capability_name = str(step.get("capability") or "")
        argv = list(step.get("argv") or [])
        try:
            result = invoke_capability(capability_name, argv, skill=skill)
            satisfied = result.returncode == 0
            return _protocol_step(
                step,
                status="ok" if satisfied else "failed",
                satisfied=satisfied,
                detail=f"{capability_name} exit={result.returncode}",
                extra={"capability": capability_name, "exit_code": int(result.returncode), "argv": argv},
            )
        except Exception as exc:
            return _protocol_step(step, status="failed", satisfied=False, detail=str(exc), extra={"capability": capability_name, "argv": argv})

    raise RuntimeError(f"unsupported postflight protocol kind: {kind}")


def record_postflight(state: dict[str, Any], *, status: str, profile: str, reason: str, steps: list[dict[str, Any]], delta: dict[str, Any]) -> None:
    cycle_id = state.get("cycle_id")
    request = state.setdefault("request", {})
    state_block = state.setdefault("state", {})
    state_block["postflight_status"] = status
    state_block["postflight_profile"] = profile
    state_block["postflight_checked_at"] = now_iso()
    state_block["updated_at"] = state_block["postflight_checked_at"]
    state_block["postflight_reason"] = reason
    state_block["postflight_steps"] = steps
    state_block["postflight_delta"] = delta
    write_dispatch_state(state)
    event_type = "PostflightCompleted" if status in {"completed", "warning", "skipped"} else "PostflightFailed"
    emit_shadow_event(
        event_type,
        actor="edge-postflight",
        cycle_id=cycle_id,
        payload={"profile": profile, "reason": reason, "steps": steps, "delta": delta},
    )
    log_event(
        "dispatch_postflight",
        actor="edge-postflight",
        cycle_id=cycle_id,
        profile=profile,
        status=status,
        reason=reason,
    )


def run_standard(state: dict[str, Any], profile: str) -> tuple[bool, str, str, list[dict[str, Any]], dict[str, Any]]:
    protocol = ensure_compiled_protocol("postflight")
    steps: list[dict[str, Any]] = []
    before = before_snapshot(state)
    request = state.setdefault("request", {})
    request["post_skill_context"] = protocol_context(protocol)
    emit_shadow_event(
        "PostSkillContextLoaded",
        actor="edge-postflight",
        cycle_id=state.get("cycle_id"),
        payload={
            "protocol_stage": "post_skill",
            "source_hash": protocol.get("source_hash"),
            "compiled_hash": protocol.get("compiled_hash"),
            "context_note_total": len(protocol.get("context_notes") or []),
            "operator_note_total": len(protocol.get("operator_notes") or []),
        },
    )

    failed_steps = 0
    claims_payload: dict[str, Any] = {}
    primitives_payload: dict[str, Any] = {}
    workflows_payload: dict[str, Any] = {}
    capabilities_payload: dict[str, Any] = {}
    pipeline_state_payload: dict[str, Any] = {}
    pipeline_state_attention: list[dict[str, Any]] = []
    curation_payload: dict[str, Any] = {}
    async_inbox_payload: dict[str, Any] = {}
    warning_seen = False

    for step in protocol.get("procedures") or []:
        try:
            result = _execute_postflight_step(step, state)
        except Exception as exc:
            result = _protocol_step(
                step,
                status="warning",
                satisfied=False,
                detail=str(exc),
                extra={"error": str(exc), "failure_mode": "exception"},
            )
        steps.append(result)
        if not result.get("satisfied"):
            failed_steps += 1
        if result.get("status") == "warning":
            warning_seen = True
        emit_protocol_step_observed(
            "postflight",
            step,
            status=str(result.get("status") or "unknown"),
            detail=str(result.get("detail") or ""),
            satisfied=bool(result.get("satisfied")),
            cycle_id=state.get("cycle_id"),
            extra={k: v for k, v in result.items() if k not in {"id", "kind", "note", "status", "satisfied", "detail", "payload"}},
        )

        payload = result.get("payload") or {}
        kind = str(step.get("kind") or "")
        if kind == "claims.refresh" and isinstance(payload, dict):
            claims_payload = payload
        elif kind == "pipeline_state.refresh" and isinstance(payload, dict):
            pipeline_state_payload = payload
            pipeline_state_attention = list(result.get("current_attention") or [])
        elif kind == "primitives.status" and isinstance(payload, dict):
            primitives_payload = payload
        elif kind == "workflow.status" and isinstance(payload, dict):
            workflows_payload = payload
        elif kind == "capabilities.status" and isinstance(payload, dict):
            capabilities_payload = payload
        elif kind == "curation.digest" and isinstance(payload, dict):
            curation_payload = payload
        elif kind == "async_inbox.respond" and isinstance(payload, dict):
            async_inbox_payload = payload

    digest = claims_payload.get("digest") or {}
    orphans = claims_payload.get("orphans") or {}
    primitives_summary = (primitives_payload.get("summary") or {})
    workflow_summary = (workflows_payload.get("summary") or {})
    capabilities_summary = (capabilities_payload.get("summary") or {})

    if claims_payload:
        request["claims_summary"] = {
            "open_total": digest.get("open_total", 0),
            "verified_total": digest.get("verified_total", 0),
            "attention_count": digest.get("attention_count", 0),
            "unthreaded_count": digest.get("unthreaded_count", 0),
            "stale_count": digest.get("stale_count", 0),
            "fanout_ratio": digest.get("fanout_ratio", 0),
            "hot_threads_by_open_claims": (digest.get("hot_threads_by_open_claims") or [])[:5],
            "oldest_open_claims": (digest.get("oldest_open_claims") or [])[:5],
        }
        request["orphan_claims_summary"] = {
            "orphan_total": orphans.get("orphan_total", 0),
            "open_orphan_total": orphans.get("open_orphan_total", 0),
            "stale_orphan_total": orphans.get("stale_orphan_total", 0),
            "multi_artifact_orphan_total": orphans.get("multi_artifact_orphan_total", 0),
            "candidate_clusters": (orphans.get("candidate_clusters") or [])[:5],
        }
    if primitives_payload:
        request["primitives_status"] = {
            "health_status": primitives_summary.get("health_status", "unknown"),
            "summary": primitives_summary,
            "attention": [
                {
                    "name": item.get("name"),
                    "effective_status": item.get("effective_status"),
                    "problems": item.get("problems", []),
                    "usage_30d": item.get("usage_30d", 0),
                }
                for item in (primitives_payload.get("sources") or [])[:5]
                if item.get("effective_status") in {"broken", "degraded"}
            ],
        }
    if capabilities_payload:
        request["capabilities_status"] = {
            "health_status": capabilities_summary.get("health_status", "unknown"),
            "summary": capabilities_summary,
            "recommended": (capabilities_payload.get("recommended") or [])[:5],
            "attention": [
                {
                    "name": item.get("name"),
                    "kind": item.get("kind"),
                    "effective_status": item.get("effective_status"),
                    "description": item.get("description", ""),
                }
                for item in (capabilities_payload.get("capabilities") or [])
                if item.get("effective_status") in {"broken", "degraded"}
            ][:5],
        }
    if workflows_payload:
        request["workflow_status"] = {
            "workflow_total": workflow_summary.get("workflow_total", 0),
            "cited_total": workflow_summary.get("cited_total", 0),
            "broken_total": workflow_summary.get("broken_total", 0),
            "stale_total": workflow_summary.get("stale_total", 0),
            "top_used": workflow_summary.get("top_used", []),
            "top_broken": workflow_summary.get("top_broken", []),
        }
    if pipeline_state_payload:
        pipeline_summary = pipeline_state_payload.get("summary") or {}
        request["pipeline_state_summary"] = {
            "artifacts_total": pipeline_summary.get("artifacts_total", 0),
            "artifacts_attention": pipeline_summary.get("artifacts_attention", 0),
            "counts_by_status": pipeline_summary.get("counts_by_status", {}),
            "current_attention": pipeline_state_attention,
        }
    if curation_payload:
        request["curation_digest"] = curation_payload
    if async_inbox_payload:
        request["async_inbox_response"] = {
            "ok": bool(async_inbox_payload.get("ok", False)),
            "reply_posted": bool(async_inbox_payload.get("reply_posted", False)),
            "reply_id": async_inbox_payload.get("reply_id"),
            "processed_count": int(async_inbox_payload.get("processed_count", 0) or 0),
            "captured_total": int(async_inbox_payload.get("captured_total", 0) or 0),
            "detail": async_inbox_payload.get("detail") or "",
        }

    delta = compute_delta(
        before,
        claims=claims_payload,
        primitives=primitives_payload,
        workflows=workflows_payload,
        capabilities=capabilities_payload,
    )
    request["postflight_evidence"] = steps
    request["postflight_effects"] = {
        "protocol_source_hash": request["post_skill_context"].get("source_hash"),
        "protocol_compiled_hash": request["post_skill_context"].get("compiled_hash"),
        "failed_steps": failed_steps,
        "delta": delta,
        "pipeline_state": {
            "artifacts_total": int(((pipeline_state_payload.get("summary") or {}).get("artifacts_total", 0)) or 0),
            "artifacts_attention": int(((pipeline_state_payload.get("summary") or {}).get("artifacts_attention", 0)) or 0),
            "current_attention": len(pipeline_state_attention),
        } if pipeline_state_payload else {},
        "curation": {
            "topics_total": int((curation_payload.get("topics") or {}).get("total", 0) or 0),
            "stale_candidates": int((curation_payload.get("corpus") or {}).get("stale_candidates", 0) or 0),
            "procedure_candidates": int((curation_payload.get("procedures") or {}).get("candidate_total", 0) or 0),
            "hot_threads": int(((curation_payload.get("hot_state") or {}).get("threads") or {}).get("hot_total", 0) or 0),
            "threads_created": int(((curation_payload.get("hot_state") or {}).get("threads") or {}).get("created_total", 0) or 0),
            "topics_created": int(((curation_payload.get("hot_state") or {}).get("topics") or {}).get("created_total", 0) or 0),
            "missing_topic_candidates": int(((curation_payload.get("hot_state") or {}).get("topics") or {}).get("missing_candidates_total", 0) or 0),
            "stale_topics": int(((curation_payload.get("hot_state") or {}).get("topics") or {}).get("stale_total", 0) or 0),
            "operator_pressure_items": int((curation_payload.get("operator_pressure") or {}).get("items_total", 0) or 0),
            "operator_threads_created": int((curation_payload.get("operator_pressure") or {}).get("threads_created", 0) or 0),
            "operator_topics_created": int((curation_payload.get("operator_pressure") or {}).get("topics_created", 0) or 0),
            "operator_workflows_created": int((curation_payload.get("operator_pressure") or {}).get("workflows_created", 0) or 0),
            "operator_pre_skill_context": int((curation_payload.get("operator_pressure") or {}).get("pre_skill_context_total", 0) or 0),
            "operator_missing_topic_candidates": int((curation_payload.get("operator_pressure") or {}).get("missing_topic_candidates_total", 0) or 0),
        } if curation_payload else {},
        "async_inbox": {
            "reply_posted": bool(async_inbox_payload.get("reply_posted", False)),
            "processed_count": int(async_inbox_payload.get("processed_count", 0) or 0),
            "captured_total": int(async_inbox_payload.get("captured_total", 0) or 0),
        } if async_inbox_payload else {},
    }

    if failed_steps or warning_seen:
        return True, "warning", "postflight_step_warning", steps, delta
    return True, "completed", "postflight_standard_completed", steps, delta


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Run deterministic postflight for the active dispatch cycle")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_run = sub.add_parser("run", help="Execute postflight")
    p_run.add_argument("--profile", help="Override postflight profile")
    return parser


def cmd_run(args: argparse.Namespace) -> int:
    state = read_dispatch_state()
    request = state.setdefault("request", {})
    profile = args.profile or request.get("postflight_profile") or "standard"

    if profile in {"", "none"}:
        record_postflight(
            state,
            status="skipped",
            profile="none",
            reason="profile_none",
            steps=[{"step": "postflight_profile", "status": "skipped", "detail": "profile=none"}],
            delta={},
        )
        print(json.dumps({"ok": True, "status": "skipped", "state": state}, indent=2, ensure_ascii=False))
        return 0

    if profile != "standard":
        record_postflight(
            state,
            status="failed",
            profile=profile,
            reason="unknown_postflight_profile",
            steps=[{"step": "postflight_profile", "status": "failed", "detail": profile}],
            delta={},
        )
        print(json.dumps({"ok": False, "reason": "unknown_postflight_profile", "state": state}, indent=2, ensure_ascii=False), file=sys.stderr)
        return 1

    try:
        ok, postflight_status, reason, steps, delta = run_standard(state, profile)
    except Exception as exc:
        record_postflight(
            state,
            status="failed",
            profile=profile,
            reason="postflight_protocol_failed",
            steps=[{"step": "postflight_protocol", "status": "failed", "detail": str(exc)}],
            delta={},
        )
        print(json.dumps({"ok": False, "reason": "postflight_protocol_failed", "error": str(exc), "state": state}, indent=2, ensure_ascii=False), file=sys.stderr)
        return 1
    record_postflight(
        state,
        status=postflight_status if ok else "failed",
        profile=profile,
        reason=reason,
        steps=steps,
        delta=delta,
    )
    output = {"ok": ok, "status": postflight_status if ok else "failed", "reason": reason, "steps": steps, "delta": delta, "state": state}
    stream = sys.stdout if ok else sys.stderr
    print(json.dumps(output, indent=2, ensure_ascii=False), file=stream)
    return 0 if ok else 1


def main() -> int:
    args = build_parser().parse_args()
    if args.cmd == "run":
        return cmd_run(args)
    return 1


if __name__ == "__main__":
    sys.exit(main())
