        "",
        f"# {title}",
        "",
        "## What it is",
        "Hot knowledge extracted from recent operator feedback.",
        "",
        "## Current operator evidence",
        *_operator_evidence_lines(group),
        "",
        "## Curation rule",
        "- Quando feedback do usuario apontar para este conceito, consolide a evidencia aqui em vez de perder o conhecimento no historico da sessao.",
        "",
        "## Next consolidation",
        "- Replace this generated summary with a durable abstraction once the direction has been worked.",
        "",
    ]
    TOPICS_DIR.mkdir(parents=True, exist_ok=True)
    path = TOPICS_DIR / f"{thread_id}.md"
    path.write_text("\n".join(lines), encoding="utf-8")
    return path


def _curate_pre_skill_context(operator_digest: dict[str, Any]) -> dict[str, Any]:
    candidates: list[dict[str, Any]] = []
    seen: set[str] = set()
    for item in _operator_pressure_items(operator_digest):
        if not _is_operator_pre_skill_context_item(item):
            continue
        key = str(item.get("item_id") or _slugify(item.get("text", "")))
        if key in seen:
            continue
        seen.add(key)
        candidates.append(
            {
                "item_id": str(item.get("item_id") or ""),
                "text": item.get("text"),
                "target": item.get("target") or "",
                "sections": item.get("sections") or [],
                "source_kinds": _coerce_list(item.get("source_kinds")),
                "judgement": "pre_skill_context",
            }
        )
    return {
        "candidate_total": len(candidates),
        "candidates": candidates[:12],
    }


def _curate_operator_pressure(operator_digest: dict[str, Any]) -> dict[str, Any]:
    thread_files = _read_thread_files()
    topic_files = _read_topic_files()
    existing_topic_threads = {
        thread_id
        for topic in topic_files.values()
        for thread_id in _coerce_list(topic.get("threads"))
    }
    groups, item_total = _operator_pressure_groups(operator_digest)
    pre_skill_context = _curate_pre_skill_context(operator_digest)

    created_threads: list[dict[str, Any]] = []
    created_topics: list[dict[str, Any]] = []
    missing_topic_candidates: list[dict[str, Any]] = []

    for group in groups:
        thread_id = str(group.get("thread_id") or "").strip()
        if not thread_id:
            continue
        if thread_id not in thread_files:
            path = _write_operator_thread_stub(group)
            thread_files[thread_id] = {
                "id": thread_id,
                "title": group.get("title") or _slug_title(thread_id),
                "status": "active",
                "updated": datetime.now(timezone.utc).date().isoformat(),
                "path": str(path),
            }
            created_threads.append({"thread_id": thread_id, "path": str(path)})

        if thread_id in existing_topic_threads:
            continue
        target_path = TOPICS_DIR / f"{thread_id}.md"
        candidate = {
            "thread_id": thread_id,
            "title": group.get("title") or _slug_title(thread_id),
            "reason": "operator_pressure_without_topic",
            "score": int(group.get("score") or 0),
        }
        missing_topic_candidates.append(candidate)
        if target_path.exists():
            candidate["reason"] = "topic_file_exists_without_thread_link"
            candidate["path"] = str(target_path)
            continue
        path = _write_operator_topic_stub(group)
        existing_topic_threads.add(thread_id)
        created_topics.append({"thread_id": thread_id, "path": str(path)})

    return {
        "generated_at": _now_iso(),
        "source": str(OPERATOR_PRESSURE_HOT_DIGEST_FILE),
        "available": OPERATOR_PRESSURE_HOT_DIGEST_FILE.exists(),
        "items_total": item_total,
        "groups_total": len(groups),
        "threads_created": len(created_threads),
        "topics_created": len(created_topics),
        "pre_skill_context_total": int(pre_skill_context.get("candidate_total") or 0),
        "missing_topic_candidates_total": len(missing_topic_candidates),
        "created_threads": created_threads,
        "created_topics": created_topics,
        "pre_skill_context": pre_skill_context,
        "missing_topic_candidates": missing_topic_candidates[:12],
        "groups": [
            {
                "thread_id": group.get("thread_id"),
                "title": group.get("title"),
                "score": group.get("score"),
                "sections": group.get("sections"),
                "item_ids": group.get("item_ids"),
                "entities": group.get("entities"),
                "source_kinds": group.get("source_kinds"),
                "evidence": group.get("evidence"),
            }
            for group in groups[:12]
        ],
    }


def _curate_hot_state(open_gaps_digest: dict[str, Any]) -> dict[str, Any]:
    thread_files = _read_thread_files()
    topic_files = _read_topic_files()
    hot_threads = open_gaps_digest.get("hot_threads_by_open_gaps") or []
    referenced_threads = sorted(
        {
            thread_id
            for gap in open_gaps_digest.get("gaps") or []
            for thread_id in _coerce_list(gap.get("threads"))
        }
    )
    existing_topic_threads = {
        thread_id
        for topic in topic_files.values()
        for thread_id in _coerce_list(topic.get("threads"))
    }

    created_threads: list[dict[str, Any]] = []
    missing_thread_files: list[dict[str, Any]] = []
    for thread_id in referenced_threads:
        if thread_id in thread_files:
            continue
        missing_thread_files.append({"thread_id": thread_id, "title": _slug_title(thread_id)})
        path = _write_thread_stub(thread_id, open_gaps_digest)
        thread_files[thread_id] = {
            "id": thread_id,
            "title": _slug_title(thread_id),
            "status": "active",
            "updated": datetime.now(timezone.utc).date().isoformat(),
            "path": str(path),
        }
        created_threads.append({"thread_id": thread_id, "path": str(path)})

    created_topics: list[dict[str, Any]] = []
    missing_topic_candidates: list[dict[str, Any]] = []
    for item in hot_threads:
        thread_id = str(item.get("thread_id") or "").strip()
        if not thread_id:
            continue
        open_gaps = int(item.get("open_gaps", 0) or 0)
        thread_title = (thread_files.get(thread_id) or {}).get("title") or _slug_title(thread_id)
        if thread_id in existing_topic_threads:
            continue
        candidate = {
            "thread_id": thread_id,
            "title": thread_title,
            "open_gaps": open_gaps,
            "reason": "hot_thread_without_topic",
        }
        missing_topic_candidates.append(candidate)
        target_path = TOPICS_DIR / f"{_slugify(thread_id)}.md"
        if target_path.exists():
            candidate["reason"] = "topic_file_exists_without_thread_link"
            candidate["path"] = str(target_path)
            continue
        path = _write_topic_stub(thread_id, open_gaps_digest, str(thread_title))
        existing_topic_threads.add(thread_id)
        created_topics.append({"thread_id": thread_id, "path": str(path)})

    topic_files = _read_topic_files()
    thread_files = _read_thread_files()
    stale_topics = [
        {
            "topic_id": topic_id,
            "title": topic.get("title"),
            "reason": "topic_without_thread_link",
            "path": topic.get("path"),
        }
        for topic_id, topic in topic_files.items()
        if not _coerce_list(topic.get("threads"))
    ]

    return {
        "generated_at": _now_iso(),
        "threads": {
            "files_total": len(thread_files),
            "referenced_total": len(referenced_threads),
            "hot_total": len(hot_threads),
            "missing_files_total": len(missing_thread_files),
            "created_total": len(created_threads),
            "missing_files": missing_thread_files[:12],
            "created": created_threads,
            "hot": hot_threads[:12],
        },
        "topics": {
            "files_total": len(topic_files),
            "thread_links_total": len(existing_topic_threads),
            "missing_candidates_total": len(missing_topic_candidates),
            "created_total": len(created_topics),
            "stale_total": len(stale_topics),
            "missing_candidates": missing_topic_candidates[:12],
            "created": created_topics,
            "stale": stale_topics[:12],
        },
        "open_gaps": {
            "total": int(open_gaps_digest.get("open_total", 0) or 0),
            "entries_with_gaps": int(open_gaps_digest.get("entries_with_gaps", 0) or 0),
            "recent": (open_gaps_digest.get("recent_open_gaps") or [])[:8],
        },
    }


def _refresh_corpus_health() -> tuple[dict[str, Any], list[str]]:
    warnings: list[str] = []
    wrapper = EDGE_REPO_DIR / "tools" / "curadoria-compute"
    if not wrapper.exists():
        warnings.append("curadoria-compute wrapper missing")
        return _read_json(CURADORIA_CANDIDATES_FILE, {}), warnings
    code, stdout, stderr = _run([str(wrapper), "--mode", "lite"])
    if code != 0:
        detail = (stderr or stdout or f"exit={code}").splitlines()[-1]
        warnings.append(f"corpus_lite_failed:{detail}")
    return _read_json(CURADORIA_CANDIDATES_FILE, {}), warnings


def _refresh_topics_index() -> list[str]:
    warnings: list[str] = []
    if not TOPICS_DIR.exists():
        return warnings
    wrapper = EDGE_REPO_DIR / "search" / "edge-index"
    if not wrapper.exists():
        warnings.append("edge-index wrapper missing for topics refresh")
        return warnings
    code, stdout, stderr = _run([str(wrapper), str(TOPICS_DIR)])
    if code != 0:
        detail = (stderr or stdout or f"exit={code}").splitlines()[-1]
        warnings.append(f"topics_index_failed:{detail}")
    return warnings


def _topics_summary() -> dict[str, Any]:
    if not TOPICS_DIR.exists():
        return {"total": 0, "updated_at": None}
    paths = sorted(TOPICS_DIR.glob("*.md"))
    updated_at = None
    if paths:
        updated_at = max(datetime.fromtimestamp(path.stat().st_mtime, timezone.utc) for path in paths).isoformat()
    return {"total": len(paths), "updated_at": updated_at}


def build_curation_digest(window_days: int) -> dict[str, Any]:
    corpus_payload, corpus_warnings = _refresh_corpus_health()
    open_gaps_digest = _read_json(OPEN_GAPS_DIGEST_FILE, {})
    operator_pressure_digest = _read_json(OPERATOR_PRESSURE_HOT_DIGEST_FILE, {})
    hot_state = _curate_hot_state(open_gaps_digest)
    operator_pressure = _curate_operator_pressure(operator_pressure_digest)
    topic_index_warnings = _refresh_topics_index()
    topics = _topics_summary()

    warnings = corpus_warnings + topic_index_warnings
    status = "warning" if warnings else "ok"
    digest = {
        "generated_at": _now_iso(),
        "status": status,
        "warnings": warnings,
        "corpus": {
            "total_docs": int(corpus_payload.get("total_docs", 0) or 0),
            "stale_candidates": int(corpus_payload.get("stale_candidates", 0) or 0)
            if isinstance(corpus_payload.get("stale_candidates"), int)
                else len(corpus_payload.get("stale_candidates") or []),
            "archive_auto": len(corpus_payload.get("archive_auto") or []),
            "merge_review": len(corpus_payload.get("merge_review") or []),
            "strengthen_targets": len(corpus_payload.get("strengthen_targets") or []),
        },
        "topics": topics,
        "hot_state": hot_state,
        "operator_pressure": operator_pressure,
        "files": {
            "curadoria_candidates": str(CURADORIA_CANDIDATES_FILE),
            "curation_digest": str(CURATION_DIGEST_FILE),
            "open_gaps_digest": str(OPEN_GAPS_DIGEST_FILE),
            "operator_pressure_hot_digest": str(OPERATOR_PRESSURE_HOT_DIGEST_FILE),
        },
    }
    _write_json(CURATION_DIGEST_FILE, digest)
    emit_shadow_event(
        "CurationDigestComputed",
        actor="edge-curation",
        artifact=str(CURATION_DIGEST_FILE),
        cycle_id=None,
        payload={
            "status": status,
            "warning_count": len(warnings),
            "topics_total": digest["topics"]["total"],
            "topics_created": hot_state["topics"]["created_total"],
            "threads_created": hot_state["threads"]["created_total"],
            "operator_pressure_items": operator_pressure["items_total"],
            "operator_pressure_topics_created": operator_pressure["topics_created"],
            "operator_pressure_threads_created": operator_pressure["threads_created"],
            "operator_pressure_pre_skill_context": operator_pressure["pre_skill_context_total"],
            "stale_candidates": digest["corpus"]["stale_candidates"],
        },
    )
    log_event(
        "curation_digest",
        actor="edge-curation",
        status=status,
        warning_count=len(warnings),
        topics_total=digest["topics"]["total"],
        topics_created=hot_state["topics"]["created_total"],
        threads_created=hot_state["threads"]["created_total"],
        operator_pressure_items=operator_pressure["items_total"],
        operator_pressure_topics_created=operator_pressure["topics_created"],
        operator_pressure_threads_created=operator_pressure["threads_created"],
        operator_pressure_pre_skill_context=operator_pressure["pre_skill_context_total"],
        stale_candidates=digest["corpus"]["stale_candidates"],
    )
    return digest


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Deterministic corpus, topic, and pre-skill context curation maintenance")
    sub = parser.add_subparsers(dest="cmd", required=True)

    sync = sub.add_parser("sync", help="Refresh curation state and digest")
    sync.add_argument("--window-days", type=int, default=60)
    sync.add_argument("--json", action="store_true")

    show = sub.add_parser("show", help="Print the latest curation digest")
    show.add_argument("--json", action="store_true")
    return parser


def cmd_sync(args: argparse.Namespace) -> int:
    digest = build_curation_digest(args.window_days)
    if args.json:
        print(json.dumps(digest, indent=2, ensure_ascii=False))
    else:
        print(f"OK: {CURATION_DIGEST_FILE}")
    return 0


def cmd_show(args: argparse.Namespace) -> int:
    digest = _read_json(CURATION_DIGEST_FILE, {})
    if args.json:
        print(json.dumps(digest, indent=2, ensure_ascii=False))
    else:
        print(f"OK: {CURATION_DIGEST_FILE}")
    return 0


def main() -> int:
    args = build_parser().parse_args()
    if args.cmd == "sync":
        return cmd_sync(args)
    if args.cmd == "show":
        return cmd_show(args)
    return 1


if __name__ == "__main__":
    sys.exit(main())
