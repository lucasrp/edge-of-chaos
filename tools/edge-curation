def _compact_operator_text(text: str, limit: int = 220) -> str:
    compact = re.sub(r"\s+", " ", str(text or "").strip())
    if len(compact) <= limit:
        return compact
    return compact[: limit - 3].rstrip() + "..."


def _operator_keywords(text: str) -> list[str]:
    normalized = _normalize_ascii(text).lower()
    words = re.findall(r"[a-z0-9]+", normalized)
    out: list[str] = []
    seen: set[str] = set()
    for word in words:
        if len(word) < 3 or word in _OPERATOR_STOPWORDS or word in seen:
            continue
        seen.add(word)
        out.append(word)
    return out


def _coerce_operator_pressure_item(raw: Any, section: str, index: int) -> dict[str, Any] | None:
    if isinstance(raw, dict):
        text = ""
        for key in ("text", "summary", "content", "description", "message", "title", "item"):
            candidate = str(raw.get(key) or "").strip()
            if candidate:
                text = candidate
                break
        if not text:
            return None
        return {
            "item_id": str(raw.get("item_id") or raw.get("id") or "").strip(),
            "text": _compact_operator_text(text),
            "section": section,
            "target": str(raw.get("target") or "").strip(),
            "kind": str(raw.get("kind") or "").strip(),
            "repeat_count": int(raw.get("repeat_count") or 0),
            "status": str(raw.get("status") or "active").strip(),
            "entities": _coerce_list(raw.get("entities")),
            "source_kinds": _coerce_list(raw.get("source_kinds")),
            "scope": str(raw.get("scope") or "").strip(),
            "last_seen_at": str(raw.get("last_seen_at") or "").strip(),
        }
    text = _compact_operator_text(str(raw or ""))
    if not text:
        return None
    return {
        "item_id": "",
        "text": text,
        "section": section,
        "target": "",
        "kind": "",
        "repeat_count": 0,
        "status": "active",
        "entities": [],
        "source_kinds": [],
        "scope": "",
        "last_seen_at": "",
        "synthetic_id": f"{section}:{index}",
    }


def _operator_pressure_items(operator_digest: dict[str, Any]) -> list[dict[str, Any]]:
    merged: dict[str, dict[str, Any]] = {}
    for section in _OPERATOR_PRESSURE_SECTIONS:
        rows = operator_digest.get(section) or []
        if not isinstance(rows, list):
            continue
        for index, raw in enumerate(rows):
            item = _coerce_operator_pressure_item(raw, section, index)
            if not item:
                continue
            key = str(item.get("item_id") or item.get("synthetic_id") or _slugify(item.get("text", ""))).strip()
            existing = merged.setdefault(
                key,
                {
                    "item_id": str(item.get("item_id") or ""),
                    "text": item["text"],
                    "sections": [],
                    "target": item.get("target") or "",
                    "kind": item.get("kind") or "",
                    "repeat_count": 0,
                    "status": item.get("status") or "active",
                    "entities": [],
                    "source_kinds": [],
                    "scope": item.get("scope") or "",
                    "last_seen_at": item.get("last_seen_at") or "",
                    "score": 0,
                },
            )
            if section not in existing["sections"]:
                existing["sections"].append(section)
            existing["score"] += _OPERATOR_SECTION_WEIGHT.get(section, 1)
            existing["repeat_count"] = max(int(existing.get("repeat_count") or 0), int(item.get("repeat_count") or 0))
            existing["score"] += int(item.get("repeat_count") or 0)
            if item.get("last_seen_at") and str(item.get("last_seen_at")) > str(existing.get("last_seen_at") or ""):
                existing["last_seen_at"] = item.get("last_seen_at")
            entities = list(existing.get("entities") or [])
            for entity in _coerce_list(item.get("entities")):
                if entity not in entities:
                    entities.append(entity)
            existing["entities"] = entities[:8]
            source_kinds = list(existing.get("source_kinds") or [])
            for source_kind in _coerce_list(item.get("source_kinds")):
                if source_kind not in source_kinds:
                    source_kinds.append(source_kind)
            existing["source_kinds"] = source_kinds[:6]
            for key_name in ("target", "kind", "status"):
                if item.get(key_name) and not existing.get(key_name):
                    existing[key_name] = item.get(key_name)
            if item.get("scope") and not existing.get("scope"):
                existing["scope"] = item.get("scope")
    return sorted(
        merged.values(),
        key=lambda item: (-int(item.get("score") or 0), str(item.get("last_seen_at") or ""), str(item.get("text") or "")),
    )


def _operator_concept_for_item(item: dict[str, Any]) -> tuple[str, str]:
    text = str(item.get("text") or "")
    entities = _coerce_list(item.get("entities"))
    haystack = _normalize_ascii(" ".join([text, str(item.get("target") or ""), str(item.get("kind") or ""), *entities])).lower()
    for pattern, slug, title in _OPERATOR_CONCEPT_RULES:
        if pattern.search(haystack):
            return slug, title

    tokens: list[str] = []
    target = _slugify(str(item.get("target") or ""))
    if target in {"workflow", "procedure", "policy", "capability", "thread", "research", "skill"}:
        tokens.append(target)
    for entity in entities:
        slug = _slugify(entity)
        if slug and slug not in _OPERATOR_STOPWORDS:
            tokens.append(slug)
    tokens.extend(_operator_keywords(text))

    unique: list[str] = []
    seen: set[str] = set()
    for token in tokens:
        token = _slugify(token)
        if not token or token in seen or token in _OPERATOR_STOPWORDS:
            continue
        seen.add(token)
        unique.append(token)
        if len(unique) >= 4:
            break
    slug = _slugify("-".join(unique) if unique else text)
    return slug, _slug_title(slug)


def _is_operator_pre_skill_context_item(item: dict[str, Any]) -> bool:
    sections = set(_coerce_list(item.get("sections")))
    if "pre_skill_context" in sections:
        return True
    text = str(item.get("text") or "")
    target = str(item.get("target") or "").strip().lower()
    scope = str(item.get("scope") or "").strip().lower()
    entities = " ".join(_coerce_list(item.get("entities")))
    haystack = " ".join([text, target, scope, entities])
    normalized_text = _normalize_ascii(text)
    if not _PRE_SKILL_CONTEXT_RE.search(haystack):
        return False
    if target in {"workflow", "procedure"} or _PROCEDURAL_WORKFLOW_RE.search(normalized_text):
        return bool(re.search(r"\bpre[- ]?skill|contexto pre[- ]?skill|context_notes|operating context\b", haystack, re.I))
    return True


def _operator_pressure_groups(operator_digest: dict[str, Any]) -> tuple[list[dict[str, Any]], int]:
    items = _operator_pressure_items(operator_digest)
    groups: dict[str, dict[str, Any]] = {}
    for item in items:
        if _is_operator_pre_skill_context_item(item):
            continue
        slug, title = _operator_concept_for_item(item)
        group = groups.setdefault(
            slug,
            {
                "thread_id": slug,
                "title": title,
                "score": 0,
                "sections": Counter(),
                "item_ids": set(),
                "entities": set(),
                "source_kinds": set(),
                "evidence": [],
            },
        )
        group["score"] += int(item.get("score") or 0)
        for section in item.get("sections") or []:
            group["sections"][section] += 1
        if item.get("item_id"):
            group["item_ids"].add(str(item.get("item_id")))
        for entity in _coerce_list(item.get("entities")):
            group["entities"].add(entity)
        for source_kind in _coerce_list(item.get("source_kinds")):
            group.setdefault("source_kinds", set()).add(source_kind)
        evidence_key = str(item.get("item_id") or item.get("text") or "").casefold()
        if evidence_key and evidence_key not in {str(existing.get("key") or "") for existing in group["evidence"]}:
            group["evidence"].append(
                {
                    "key": evidence_key,
                    "text": item.get("text"),
                    "sections": item.get("sections") or [],
                    "target": item.get("target") or "",
                    "kind": item.get("kind") or "",
                    "repeat_count": int(item.get("repeat_count") or 0),
                    "source_kinds": _coerce_list(item.get("source_kinds")),
                    "last_seen_at": item.get("last_seen_at") or "",
                }
            )

    normalized: list[dict[str, Any]] = []
    for group in groups.values():
        sections = group["sections"]
        normalized.append(
            {
                "thread_id": group["thread_id"],
                "title": group["title"],
                "score": int(group["score"]),
                "sections": dict(sorted(sections.items())),
                "item_ids": sorted(group["item_ids"]),
                "entities": sorted(group["entities"]),
                "source_kinds": sorted(group.get("source_kinds", set())),
                "evidence": [
                    {key: value for key, value in evidence.items() if key != "key"}
                    for evidence in group["evidence"][:6]
                ],
            }
        )
    normalized.sort(key=lambda item: (-int(item.get("score") or 0), str(item.get("thread_id") or "")))
    return normalized[:_OPERATOR_GROUP_LIMIT], len(items)


def _operator_evidence_lines(group: dict[str, Any]) -> list[str]:
    lines: list[str] = []
    for evidence in group.get("evidence") or []:
        sections = ", ".join(_coerce_list(evidence.get("sections"))[:3]) or "operator_pressure"
        text = _compact_operator_text(str(evidence.get("text") or ""))
        suffix_parts = []
        if evidence.get("target"):
            suffix_parts.append(f"target={evidence.get('target')}")
        if evidence.get("kind"):
            suffix_parts.append(f"kind={evidence.get('kind')}")
        source_kinds = _coerce_list(evidence.get("source_kinds"))
        if source_kinds:
            suffix_parts.append(f"source={'+'.join(source_kinds[:2])}")
        suffix = f" ({', '.join(suffix_parts)})" if suffix_parts else ""
        lines.append(f"- [{sections}] {text}{suffix}")
    return lines or ["- No operator evidence details available yet."]


