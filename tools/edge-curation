def _now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def _read_json(path: Path, default: Any) -> Any:
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return default


def _write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def _run(cmd: list[str]) -> tuple[int, str, str]:
    result = subprocess.run(cmd, cwd=str(EDGE_REPO_DIR), capture_output=True, text=True)
    return result.returncode, (result.stdout or "").strip(), (result.stderr or "").strip()


def _load_frontmatter(path: Path) -> dict[str, Any]:
    raw = path.read_text(encoding="utf-8")
    parts = raw.split("---", 2)
    if len(parts) < 3:
        return {}
    payload = yaml.safe_load(parts[1]) or {}
    return payload if isinstance(payload, dict) else {}


def _coerce_list(value: Any) -> list[str]:
    if value is None:
        return []
    if isinstance(value, list):
        items = value
    else:
        items = [value]
    return [str(item).strip() for item in items if str(item).strip()]


def _slug_title(slug: str) -> str:
    return re.sub(r"[-_]+", " ", str(slug or "").strip()).strip().title()


def _normalize_ascii(value: str) -> str:
    return unicodedata.normalize("NFKD", str(value or "")).encode("ascii", "ignore").decode("ascii")


def _slugify(value: str) -> str:
    normalized = _normalize_ascii(value)
    slug = re.sub(r"[^a-z0-9]+", "-", normalized.strip().lower())
    return slug.strip("-") or "topic"


def _first_heading(raw: str) -> str:
    for line in raw.splitlines():
        if line.startswith("# "):
            return line.lstrip("# ").strip()
    return ""


def _gap_refs_for_thread(open_gaps_digest: dict[str, Any], thread_id: str) -> list[dict[str, Any]]:
    gaps = open_gaps_digest.get("gaps") or []
    refs: list[dict[str, Any]] = []
    for item in gaps:
        if thread_id not in _coerce_list(item.get("threads")):
            continue
        refs.append(
            {
                "gap_id": item.get("gap_id"),
                "text": item.get("text"),
                "artifact": item.get("artifact_filename"),
                "date": item.get("date"),
            }
        )
    refs.sort(key=lambda item: item.get("date") or "")
    return refs[:8]


def _read_thread_files() -> dict[str, dict[str, Any]]:
    threads: dict[str, dict[str, Any]] = {}
    if not THREADS_DIR.exists():
        return threads
    for path in sorted(THREADS_DIR.glob("*.md")):
        try:
            raw = path.read_text(encoding="utf-8", errors="replace")
            fm = _load_frontmatter(path)
        except Exception:
            continue
        thread_id = str(fm.get("id") or path.stem).strip()
        if not thread_id:
            continue
        threads[thread_id] = {
            "id": thread_id,
            "title": str(fm.get("title") or _first_heading(raw) or _slug_title(thread_id)),
            "status": str(fm.get("status") or "unknown"),
            "updated": str(fm.get("updated") or ""),
            "path": str(path),
        }
    return threads


def _read_topic_files() -> dict[str, dict[str, Any]]:
    topics: dict[str, dict[str, Any]] = {}
    if not TOPICS_DIR.exists():
        return topics
    for path in sorted(TOPICS_DIR.glob("*.md")):
        try:
            raw = path.read_text(encoding="utf-8", errors="replace")
            fm = _load_frontmatter(path)
        except Exception:
            continue
        topic_id = path.stem
        linked_threads = set(_coerce_list(fm.get("threads")))
        for match in re.findall(r"`([a-z0-9][a-z0-9_-]+)`", raw, flags=re.I):
            linked_threads.add(match)
        topics[topic_id] = {
            "id": topic_id,
            "title": str(fm.get("title") or _first_heading(raw) or _slug_title(topic_id)),
            "status": str(fm.get("status") or "unknown"),
            "threads": sorted(linked_threads),
            "path": str(path),
            "generated": bool(fm.get("generated_by") == "edge-curation"),
        }
    return topics


