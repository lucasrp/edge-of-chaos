#!/usr/bin/env python3
"""edge-curation — deterministic corpus/workflow curation sync and digest."""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from collections import Counter, defaultdict
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Any

import yaml

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR.parent / "config"))
from paths import (  # noqa: E402
    CURADORIA_CANDIDATES_FILE,
    CURATION_DIGEST_FILE,
    EDGE_REPO_DIR,
    ENTRIES_DIR,
    PROCEDURE_CURATION_FILE,
    STATE_DIR,
    TOPICS_DIR,
    WORKFLOW_HEALTH_FILE,
)
sys.path.insert(0, str(SCRIPT_DIR))
from _shared.telemetry import emit_shadow_event, log_event  # noqa: E402


def _now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def _read_json(path: Path, default: Any) -> Any:
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return default


def _write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def _run(cmd: list[str]) -> tuple[int, str, str]:
    result = subprocess.run(cmd, cwd=str(EDGE_REPO_DIR), capture_output=True, text=True)
    return result.returncode, (result.stdout or "").strip(), (result.stderr or "").strip()


def _load_frontmatter(path: Path) -> dict[str, Any]:
    raw = path.read_text(encoding="utf-8")
    parts = raw.split("---", 2)
    if len(parts) < 3:
        return {}
    payload = yaml.safe_load(parts[1]) or {}
    return payload if isinstance(payload, dict) else {}


def _coerce_list(value: Any) -> list[str]:
    if value is None:
        return []
    if isinstance(value, list):
        items = value
    else:
        items = [value]
    return [str(item).strip() for item in items if str(item).strip()]


def _entry_date(frontmatter: dict[str, Any], path: Path) -> datetime:
    raw = str(frontmatter.get("date") or "").strip()
    if raw:
        try:
            if len(raw) == 10:
                return datetime.fromisoformat(raw).replace(tzinfo=timezone.utc)
            parsed = datetime.fromisoformat(raw.replace("Z", "+00:00"))
            return parsed if parsed.tzinfo else parsed.replace(tzinfo=timezone.utc)
        except Exception:
            pass
    return datetime.fromtimestamp(path.stat().st_mtime, timezone.utc)


def _normalize_procedure(text: str) -> str:
    normalized = re.sub(r"\s+", " ", text.strip().lower())
    normalized = re.sub(r"[“”\"'`]+", "", normalized)
    return normalized


def _workflow_title_from_procedure(text: str) -> str:
    plain = text.lstrip("!").strip()
    plain = re.sub(r"\s+", " ", plain)
    if len(plain) > 96:
        plain = plain[:93].rstrip() + "..."
    if not plain.lower().startswith("workflow:"):
        plain = f"workflow: {plain}"
    return plain


def _iter_recent_entries(window_days: int) -> list[tuple[Path, dict[str, Any], datetime]]:
    cutoff = datetime.now(timezone.utc) - timedelta(days=window_days)
    rows: list[tuple[Path, dict[str, Any], datetime]] = []
    if not ENTRIES_DIR.exists():
        return rows
    for path in sorted(ENTRIES_DIR.glob("*.md")):
        try:
            frontmatter = _load_frontmatter(path)
        except Exception:
            continue
        dt = _entry_date(frontmatter, path)
        if dt >= cutoff:
            rows.append((path, frontmatter, dt))
    return rows


def _build_procedure_curation(window_days: int) -> dict[str, Any]:
    rows = _iter_recent_entries(window_days)
    groups: dict[str, dict[str, Any]] = {}
    broken_counts: dict[str, dict[str, Any]] = {}
    workflow_used_counts: Counter[str] = Counter()
    recent_workflow_entries: dict[str, datetime] = {}
    total_procedures = 0
    total_workflows_used = 0
    total_workflows_broken = 0

    for path, frontmatter, dt in rows:
        entry_name = path.name
        for item in _coerce_list(frontmatter.get("procedure")):
            total_procedures += 1
            key = _normalize_procedure(item)
            group = groups.setdefault(
                key,
                {
                    "representative": item,
                    "claims": [],
                    "source_entries": [],
                    "anti_pattern": item.startswith("!"),
                },
            )
            group["claims"].append(item)
            if entry_name not in group["source_entries"]:
                group["source_entries"].append(entry_name)

        for slug in _coerce_list(frontmatter.get("workflows_used")):
            total_workflows_used += 1
            workflow_used_counts[slug] += 1

        for slug in _coerce_list(frontmatter.get("workflows_broken")):
            total_workflows_broken += 1
            record = broken_counts.setdefault(slug, {"slug": slug, "broken_count": 0, "citing_entries": []})
            record["broken_count"] += 1
            if entry_name not in record["citing_entries"]:
                record["citing_entries"].append(entry_name)

    if ENTRIES_DIR.exists():
        for path in sorted(ENTRIES_DIR.glob("*.md")):
            try:
                frontmatter = _load_frontmatter(path)
            except Exception:
                continue
            tags = {str(tag).strip() for tag in _coerce_list(frontmatter.get("tags"))}
            if not ({"workflow", "workflow-draft"} & tags):
                continue
            slug = path.stem.split("-", 3)[-1]
            recent_workflow_entries[slug] = _entry_date(frontmatter, path)

    candidates: list[dict[str, Any]] = []
    for cluster_id, (key, group) in enumerate(
        sorted(groups.items(), key=lambda item: (-len(item[1]["claims"]), item[1]["representative"].lower())),
        start=1,
    ):
        claim_count = len(group["claims"])
        if claim_count < 3:
            continue
        representative = str(group["representative"] or "")
        candidates.append(
            {
                "cluster_id": cluster_id,
                "theme": representative,
                "claims": list(group["claims"]),
                "claim_count": claim_count,
                "source_entries": list(group["source_entries"]),
                "median_sim_estimate": 1.0,
                "anti_pattern": bool(group.get("anti_pattern")),
                "suggested_workflow_title": _workflow_title_from_procedure(representative),
            }
        )

    never_cited: list[dict[str, Any]] = []
    cutoff = datetime.now(timezone.utc) - timedelta(days=window_days)
    for slug, dt in sorted(recent_workflow_entries.items()):
        if workflow_used_counts.get(slug, 0) == 0 and dt < cutoff:
            never_cited.append({"slug": slug, "age_days": int((datetime.now(timezone.utc) - dt).days)})

    payload = {
        "generated_at": _now_iso(),
        "window_days": window_days,
        "total_entries": len(rows),
        "total_procedures": total_procedures,
        "total_workflows_used": total_workflows_used,
        "total_workflows_broken": total_workflows_broken,
        "crystallization_candidates": candidates,
        "broken_workflows": sorted(broken_counts.values(), key=lambda item: (-int(item["broken_count"]), item["slug"])),
        "never_cited_workflows": never_cited,
    }
    _write_json(PROCEDURE_CURATION_FILE, payload)
    return payload


def _refresh_corpus_health() -> tuple[dict[str, Any], list[str]]:
    warnings: list[str] = []
    wrapper = EDGE_REPO_DIR / "tools" / "curadoria-compute"
    if not wrapper.exists():
        warnings.append("curadoria-compute wrapper missing")
        return _read_json(CURADORIA_CANDIDATES_FILE, {}), warnings
    code, stdout, stderr = _run([str(wrapper), "--mode", "lite"])
    if code != 0:
        detail = (stderr or stdout or f"exit={code}").splitlines()[-1]
        warnings.append(f"corpus_lite_failed:{detail}")
    return _read_json(CURADORIA_CANDIDATES_FILE, {}), warnings


def _refresh_workflow_funnel() -> tuple[dict[str, Any], list[str]]:
    warnings: list[str] = []
    tool = EDGE_REPO_DIR / "tools" / "rollup-workflow-funnel.py"
    out_path = STATE_DIR / "workflow-funnel.json"
    code, stdout, stderr = _run([sys.executable, str(tool)])
    if code != 0:
        detail = (stderr or stdout or f"exit={code}").splitlines()[-1]
        warnings.append(f"workflow_funnel_failed:{detail}")
    payload = _read_json(out_path, {})
    return payload, warnings


def _refresh_topics_index() -> list[str]:
    warnings: list[str] = []
    if not TOPICS_DIR.exists():
        return warnings
    wrapper = EDGE_REPO_DIR / "search" / "edge-index"
    if not wrapper.exists():
        warnings.append("edge-index wrapper missing for topics refresh")
        return warnings
    code, stdout, stderr = _run([str(wrapper), str(TOPICS_DIR)])
    if code != 0:
        detail = (stderr or stdout or f"exit={code}").splitlines()[-1]
        warnings.append(f"topics_index_failed:{detail}")
    return warnings


def _topics_summary() -> dict[str, Any]:
    if not TOPICS_DIR.exists():
        return {"total": 0, "updated_at": None}
    paths = sorted(TOPICS_DIR.glob("*.md"))
    updated_at = None
    if paths:
        updated_at = max(datetime.fromtimestamp(path.stat().st_mtime, timezone.utc) for path in paths).isoformat()
    return {"total": len(paths), "updated_at": updated_at}


def build_curation_digest(window_days: int) -> dict[str, Any]:
    corpus_payload, corpus_warnings = _refresh_corpus_health()
    procedure_payload = _build_procedure_curation(window_days)
    funnel_payload, funnel_warnings = _refresh_workflow_funnel()
    topic_index_warnings = _refresh_topics_index()
    workflow_health = _read_json(WORKFLOW_HEALTH_FILE, {})
    topics = _topics_summary()

    warnings = corpus_warnings + funnel_warnings + topic_index_warnings
    status = "warning" if warnings else "ok"
    digest = {
        "generated_at": _now_iso(),
        "status": status,
        "warnings": warnings,
        "corpus": {
            "total_docs": int(corpus_payload.get("total_docs", 0) or 0),
            "stale_candidates": int(corpus_payload.get("stale_candidates", 0) or 0)
            if isinstance(corpus_payload.get("stale_candidates"), int)
            else len(corpus_payload.get("stale_candidates") or []),
            "archive_auto": len(corpus_payload.get("archive_auto") or []),
            "merge_review": len(corpus_payload.get("merge_review") or []),
            "strengthen_targets": len(corpus_payload.get("strengthen_targets") or []),
        },
        "procedures": {
            "total_entries": int(procedure_payload.get("total_entries", 0) or 0),
            "total_procedures": int(procedure_payload.get("total_procedures", 0) or 0),
            "candidate_total": len(procedure_payload.get("crystallization_candidates") or []),
            "broken_workflow_total": len(procedure_payload.get("broken_workflows") or []),
            "never_cited_total": len(procedure_payload.get("never_cited_workflows") or []),
        },
        "topics": topics,
        "workflow_health": {
            "citation_total": len((workflow_health.get("citations") or {})),
            "funnel_tracked_total": int(funnel_payload.get("tracked_workflows", 0) or 0),
            "funnel_states": dict(funnel_payload.get("current_state") or {}),
        },
        "files": {
            "curadoria_candidates": str(CURADORIA_CANDIDATES_FILE),
            "procedure_curation": str(PROCEDURE_CURATION_FILE),
            "workflow_health": str(WORKFLOW_HEALTH_FILE),
            "curation_digest": str(CURATION_DIGEST_FILE),
        },
    }
    _write_json(CURATION_DIGEST_FILE, digest)
    emit_shadow_event(
        "CurationDigestComputed",
        actor="edge-curation",
        artifact=str(CURATION_DIGEST_FILE),
        cycle_id=None,
        payload={
            "status": status,
            "warning_count": len(warnings),
            "candidate_total": digest["procedures"]["candidate_total"],
            "topics_total": digest["topics"]["total"],
            "stale_candidates": digest["corpus"]["stale_candidates"],
        },
    )
    log_event(
        "curation_digest",
        actor="edge-curation",
        status=status,
        warning_count=len(warnings),
        candidate_total=digest["procedures"]["candidate_total"],
        topics_total=digest["topics"]["total"],
        stale_candidates=digest["corpus"]["stale_candidates"],
    )
    return digest


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Deterministic corpus/workflow curation maintenance")
    sub = parser.add_subparsers(dest="cmd", required=True)

    sync = sub.add_parser("sync", help="Refresh curation state and digest")
    sync.add_argument("--window-days", type=int, default=60)
    sync.add_argument("--json", action="store_true")

    show = sub.add_parser("show", help="Print the latest curation digest")
    show.add_argument("--json", action="store_true")
    return parser


def cmd_sync(args: argparse.Namespace) -> int:
    digest = build_curation_digest(args.window_days)
    if args.json:
        print(json.dumps(digest, indent=2, ensure_ascii=False))
    else:
        print(f"OK: {CURATION_DIGEST_FILE}")
    return 0


def cmd_show(args: argparse.Namespace) -> int:
    digest = _read_json(CURATION_DIGEST_FILE, {})
    if args.json:
        print(json.dumps(digest, indent=2, ensure_ascii=False))
    else:
        print(f"OK: {CURATION_DIGEST_FILE}")
    return 0


def main() -> int:
    args = build_parser().parse_args()
    if args.cmd == "sync":
        return cmd_sync(args)
    if args.cmd == "show":
        return cmd_show(args)
    return 1


if __name__ == "__main__":
    sys.exit(main())
