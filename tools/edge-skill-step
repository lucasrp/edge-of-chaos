#!/usr/bin/env python3
"""Track skill step execution. Detects silently skipped steps.

Usage:
    edge-skill-step <skill> <step_id>          # Log step as done
    edge-skill-step <skill> skip <step_id> [reason]  # Log explicit skip
    edge-skill-step <skill> end                # Compute summary (missing steps)
    edge-skill-step report [--last N]          # Summary for /ed-reflexao
"""

import datetime
import json
import sys
from collections import Counter, defaultdict
from pathlib import Path

try:
    import yaml
except ImportError:
    sys.exit("PyYAML required: pip install pyyaml")

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR.parent / "config"))
from paths import LOGS_DIR
sys.path.insert(0, str(SCRIPT_DIR))
from _shared.telemetry import current_cycle_id, emit_shadow_event

LOG = LOGS_DIR / "skill-steps.jsonl"
REGISTRY = Path(__file__).resolve().parent / "skill-steps-registry.yaml"
SKILL_ALIASES = {
    "research": "ed-pesquisa",
    "pesquisa": "ed-pesquisa",
    "discovery": "ed-descoberta",
    "descoberta": "ed-descoberta",
    "heartbeat": "ed-heartbeat",
    "strategy": "ed-estrategia",
    "estrategia": "ed-estrategia",
    "autonomy": "ed-autonomia",
    "autonomia": "ed-autonomia",
    "report": "ed-relatorio",
    "relatorio": "ed-relatorio",
    "experiment": "ed-experimento",
    "experimento": "ed-experimento",
    "planner": "ed-planejar",
    "planejar": "ed-planejar",
    "plan": "ed-planejar",
    "reflection-hn": "ed-reflexao-HN",
    "reflexao-hn": "ed-reflexao-HN",
    "reflection-m": "ed-reflexao-M",
    "reflexao-m": "ed-reflexao-M",
}


def _load_registry():
    if REGISTRY.exists():
        with open(REGISTRY) as f:
            return yaml.safe_load(f) or {}
    return {}


def _log(data):
    LOG.parent.mkdir(parents=True, exist_ok=True)
    data["ts"] = datetime.datetime.now().isoformat(timespec="seconds")
    with open(LOG, "a") as f:
        f.write(json.dumps(data, ensure_ascii=False) + "\n")


def _read_log():
    if not LOG.exists():
        return []
    return [json.loads(line) for line in LOG.read_text().strip().split("\n") if line.strip()]


def _candidate_skill_names(skill):
    raw = (skill or "").strip()
    normalized = raw.lstrip("/")
    candidates = [raw, normalized, normalized.lower()]
    if "-" in normalized:
        _, suffix = normalized.split("-", 1)
        candidates.extend([suffix, suffix.lower()])
    seen = set()
    ordered = []
    for candidate in candidates:
        if candidate and candidate not in seen:
            seen.add(candidate)
            ordered.append(candidate)
    return ordered


def _resolve_registry_skill(skill):
    reg = _load_registry()
    raw = (skill or "").strip()
    for candidate in _candidate_skill_names(raw):
        if candidate in reg:
            return raw, candidate
        alias = SKILL_ALIASES.get(candidate.lower())
        if alias and alias in reg:
            return raw, alias
    return raw, None


def _registry_steps(skill):
    """Get expected step IDs for a skill from registry."""
    reg = _load_registry()
    raw_skill, registry_skill = _resolve_registry_skill(skill)
    if not registry_skill:
        return [], {}, raw_skill, None
    entries = reg.get(registry_skill, [])
    return [s.split(":")[0] for s in entries], {s.split(":")[0]: s for s in entries}, raw_skill, registry_skill


def _entry_for_skill(skill, *, event, **extra):
    raw_skill, registry_skill = _resolve_registry_skill(skill)
    entry = {"skill": raw_skill, "event": event, **extra}
    if registry_skill:
        entry["registry_skill"] = registry_skill
    return entry


def cmd_step(skill, step_id):
    """Log a step as executed."""
    entry = _entry_for_skill(skill, event="step", step=step_id, status="done")
    _log(entry)
    emit_shadow_event(
        "SkillStepObserved",
        actor="edge-skill-step",
        cycle_id=current_cycle_id(),
        payload={
            "skill": entry["skill"],
            "registry_skill": entry.get("registry_skill", ""),
            "step": step_id,
            "status": "done",
        },
    )


def cmd_skip(skill, step_id, reason=None):
    """Log a step as explicitly skipped."""
    entry = _entry_for_skill(skill, event="step", step=step_id, status="skipped")
    if reason:
        entry["reason"] = reason
    _log(entry)
    payload = {
        "skill": entry["skill"],
        "registry_skill": entry.get("registry_skill", ""),
        "step": step_id,
        "status": "skipped",
    }
    if reason:
        payload["reason"] = reason
    emit_shadow_event(
        "SkillStepObserved",
        actor="edge-skill-step",
        cycle_id=current_cycle_id(),
        payload=payload,
    )


def cmd_end(skill):
    """End a skill run. Compare logged steps against registry."""
    expected_ids, step_names, raw_skill, registry_skill = _registry_steps(skill)

    if not expected_ids:
        entry = _entry_for_skill(skill, event="end", warning=f"skill '{raw_skill}' not in registry")
        _log(entry)
        print(f"⚠ Skill '{raw_skill}' não está no registry. Nada para comparar.")
        return

    # Read log backwards to find steps for this skill since last 'end' event
    all_entries = _read_log()
    recorded_done = set()
    recorded_skip = {}

    for entry in reversed(all_entries):
        entry_skill = entry.get("registry_skill") or entry.get("skill")
        if entry_skill != registry_skill:
            continue
        if entry.get("event") == "end":
            break  # stop at previous end
        if entry.get("event") == "step":
            sid = entry.get("step", "")
            if entry.get("status") == "done":
                recorded_done.add(sid)
            elif entry.get("status") == "skipped":
                recorded_skip[sid] = entry.get("reason", "")

    all_accounted = recorded_done | set(recorded_skip.keys())
    silent_skips = [s for s in expected_ids if s not in all_accounted]

    summary = {
        "skill": raw_skill,
        "registry_skill": registry_skill,
        "event": "end",
        "expected": len(expected_ids),
        "done": len(recorded_done),
        "explicit_skips": len(recorded_skip),
        "silent_skips": silent_skips,
        "completion_pct": round(len(recorded_done) / len(expected_ids) * 100) if expected_ids else 0,
    }
    if recorded_skip:
        summary["skip_details"] = recorded_skip
    _log(summary)
    emit_shadow_event(
        "SkillRunCompleted",
        actor="edge-skill-step",
        cycle_id=current_cycle_id(),
        payload=summary,
    )

    # Print summary
    if silent_skips:
        named = [step_names.get(s, s) for s in silent_skips]
        print(f"⚠ {raw_skill}: {len(silent_skips)} passos silenciosamente pulados:")
        for s in named:
            print(f"  - {s}")
    if recorded_skip:
        print(f"  ({len(recorded_skip)} skip(s) explícito(s))")
    display_skill = raw_skill if raw_skill == registry_skill else f"{raw_skill} -> {registry_skill}"
    print(f"✓ {display_skill}: {summary['done']}/{summary['expected']} passos "
          f"({summary['completion_pct']}%)")


def cmd_report(last_n=20):
    """Summary report for /ed-reflexao."""
    entries = _read_log()
    ends = [e for e in entries if e.get("event") == "end" and "expected" in e]

    if not ends:
        print("Sem dados de execução de skills.")
        return

    recent = ends[-last_n:]

    # Aggregate by skill
    by_skill = defaultdict(list)
    for e in recent:
        by_skill[e.get("registry_skill") or e["skill"]].append(e)

    print(f"=== Skill Step Completion ({len(recent)} execuções recentes) ===\n")

    # Global stats
    total_silent = sum(len(e.get("silent_skips", [])) for e in recent)
    total_explicit = sum(e.get("explicit_skips", 0) for e in recent)
    avg_completion = sum(e.get("completion_pct", 0) for e in recent) / len(recent) if recent else 0

    print(f"Média de completude: {avg_completion:.0f}%")
    print(f"Total silent skips: {total_silent}")
    print(f"Total explicit skips: {total_explicit}")
    print()

    # Per-skill breakdown
    all_silent_steps = Counter()
    for e in recent:
        for s in e.get("silent_skips", []):
            all_silent_steps[f"{e.get('registry_skill') or e['skill']}:{s}"] += 1

    if all_silent_steps:
        print("Passos mais silenciosamente pulados:")
        for step, count in all_silent_steps.most_common(10):
            skill_name, step_id = step.split(":", 1)
            _, names, _, _ = _registry_steps(skill_name)
            label = names.get(step_id, step_id)
            print(f"  {step}: {count}x — {label}")
        print()

    # Per-skill summary
    for skill, runs in sorted(by_skill.items()):
        avg_pct = sum(r.get("completion_pct", 0) for r in runs) / len(runs)
        silent = sum(len(r.get("silent_skips", [])) for r in runs)
        print(f"{skill} ({len(runs)} runs, avg {avg_pct:.0f}%, {silent} silent skips)")


def main():
    args = sys.argv[1:]
    if not args:
        print(__doc__)
        sys.exit(1)

    if args[0] == "report":
        last_n = 20
        if "--last" in args:
            idx = args.index("--last")
            last_n = int(args[idx + 1])
        cmd_report(last_n)
        return

    skill = args[0]

    if len(args) == 1:
        print(__doc__)
        sys.exit(1)

    if args[1] == "end":
        cmd_end(skill)
    elif args[1] == "skip":
        if len(args) < 3:
            print("Usage: edge-skill-step <skill> skip <step_id> [reason]")
            sys.exit(1)
        reason = " ".join(args[3:]) if len(args) > 3 else None
        cmd_skip(skill, args[2], reason)
    else:
        # edge-skill-step <skill> <step_id>
        cmd_step(skill, args[1])


if __name__ == "__main__":
    main()
