#!/usr/bin/env python3
"""edge-runner — backend-neutral CLI boundary for skill and prompt execution.

Usage:
  edge-runner skill --skill /ed-heartbeat
  edge-runner skill --skill /ed-heartbeat --dispatch-trigger heartbeat
  edge-runner prompt --prompt "Diagnose the current health state"
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
import signal
import subprocess
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR.parent / "config"))
from paths import EDGE_INSTANCE, EDGE_REPO_DIR, SKILL_STEPS_FILE, STATE_EVENTS_FILE  # noqa: E402
sys.path.insert(0, str(SCRIPT_DIR))
from _shared.dispatch_runtime import read_dispatch_state, render_skill_runtime_prompt, write_dispatch_state  # noqa: E402
from _shared.telemetry import emit_shadow_event  # noqa: E402
from _shared.telemetry import log_run_step  # noqa: E402


class RunnerAbort(Exception):
    def __init__(self, reason: str, message: str | None = None) -> None:
        super().__init__(message or reason)
        self.reason = reason


def now_stamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def make_cycle_id() -> str:
    return f"cycle-runner-{now_stamp()}-{uuid.uuid4().hex[:6]}"


def resolve_cwd(value: str | None) -> str:
    if value:
        return str(Path(value).expanduser().resolve())
    return str(EDGE_REPO_DIR)


def resolve_claude_bin() -> str:
    env_override = os.environ.get("EDGE_CLAUDE_BIN") or os.environ.get("CLAUDE_BIN")
    candidates = []
    if env_override:
        candidates.append(env_override)

    path_hit = shutil.which("claude")
    if path_hit:
        candidates.append(path_hit)

    home = Path.home()
    candidates.extend(
        [
            str(home / ".local" / "bin" / "claude"),
            str(home / "bin" / "claude"),
        ]
    )
    for glob_hit in sorted((home / ".nvm" / "versions" / "node").glob("*/bin/claude"), reverse=True):
        candidates.append(str(glob_hit))

    seen: set[str] = set()
    for candidate in candidates:
        if not candidate or candidate in seen:
            continue
        seen.add(candidate)
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    raise FileNotFoundError("claude CLI not found on PATH or common install locations")


def build_backend_command(args: argparse.Namespace) -> list[str]:
    if args.backend != "claude":
        raise ValueError(f"unsupported backend: {args.backend}")

    cmd = [resolve_claude_bin(), "-p", "-"]
    if args.max_turns is not None:
        cmd.extend(["--max-turns", str(args.max_turns)])
    if args.allowed_tools:
        cmd.extend(["--allowedTools", args.allowed_tools])
    if args.output_format:
        cmd.extend(["--output-format", args.output_format])
    if args.dangerously_skip_permissions:
        cmd.append("--dangerously-skip-permissions")
    return cmd


def infer_dispatch_defaults(args: argparse.Namespace) -> None:
    if args.cmd != "skill":
        return
    if args.dispatch_trigger:
        return

    skill = (args.skill or "").strip().lstrip("/")
    if not skill or not skill.endswith("-heartbeat"):
        return

    args.dispatch_trigger = "heartbeat"
    args.dispatch_policy = args.dispatch_policy or "autonomous"
    args.dispatch_routing_mode = args.dispatch_routing_mode or "auto"
    args.dispatch_preflight_profile = args.dispatch_preflight_profile or "heartbeat_default"
    args.dispatch_postflight_profile = args.dispatch_postflight_profile or "standard"


def run_edge_tool(
    tool_name: str,
    args: list[str],
    env: dict[str, str],
    *,
    allow_nonzero: bool = False,
) -> tuple[int, dict]:
    cmd = [str(SCRIPT_DIR / tool_name), *args]
    result = subprocess.run(
        cmd,
        env=env,
        cwd=str(EDGE_REPO_DIR),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0 and not allow_nonzero:
        detail = result.stderr.strip() or result.stdout.strip() or f"exit {result.returncode}"
        raise RunnerAbort(f"{tool_name}_failed", f"{' '.join(cmd)} failed: {detail}")
    payload = result.stdout.strip()
    if not payload:
        return result.returncode, {}
    try:
        return result.returncode, json.loads(payload)
    except json.JSONDecodeError:
        return result.returncode, {}


def maybe_open_cycle(args: argparse.Namespace, env: dict[str, str]) -> str | None:
    if not args.dispatch_trigger:
        return None

    cycle_id = args.cycle_id or make_cycle_id()
    dispatch_args = [
        "open",
        "--trigger",
        args.dispatch_trigger,
        "--cycle-id",
        cycle_id,
    ]
    if args.cmd == "skill" and args.skill:
        dispatch_args.extend(["--skill", args.skill.lstrip("/")])
    elif args.cmd == "prompt":
        dispatch_args.extend(["--skill", "prompt"])
    if args.dispatch_policy:
        dispatch_args.extend(["--policy", args.dispatch_policy])
    if args.dispatch_routing_mode:
        dispatch_args.extend(["--routing-mode", args.dispatch_routing_mode])
    if args.dispatch_preflight_profile:
        dispatch_args.extend(["--preflight-profile", args.dispatch_preflight_profile])
    if args.dispatch_postflight_profile:
        dispatch_args.extend(["--postflight-profile", args.dispatch_postflight_profile])
    if args.dispatch_force:
        dispatch_args.append("--force")

    env["EDGE_CYCLE_ID"] = cycle_id
    run_edge_tool("edge-dispatch", dispatch_args, env)
    return cycle_id


def maybe_run_preflight(args: argparse.Namespace, env: dict[str, str], cycle_id: str | None) -> None:
    if not cycle_id:
        return
    preflight_args = ["run", "--stage", "preflight"]
    if args.dispatch_preflight_profile:
        preflight_args.extend(["--profile", args.dispatch_preflight_profile])
    if args.cmd == "skill" and args.dispatch_trigger != "heartbeat" and args.skill:
        preflight_args.extend(["--skill", args.skill.lstrip("/")])
    elif args.cmd == "prompt":
        preflight_args.extend(["--skill", "prompt"])
    status, payload = run_edge_tool("edge-preflight", preflight_args, env, allow_nonzero=True)
    if status == 2:
        detail = (payload or {}).get("reason") or "duplicate_risk_block"
        raise RunnerAbort("preflight_blocked", f"preflight blocked: {detail}")
    if status != 0:
        detail = (payload or {}).get("error") or "preflight_failed"
        raise RunnerAbort("preflight_failed", f"preflight failed: {detail}")


def maybe_dispatch_skill(args: argparse.Namespace, env: dict[str, str], cycle_id: str | None) -> None:
    if not cycle_id:
        return
    if args.cmd == "skill":
        skill_name = args.skill.lstrip("/")
        if skill_name.endswith("-heartbeat"):
            return
    else:
        skill_name = "prompt"
    run_edge_tool("edge-dispatch", ["dispatch", "--skill", skill_name], env)


def exploration_disabled() -> bool:
    value = str(os.environ.get("EDGE_EXPLORE_DISABLED", "") or "").strip().lower()
    return value in {"1", "true", "yes", "on"}


def derive_exploration_query(state: dict, skill_name: str) -> str:
    request = state.get("request", {}) or {}
    if request.get("corpus_query"):
        return str(request.get("corpus_query") or "")
    args = request.get("args") or {}
    if isinstance(args, dict):
        for key in ("query", "topic", "title", "subject", "target", "question", "task", "prompt", "focus"):
            value = args.get(key)
            if value is not None and str(value).strip():
                return str(value).strip()
    inbox = request.get("async_inbox") or {}
    direct = inbox.get("direct_messages") or []
    if direct and isinstance(direct[0], dict):
        text = str(direct[0].get("text") or direct[0].get("body") or "").strip()
        if text:
            return text[:500]
    return normalize_skill_name(skill_name).replace("-", " ")


def maybe_run_exploration(args: argparse.Namespace, env: dict[str, str], cycle_id: str | None, skill_name: str | None) -> None:
    if not cycle_id or exploration_disabled():
        return
    normalized = normalize_skill_name(skill_name)
    if not normalized or normalized.endswith("heartbeat"):
        return
    try:
        state = dispatch_state_matches(cycle_id) or read_dispatch_state()
        existing = ((state.get("request", {}) or {}).get("exploration_pack") or {})
        if existing.get("path") and existing.get("skill") == normalized:
            return
        query = derive_exploration_query(state, normalized)
        explore_args = ["run", "--skill", normalized, "--query", query, "--cycle-id", cycle_id]
        if str(os.environ.get("EDGE_EXPLORE_SKIP_SOURCES", "") or "").strip().lower() in {"1", "true", "yes", "on"}:
            explore_args.append("--skip-sources")
        status, payload = run_edge_tool("edge-explore", explore_args, env, allow_nonzero=True)
        if status != 0:
            emit_shadow_event(
                "ExplorationPackFailed",
                actor="edge-runner",
                cycle_id=cycle_id,
                payload={
                    "skill": normalized,
                    "query": query,
                    "status": "warning",
                    "reason": (payload or {}).get("error") or f"edge-explore exit={status}",
                },
            )
    except Exception as exc:
        emit_shadow_event(
            "ExplorationPackFailed",
            actor="edge-runner",
            cycle_id=cycle_id,
            payload={"skill": normalized, "status": "warning", "reason": str(exc)},
        )


def autonomy_checkup_disabled() -> bool:
    value = str(os.environ.get("EDGE_AUTONOMY_PRIMITIVE_CHECKUP_DISABLED", "") or "").strip().lower()
    return value in {"1", "true", "yes", "on"}


def attach_autonomy_checkup(cycle_id: str, payload: dict) -> None:
    state = dispatch_state_matches(cycle_id)
    if not state:
        return
    request = state.setdefault("request", {})
    summary = (payload.get("summary") or {}) if isinstance(payload, dict) else {}
    checkup = (payload.get("checkup") or {}) if isinstance(payload, dict) else {}
    capabilities = (payload.get("capabilities_status") or {}) if isinstance(payload, dict) else {}
    request["autonomy_primitives_checkup"] = {
        "status": checkup.get("status") or summary.get("health_status") or "unknown",
        "generated_at": payload.get("generated_at") or "",
        "primitive_summary": summary,
        "checkup": checkup,
        "capability_summary": (capabilities.get("summary") or {}),
        "candidate_actions": checkup.get("candidate_actions") or [],
    }
    if summary:
        request["primitives_status"] = {
            "health_status": summary.get("health_status"),
            "summary": summary,
            "sources": payload.get("sources") or [],
        }
    if capabilities:
        request["capabilities_status"] = {
            "health_status": (capabilities.get("summary") or {}).get("health_status"),
            "summary": capabilities.get("summary") or {},
            "recommended": capabilities.get("recommended") or [],
            "capabilities": capabilities.get("capabilities") or [],
        }
    state.setdefault("state", {})["autonomy_primitives_checkup_status"] = request["autonomy_primitives_checkup"]["status"]
    write_dispatch_state(state)


def maybe_run_autonomy_primitive_checkup(
    args: argparse.Namespace,
    env: dict[str, str],
    cycle_id: str | None,
    skill_name: str | None,
) -> None:
    if not cycle_id or autonomy_checkup_disabled():
        return
    normalized = normalize_skill_name(skill_name)
    if normalized != "autonomy":
        return
    try:
        status, payload = run_edge_tool(
            "edge-primitives",
            ["status", "--json", "--checkup", "--skill", "autonomy"],
            env,
            allow_nonzero=True,
        )
        if payload:
            attach_autonomy_checkup(cycle_id, payload)
        if status != 0:
            emit_shadow_event(
                "AutonomyPrimitiveCheckupFailed",
                actor="edge-runner",
                cycle_id=cycle_id,
                payload={"skill": normalized, "status": "warning", "exit_code": status},
            )
    except Exception as exc:
        emit_shadow_event(
            "AutonomyPrimitiveCheckupFailed",
            actor="edge-runner",
            cycle_id=cycle_id,
            payload={"skill": normalized, "status": "warning", "reason": str(exc)},
        )


def maybe_close_cycle(
    args: argparse.Namespace,
    env: dict[str, str],
    cycle_id: str | None,
    *,
    status: str,
    reason: str | None,
) -> dict:
    if not cycle_id:
        return {}
    close_args = ["--status", status]
    if reason:
        close_args.extend(["--reason", reason])
    _, payload = run_edge_tool("edge-close", close_args, env, allow_nonzero=True)
    return payload


def build_backend_content(args: argparse.Namespace, cycle_id: str | None) -> str:
    if args.cmd != "skill" or not cycle_id:
        return args.skill if args.cmd == "skill" else args.prompt
    state = read_dispatch_state()
    return render_skill_runtime_prompt(args.skill, state)


def dispatch_state_matches(cycle_id: str) -> dict | None:
    try:
        state = read_dispatch_state()
    except Exception:
        return None
    if state.get("cycle_id") != cycle_id:
        return None
    return state


def iter_jsonl(path: Path) -> list[dict]:
    if not path.exists():
        return []
    rows = []
    for line in path.read_text(encoding="utf-8").splitlines():
        if not line.strip():
            continue
        try:
            rows.append(json.loads(line))
        except json.JSONDecodeError:
            continue
    return rows


def iso_ge(left: str | None, right: str | None) -> bool:
    if not left or not right:
        return False
    try:
        left_dt = datetime.fromisoformat(left)
        right_dt = datetime.fromisoformat(right)
    except ValueError:
        return False
    if left_dt.tzinfo is None:
        left_dt = left_dt.replace(tzinfo=timezone.utc)
    if right_dt.tzinfo is None:
        right_dt = right_dt.replace(tzinfo=timezone.utc)
    return left_dt >= right_dt


def normalize_skill_name(skill: str | None) -> str:
    raw = str(skill or "").strip().lstrip("/")
    prefix = str(EDGE_INSTANCE or "").strip()
    if prefix and raw.startswith(f"{prefix}-"):
        raw = raw[len(prefix) + 1:]
    return raw


def skill_run_completed_for_cycle(cycle_id: str, skill: str | None) -> bool:
    state = dispatch_state_matches(cycle_id)
    if not state:
        return False
    requested_skill = normalize_skill_name(skill)
    if not requested_skill:
        return False
    state_block = state.get("state", {}) or {}
    threshold = state_block.get("dispatched_at") or state_block.get("opened_at")

    accepted = {requested_skill, f"/{requested_skill}"}
    for event in reversed(iter_jsonl(STATE_EVENTS_FILE)):
        if event.get("type") != "SkillRunCompleted":
            continue
        if event.get("cycle_id") != cycle_id:
            continue
        payload = event.get("payload", {}) or {}
        event_skill = normalize_skill_name(payload.get("skill"))
        registry_skill = normalize_skill_name(payload.get("registry_skill"))
        if event_skill not in accepted and registry_skill not in accepted:
            continue
        if threshold and not iso_ge(event.get("ts"), threshold):
            continue
        return True

    for row in reversed(iter_jsonl(SKILL_STEPS_FILE)):
        if row.get("event") != "end":
            continue
        if normalize_skill_name(row.get("skill")) not in accepted and normalize_skill_name(row.get("registry_skill")) not in accepted:
            continue
        if threshold and not iso_ge(row.get("ts"), threshold):
            continue
        return True
    return False


def dispatched_follow_on_skill(args: argparse.Namespace, cycle_id: str | None) -> str | None:
    if not cycle_id or args.cmd != "skill":
        return None
    initial_skill = normalize_skill_name(args.skill)
    if not initial_skill.endswith("heartbeat"):
        return None
    state = dispatch_state_matches(cycle_id)
    if not state:
        return None
    request = state.get("request", {}) or {}
    state_block = state.get("state", {}) or {}
    dispatched_skill = normalize_skill_name(request.get("skill"))
    if not state_block.get("skill_dispatched"):
        return None
    if not dispatched_skill or dispatched_skill == initial_skill or dispatched_skill.endswith("heartbeat"):
        return None
    return dispatched_skill


def make_follow_on_skill_args(args: argparse.Namespace, skill_name: str) -> argparse.Namespace:
    follow_on = argparse.Namespace(**vars(args))
    follow_on.skill = f"/{normalize_skill_name(skill_name)}"
    return follow_on


DEFAULT_SKILL_TIMEOUT_SECONDS = 5400  # 90 minutes — see issue #374


def resolve_skill_timeout_seconds() -> int | None:
    raw = os.environ.get("EDGE_RUNNER_SKILL_TIMEOUT_SEC")
    if raw is None or raw == "":
        return DEFAULT_SKILL_TIMEOUT_SECONDS
    try:
        value = int(raw)
    except ValueError:
        return DEFAULT_SKILL_TIMEOUT_SECONDS
    if value <= 0:
        return None
    return value


def invoke_backend(args: argparse.Namespace, env: dict[str, str], *, cycle_id: str | None = None) -> int:
    content = build_backend_content(args, cycle_id)
    cmd = build_backend_command(args)

    timeout_seconds = resolve_skill_timeout_seconds()
    if timeout_seconds is None:
        result = subprocess.run(cmd, env=env, cwd=resolve_cwd(args.cwd), input=content, text=True)
        return result.returncode

    popen_kwargs: dict = {
        "env": env,
        "cwd": resolve_cwd(args.cwd),
        "stdin": subprocess.PIPE,
        "text": True,
    }
    if os.name == "posix":
        popen_kwargs["start_new_session"] = True
    proc = subprocess.Popen(cmd, **popen_kwargs)
    try:
        proc.communicate(input=content, timeout=timeout_seconds)
        return proc.returncode
    except subprocess.TimeoutExpired:
        target = args.skill if args.cmd == "skill" else "prompt"
        emit_shadow_event(
            "SkillSubprocessTimeout",
            actor="edge-runner",
            cycle_id=cycle_id,
            payload={
                "target": target,
                "mode": args.cmd,
                "timeout_seconds": timeout_seconds,
                "pid": proc.pid,
            },
        )
        _terminate_process_group(proc)
        raise RunnerAbort("skill_subprocess_timeout", f"backend exceeded {timeout_seconds}s — process group killed")


def _terminate_process_group(proc: subprocess.Popen) -> None:
    if os.name != "posix":
        try:
            proc.kill()
        except Exception:
            pass
        try:
            proc.wait(timeout=5)
        except Exception:
            pass
        return
    try:
        pgid = os.getpgid(proc.pid)
    except (ProcessLookupError, OSError):
        return
    try:
        os.killpg(pgid, signal.SIGTERM)
    except (ProcessLookupError, OSError):
        return
    try:
        proc.wait(timeout=10)
        return
    except subprocess.TimeoutExpired:
        pass
    try:
        os.killpg(pgid, signal.SIGKILL)
    except (ProcessLookupError, OSError):
        return
    try:
        proc.wait(timeout=5)
    except Exception:
        pass


def maybe_mark_skill_completion(skill: str, cycle_id: str | None, exit_code: int) -> None:
    if not cycle_id or exit_code != 0:
        return
    normalized = normalize_skill_name(skill)
    if not normalized:
        return
    state = dispatch_state_matches(cycle_id)
    if not state:
        return
    current_skill = normalize_skill_name((state.get("request", {}) or {}).get("skill"))
    if normalized != current_skill:
        return
    if not (state.get("state", {}) or {}).get("skill_dispatched") and normalized != "prompt":
        return
    if skill_run_completed_for_cycle(cycle_id, normalized):
        return
    emit_shadow_event(
        "SkillRunCompleted",
        actor="edge-runner",
        cycle_id=cycle_id,
        payload={
            "skill": normalized,
            "registry_skill": normalized,
            "event": "end",
            "expected": 1,
            "done": 1,
            "explicit_skips": 0,
            "silent_skips": [],
            "completion_pct": 100,
            "completion_source": "edge_runner_fallback",
        },
    )


def add_common_arguments(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--backend", default="claude", choices=["claude"])
    parser.add_argument("--cwd", help="Working directory for the backend invocation")
    parser.add_argument("--max-turns", type=int, help="Backend max turns")
    parser.add_argument("--allowed-tools", help="Backend allowed tools payload")
    parser.add_argument("--output-format", help="Backend output format")
    parser.add_argument(
        "--dangerously-skip-permissions",
        action="store_true",
        help="Pass through the Claude permissions bypass flag",
    )
    parser.add_argument("--dispatch-trigger", choices=["heartbeat", "operator", "user"])
    parser.add_argument("--dispatch-policy", choices=["autonomous", "operator"])
    parser.add_argument("--dispatch-routing-mode", choices=["auto", "explicit"])
    parser.add_argument("--dispatch-preflight-profile")
    parser.add_argument("--dispatch-postflight-profile")
    parser.add_argument("--dispatch-force", action="store_true")
    parser.add_argument("--cycle-id", help="Override the generated dispatch cycle id")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Backend-neutral boundary for edge skill and prompt execution")
    sub = parser.add_subparsers(dest="cmd", required=True)
    p_skill = sub.add_parser("skill", help="Invoke one skill through the configured backend")
    add_common_arguments(p_skill)
    p_skill.add_argument("--skill", required=True)
    p_prompt = sub.add_parser("prompt", help="Invoke one free-form prompt through the configured backend")
    add_common_arguments(p_prompt)
    p_prompt.add_argument("--prompt", required=True)
    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    infer_dispatch_defaults(args)

    env = os.environ.copy()
    env.setdefault("EDGE_REPO_DIR", str(EDGE_REPO_DIR))
    env["EDGE_RUNNER_BACKEND"] = args.backend
    env["EDGE_RUNNER_MODE"] = args.cmd
    env["EDGE_RUNNER_PID"] = str(os.getpid())
    env["EDGE_RUNNER_STARTED_AT"] = now_iso()

    cycle_id = None
    exit_code = 0
    close_status = "completed"
    close_reason = None

    try:
        cycle_id = maybe_open_cycle(args, env)
        maybe_run_preflight(args, env, cycle_id)
        maybe_dispatch_skill(args, env, cycle_id)
        if args.cmd == "prompt":
            maybe_run_exploration(args, env, cycle_id, "prompt")
        elif args.cmd == "skill" and not normalize_skill_name(args.skill).endswith("heartbeat"):
            maybe_run_exploration(args, env, cycle_id, args.skill)
            maybe_run_autonomy_primitive_checkup(args, env, cycle_id, args.skill)
        if cycle_id:
            log_run_step(
                "edge-runner",
                "invoke",
                "started",
                run_id=cycle_id,
                backend=args.backend,
                mode=args.cmd,
                target=args.skill if args.cmd == "skill" else "prompt",
            )

        exit_code = invoke_backend(args, env, cycle_id=cycle_id)
        if args.cmd == "prompt":
            maybe_mark_skill_completion("prompt", cycle_id, exit_code)
        elif args.cmd == "skill":
            maybe_mark_skill_completion(args.skill, cycle_id, exit_code)

        follow_on_skill = dispatched_follow_on_skill(args, cycle_id)
        if follow_on_skill and exit_code == 0:
            maybe_run_exploration(args, env, cycle_id, follow_on_skill)
            maybe_run_autonomy_primitive_checkup(args, env, cycle_id, follow_on_skill)
            log_run_step(
                "edge-runner",
                "handoff",
                "started",
                run_id=cycle_id,
                backend=args.backend,
                mode=args.cmd,
                target=follow_on_skill,
            )
            follow_on_args = make_follow_on_skill_args(args, follow_on_skill)
            follow_on_exit = invoke_backend(follow_on_args, env, cycle_id=cycle_id)
            maybe_mark_skill_completion(follow_on_skill, cycle_id, follow_on_exit)
            final_status = "completed" if follow_on_exit == 0 else "failed"
            log_run_step(
                "edge-runner",
                "handoff",
                final_status,
                run_id=cycle_id,
                backend=args.backend,
                mode="skill",
                target=follow_on_skill,
                exit_code=follow_on_exit,
            )
            if follow_on_exit != 0:
                exit_code = follow_on_exit
                close_status = "failed"
                close_reason = f"dispatched_backend_exit_{follow_on_exit}"
        if exit_code != 0:
            close_status = "failed"
            close_reason = close_reason or f"backend_exit_{exit_code}"
    except KeyboardInterrupt:
        exit_code = 130
        close_status = "aborted"
        close_reason = "keyboard_interrupt"
    except RunnerAbort as exc:
        exit_code = 1
        close_status = "failed"
        close_reason = exc.reason
        print(f"edge-runner: {exc}", file=sys.stderr)
    except Exception as exc:
        exit_code = 1
        close_status = "failed"
        close_reason = type(exc).__name__.lower()
        print(f"edge-runner: {exc}", file=sys.stderr)
    finally:
        if cycle_id:
            try:
                payload = maybe_close_cycle(args, env, cycle_id, status=close_status, reason=close_reason)
                state_block = (payload or {}).get("state", {}) or {}
                actual_close_status = state_block.get("close_status") or close_status
                actual_close_reason = state_block.get("close_reason") or close_reason
                if close_status == "completed" and actual_close_status != "completed":
                    close_status = actual_close_status
                    close_reason = actual_close_reason
                    if exit_code == 0:
                        exit_code = 1
            except Exception as exc:
                print(f"edge-runner: failed to close cycle {cycle_id}: {exc}", file=sys.stderr)
                if exit_code == 0:
                    exit_code = 1
                    close_status = "failed"
                    close_reason = "close_failure"
            final_status = "completed" if close_status == "completed" and exit_code == 0 else close_status
            log_run_step(
                "edge-runner",
                "invoke",
                final_status,
                run_id=cycle_id,
                backend=args.backend,
                mode=args.cmd,
                target=args.skill if args.cmd == "skill" else "prompt",
                exit_code=exit_code,
                close_status=close_status,
                close_reason=close_reason or "",
            )
    return exit_code


if __name__ == "__main__":
    sys.exit(main())
