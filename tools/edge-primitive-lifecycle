#!/usr/bin/env python3
"""edge-primitive-lifecycle — canonical lifecycle helper for on-demand primitives.

Usage:
  edge-primitive-lifecycle missing arxiv --operation search
  edge-primitive-lifecycle contract arxiv --description "Recent preprints"
  edge-primitive-lifecycle materialize arxiv
  edge-primitive-lifecycle probe arxiv -- ./libexec/ed/arxiv --query "q"
"""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

import yaml

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR.parent / "config"))
from paths import LIBEXEC_DIR, SOURCES_MANIFEST_FILE  # noqa: E402
sys.path.insert(0, str(SCRIPT_DIR / "_shared"))
from telemetry import (  # noqa: E402
    log_primitive_contract_written,
    log_primitive_manifest_updated,
    log_primitive_materialized,
    log_primitive_missing,
    log_primitive_probe_completed,
)


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def sha256_path(path: Path) -> str | None:
    try:
        if path.is_symlink():
            return f"sha256:{hashlib.sha256(os.readlink(path).encode('utf-8')).hexdigest()}"
        if path.is_file():
            return f"sha256:{hashlib.sha256(path.read_bytes()).hexdigest()}"
    except OSError:
        return None
    return None


def load_manifest() -> dict:
    if not SOURCES_MANIFEST_FILE.exists():
        return {"version": 1, "sources": []}
    data = yaml.safe_load(SOURCES_MANIFEST_FILE.read_text(encoding="utf-8")) or {}
    if not isinstance(data, dict):
        return {"version": 1, "sources": []}
    data.setdefault("version", 1)
    data.setdefault("sources", [])
    if not isinstance(data["sources"], list):
        data["sources"] = []
    return data


def save_manifest(data: dict) -> None:
    SOURCES_MANIFEST_FILE.parent.mkdir(parents=True, exist_ok=True)
    SOURCES_MANIFEST_FILE.write_text(
        yaml.safe_dump(data, allow_unicode=True, sort_keys=False),
        encoding="utf-8",
    )


def upsert_manifest_entry(source: str) -> tuple[dict, dict]:
    manifest = load_manifest()
    for entry in manifest["sources"]:
        if isinstance(entry, dict) and entry.get("name") == source:
            return manifest, entry
    entry = {"name": source}
    manifest["sources"].append(entry)
    return manifest, entry


def default_meta_path(source: str) -> Path:
    return LIBEXEC_DIR / f"{source}.meta.yaml"


def default_binary_path(source: str) -> Path:
    return LIBEXEC_DIR / source


def cmd_missing(args: argparse.Namespace) -> int:
    detail = args.detail or (
        f"primitive '{args.source}' returned exit {args.exit_code}"
        + (f" for operation '{args.operation}'" if args.operation else "")
    )
    log_primitive_missing(
        args.source,
        operation=args.operation,
        exit_code=args.exit_code,
        detail=detail,
    )
    print(json.dumps({"ok": True, "source": args.source, "exit_code": args.exit_code, "detail": detail}, ensure_ascii=False))
    return 0


def cmd_contract(args: argparse.Namespace) -> int:
    meta_path = Path(args.meta_path) if args.meta_path else default_meta_path(args.source)
    meta_path.parent.mkdir(parents=True, exist_ok=True)
    created_at = now_iso()
    operations = [{"name": op, "status": "planned"} for op in args.operation]
    meta = {
        "name": args.source,
        "description": args.description,
        "version": args.version,
        "status": "contract-only",
        "created_at": created_at,
        "updated_at": created_at,
        "operations": operations,
        "notes": args.note or "",
    }
    meta_path.write_text(yaml.safe_dump(meta, allow_unicode=True, sort_keys=False), encoding="utf-8")
    meta_hash = sha256_path(meta_path)
    log_primitive_contract_written(
        args.source,
        meta_path=str(meta_path),
        status="contract-only",
        hash_value=meta_hash,
        operation_count=len(operations),
    )

    manifest, entry = upsert_manifest_entry(args.source)
    entry.update(
        {
            "name": args.source,
            "description": args.description,
            "status": "contract-only",
            "created_at": entry.get("created_at") or created_at,
            "updated_at": created_at,
            "meta_path": str(meta_path),
            "binary_path": entry.get("binary_path", ""),
            "operations": [op["name"] for op in operations],
        }
    )
    save_manifest(manifest)
    log_primitive_manifest_updated(
        args.source,
        manifest_path=str(SOURCES_MANIFEST_FILE),
        status="contract-only",
        meta_path=str(meta_path),
    )
    print(json.dumps({"ok": True, "source": args.source, "meta_path": str(meta_path)}, ensure_ascii=False))
    return 0


def cmd_materialize(args: argparse.Namespace) -> int:
    binary_path = Path(args.binary_path) if args.binary_path else default_binary_path(args.source)
    meta_path = Path(args.meta_path) if args.meta_path else default_meta_path(args.source)
    if not binary_path.exists():
        print(json.dumps({"ok": False, "error": f"binary not found: {binary_path}"}, ensure_ascii=False))
        return 1
    if args.ensure_executable:
        binary_path.chmod(binary_path.stat().st_mode | 0o111)

    manifest, entry = upsert_manifest_entry(args.source)
    timestamp = now_iso()
    entry.update(
        {
            "name": args.source,
            "status": args.status,
            "created_at": entry.get("created_at") or timestamp,
            "updated_at": timestamp,
            "meta_path": str(meta_path) if meta_path.exists() else entry.get("meta_path", ""),
            "binary_path": str(binary_path),
        }
    )
    save_manifest(manifest)

    binary_hash = sha256_path(binary_path)
    log_primitive_materialized(
        args.source,
        binary_path=str(binary_path),
        hash_value=binary_hash,
        status=args.status,
    )
    log_primitive_manifest_updated(
        args.source,
        manifest_path=str(SOURCES_MANIFEST_FILE),
        status=args.status,
        binary_path=str(binary_path),
        meta_path=str(meta_path) if meta_path.exists() else "",
    )
    print(json.dumps({"ok": True, "source": args.source, "binary_path": str(binary_path)}, ensure_ascii=False))
    return 0


def cmd_probe(args: argparse.Namespace) -> int:
    command = list(args.command or [])
    if not command:
        print(json.dumps({"ok": False, "error": "probe requires --command ..."}, ensure_ascii=False))
        return 2

    result = subprocess.run(command, capture_output=True, text=True)
    ok = result.returncode == 0
    log_primitive_probe_completed(
        args.source,
        command=command,
        exit_code=result.returncode,
        ok=ok,
        operation=args.operation or "",
        stdout_len=len(result.stdout or ""),
        stderr_len=len(result.stderr or ""),
    )
    if result.returncode in {77, 127}:
        log_primitive_missing(
            args.source,
            operation=args.operation,
            exit_code=result.returncode,
            detail=(result.stderr or result.stdout or "").strip()[:240],
        )

    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Canonical lifecycle helper for on-demand primitives")
    sub = parser.add_subparsers(dest="command_name", required=True)

    missing = sub.add_parser("missing", help="Record exit 127 or exit 77 for a missing primitive")
    missing.add_argument("source")
    missing.add_argument("--operation")
    missing.add_argument("--exit-code", type=int, default=127, choices=[77, 127])
    missing.add_argument("--detail", default="")
    missing.set_defaults(func=cmd_missing)

    contract = sub.add_parser("contract", help="Write the primitive contract and register contract-only status")
    contract.add_argument("source")
    contract.add_argument("--description", required=True)
    contract.add_argument("--meta-path")
    contract.add_argument("--version", default="0.1.0")
    contract.add_argument("--operation", action="append", default=[])
    contract.add_argument("--note", default="")
    contract.set_defaults(func=cmd_contract)

    materialize = sub.add_parser("materialize", help="Register a materialized primitive binary")
    materialize.add_argument("source")
    materialize.add_argument("--binary-path")
    materialize.add_argument("--meta-path")
    materialize.add_argument("--status", default="active")
    materialize.add_argument("--ensure-executable", action="store_true")
    materialize.set_defaults(func=cmd_materialize)

    probe = sub.add_parser("probe", help="Run a probe command and record the lifecycle fact")
    probe.add_argument("source")
    probe.add_argument("--operation")
    probe.add_argument("--command", nargs="+", required=True)
    probe.set_defaults(func=cmd_probe)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
