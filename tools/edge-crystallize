#!/usr/bin/env python3
"""edge-crystallize: Create workflow entries from procedure clusters or operator directives.

Two modes:
  1. From procedure-curation.json (automated clustering → draft entries)
  2. From operator directive (explicit instruction → approved entry immediately)

Usage:
    edge-crystallize                                    # drafts for candidates >= 3 claims
    edge-crystallize --min-claims 5                     # only strong clusters
    edge-crystallize --approve                          # create as workflow (skip draft stage)
    edge-crystallize --dry-run                          # show what would be created
    edge-crystallize --cluster 1                        # only specific cluster
    edge-crystallize --from-operator "Always validate claims against 3 sources before publishing"
"""

import argparse
import json
import os
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path

_SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(_SCRIPT_DIR.parent / "tools"))
sys.path.insert(0, str(_SCRIPT_DIR.parent / "config"))
try:
    from _shared.telemetry import log_workflow_transition
except Exception:
    def log_workflow_transition(*a, **kw): pass
from paths import ENTRIES_DIR, PROCEDURE_CURATION_FILE  # noqa: E402


def slugify(text):
    """Convert title to a URL-friendly slug."""
    text = text.lower()
    text = re.sub(r"workflow:\s*", "", text)
    text = re.sub(r"[^a-z0-9]+", "-", text)
    return text.strip("-")[:60]


def index_entry(filepath):
    """Index a blog entry if edge-index is available."""
    try:
        subprocess.run(
            ["edge-index", str(filepath)],
            capture_output=True, timeout=30
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass


def create_from_operator(directive, dry_run=False):
    """Create an approved workflow directly from an operator directive."""
    entries_dir = ENTRIES_DIR
    entries_dir.mkdir(parents=True, exist_ok=True)
    today = datetime.now().strftime("%Y-%m-%d")

    # Extract a title from the directive
    # Try to find the core action: "always X" → "X", "whenever Y, do Z" → "Z"
    directive_clean = directive.strip().rstrip(".")
    slug = slugify(directive_clean)[:50]
    title = f"workflow: {directive_clean[:80]}"

    filename = f"{today}-{slug}.md"
    filepath = entries_dir / filename

    if filepath.exists():
        print(f"  SKIP {filename} (already exists)")
        return 0

    content = (
        f"---\n"
        f"title: \"{title}\"\n"
        f"date: {today}\n"
        f"tags: [workflow, operator-directive]\n"
        f"trigger: \"Operator instruction\"\n"
        f"claims:\n"
        f"  - \"Operator directive — approved on creation\"\n"
        f"threads: []\n"
        f"keywords: [{slug.replace('-', ', ')}]\n"
        f"workflows_used: []\n"
        f"workflows_broken: []\n"
        f"---\n\n"
        f"## Directive\n\n"
        f"{directive_clean}\n\n"
        f"## Origin\n\n"
        f"Operator instruction, {today}. Approved on creation — operator authority.\n"
    )

    if dry_run:
        print(f"  WOULD CREATE {filename} (operator directive, tag=workflow)")
        return 1

    filepath.write_text(content)
    print(f"  CREATED {filename} (operator directive, tag=workflow)")
    index_entry(filepath)
    log_workflow_transition(slug, from_state="claim", to_state="approved",
                            approved_by="operator", source="operator-directive")
    return 1


def create_from_curation(args):
    """Create workflow-draft entries from procedure-curation.json candidates."""
    curation_file = PROCEDURE_CURATION_FILE
    entries_dir = ENTRIES_DIR
    entries_dir.mkdir(parents=True, exist_ok=True)
    today = datetime.now().strftime("%Y-%m-%d")

    if not curation_file.exists():
        print("No procedure-curation.json found. Run edge-curation sync first.")
        sys.exit(1)

    data = json.load(open(curation_file))
    candidates = data.get("crystallization_candidates", [])

    if not candidates:
        print("No crystallization candidates found.")
        sys.exit(0)

    tag = "workflow" if args.approve else "workflow-draft"
    created = 0
    skipped = 0

    for cand in candidates:
        cluster_id = cand.get("cluster_id", 0)
        claim_count = cand.get("claim_count", len(cand.get("claims", [])))
        title = cand.get("suggested_workflow_title", f"workflow: cluster-{cluster_id}")
        claims = cand.get("claims", [])
        source_entries = cand.get("source_entries", [])
        steps = cand.get("suggested_steps", "")
        theme = cand.get("theme", "")
        sim = cand.get("median_sim_estimate", "?")

        # Filters
        if args.cluster is not None and cluster_id != args.cluster:
            continue
        if claim_count < args.min_claims:
            skipped += 1
            continue

        slug = slugify(title)
        filename = f"{today}-{slug}.md"
        filepath = entries_dir / filename

        # Skip if already exists
        if filepath.exists():
            print(f"  SKIP {filename} (already exists)")
            skipped += 1
            continue

        # Also skip if a workflow with same slug already exists (any date)
        existing = list(entries_dir.glob(f"*{slug}*.md"))
        if existing:
            print(f"  SKIP {slug} (similar entry exists: {existing[0].name})")
            skipped += 1
            continue

        # Build the entry
        claims_yaml = "\n".join(f'  - "{c}"' for c in claims)
        sources_yaml = "\n".join(f"  - {s}" for s in source_entries)

        # Build body from steps
        if steps:
            step_lines = steps.split(". ")
            steps_md = "\n".join(
                f"{s.strip()}" if s[0].isdigit() else f"- {s.strip()}"
                for s in step_lines if s.strip()
            )
        else:
            steps_md = "_To be defined based on practice._"

        body = (
            f"## Theme\n\n{theme}\n\n"
            f"## Steps\n\n{steps_md}\n\n"
            f"## Source claims\n\n"
        )
        for c in claims:
            body += f"- {c}\n"
        body += f"\n## Source entries\n\n"
        for s in source_entries:
            body += f"- {s}\n"

        content = (
            f"---\n"
            f"title: \"{title}\"\n"
            f"date: {today}\n"
            f"tags: [{tag}, procedure-claims]\n"
            f"trigger: \"{theme}\"\n"
            f"source_claims:\n{claims_yaml}\n"
            f"source_entries:\n{sources_yaml}\n"
            f"cluster_similarity: {sim}\n"
            f"claims:\n"
            f"  - \"Crystallized from {claim_count} procedure-claims across {len(source_entries)} entries\"\n"
            f"threads: []\n"
            f"keywords: [{slug.replace('-', ', ')}]\n"
            f"workflows_used: []\n"
            f"workflows_broken: []\n"
            f"---\n\n"
            f"{body}"
        )

        if args.dry_run:
            print(f"  WOULD CREATE {filename} ({claim_count} claims, tag={tag})")
        else:
            filepath.write_text(content)
            print(f"  CREATED {filename} ({claim_count} claims, tag={tag})")
            index_entry(filepath)
            target_state = "approved" if tag == "workflow" else "draft"
            log_workflow_transition(
                slug, from_state="cluster", to_state=target_state,
                approved_by=("auto" if tag == "workflow" else None),
                cluster_id=cluster_id, claim_count=claim_count,
            )

        created += 1

    print()
    if args.dry_run:
        print(f"Dry run: {created} would be created, {skipped} skipped")
    else:
        print(f"Done: {created} created, {skipped} skipped")
        if created > 0 and not args.approve:
            print(f"\nDrafts appear in the blog with tag '{tag}'.")
            print("Approve with: edge-crystallize --approve --cluster N")


def main():
    parser = argparse.ArgumentParser(
        description="Crystallize procedure clusters or operator directives into workflow entries"
    )
    parser.add_argument("--min-claims", type=int, default=3,
                        help="Minimum claims for crystallization (default: 3)")
    parser.add_argument("--approve", action="store_true",
                        help="Create as 'workflow' instead of 'workflow-draft'")
    parser.add_argument("--dry-run", action="store_true",
                        help="Show what would be created without writing")
    parser.add_argument("--cluster", type=int,
                        help="Only crystallize a specific cluster ID")
    parser.add_argument("--from-operator", type=str, metavar="DIRECTIVE",
                        help="Create approved workflow from operator instruction (skips draft)")
    args = parser.parse_args()

    if args.from_operator:
        n = create_from_operator(args.from_operator, args.dry_run)
        if n and not args.dry_run:
            print(f"\nWorkflow created with tag 'workflow' (approved — operator authority).")
            print("Enters edge-search recall immediately.")
    else:
        create_from_curation(args)


if __name__ == "__main__":
    main()
