#!/usr/bin/env python3
"""edge-workflows — workflow health read model."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))
from _shared.workflow_runtime import build_workflow_status  # noqa: E402


def cmd_status(args: argparse.Namespace) -> int:
    payload = build_workflow_status()
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return 0

    summary = payload.get("summary") or {}
    print("=== WORKFLOW STATUS ===")
    print(f"Total: {summary.get('workflow_total', 0)}")
    print(f"Cited: {summary.get('cited_total', 0)}")
    print(f"Broken: {summary.get('broken_total', 0)}")
    print(f"Stale: {summary.get('stale_total', 0)}")
    top_used = summary.get("top_used") or []
    if top_used:
        print("")
        print("Top used:")
        for item in top_used:
            print(f"  {item.get('slug')}: used={item.get('used', 0)} broken={item.get('broken', 0)}")
    top_broken = summary.get("top_broken") or []
    if top_broken:
        print("")
        print("Top broken:")
        for item in top_broken:
            print(f"  {item.get('slug')}: used={item.get('used', 0)} broken={item.get('broken', 0)}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Workflow runtime read model")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_status = sub.add_parser("status", help="Show workflow health summary")
    p_status.add_argument("--json", action="store_true")
    return parser


def main() -> int:
    args = build_parser().parse_args()
    if args.cmd == "status":
        return cmd_status(args)
    return 1


if __name__ == "__main__":
    sys.exit(main())
