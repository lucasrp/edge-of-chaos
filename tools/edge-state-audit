#!/usr/bin/env python3
"""edge-state-audit — Snapshot, propose, and audit state changes.

Three modes:
  snapshot  — capture SHA256 hashes of protected files (PRE state)
  propose   — write state-proposal.yaml with intended changes
  audit     — compare PRE snapshot vs POST state, validate against proposal

Protected files: MEMORY.md, capabilities.md, debugging.md, personality.md, skills/**/*.md

Usage:
  edge-state-audit snapshot --slug SLUG          # Phase 4a step 1: save PRE hashes
  edge-state-audit propose --slug SLUG --file PATH  # Phase 4a step 2: register proposal (called by agent)
  edge-state-audit audit --slug SLUG             # Phase 5b: compare PRE vs POST, validate proposal

Exit codes:
  0 = OK (all changes proposed)
  1 = error (bad args, missing files)
  2 = partial (some proposed changes not executed)
  4 = divergence (proposed action != executed action)
  5 = violation (unproposed change to protected file)
"""

import argparse
import hashlib
import json
import os
import subprocess
import sys
import yaml
from datetime import datetime, timezone
from pathlib import Path
from glob import glob

HOME = Path.home()
META_DIR = HOME / "edge" / "meta-reports"
SNAPSHOT_DIR = HOME / "edge" / "state-snapshots"

# Protected paths — any change here MUST be proposed
PROTECTED_PATTERNS = [
    str(HOME / ".claude/projects/-home-vboxuser/memory/MEMORY.md"),
    str(HOME / ".claude/projects/-home-vboxuser/memory/debugging.md"),
    str(HOME / ".claude/projects/-home-vboxuser/memory/personality.md"),
    str(HOME / ".claude/projects/-home-vboxuser/memory/insights.md"),
    str(HOME / "edge/autonomy/capabilities.md"),
    str(HOME / "edge/autonomy/frontier.md"),
    str(HOME / "edge/autonomy/workflows.md"),
    str(HOME / "edge/autonomy/metrics.md"),
    str(HOME / "edge/autonomy/log.md"),
    str(HOME / "edge/autonomy/autonomy-policy.md"),
]

# Glob patterns for skills
PROTECTED_GLOBS = [
    str(HOME / ".claude/skills/*/SKILL.md"),
    str(HOME / ".claude/skills/_shared/*.md"),
]

GREEN = "\033[0;32m"
RED = "\033[0;31m"
YELLOW = "\033[1;33m"
NC = "\033[0m"


def ok(msg):
    print(f"  {GREEN}OK{NC}: {msg}")


def warn(msg):
    print(f"  {YELLOW}WARN{NC}: {msg}")


def fail(msg):
    print(f"  {RED}FAIL{NC}: {msg}")


def get_protected_files() -> list[str]:
    """Expand all protected patterns to actual file paths."""
    files = []
    for p in PROTECTED_PATTERNS:
        if os.path.exists(p):
            files.append(p)
    for pattern in PROTECTED_GLOBS:
        files.extend(glob(pattern))
    return sorted(set(files))


def hash_file(path: str) -> str:
    """SHA256 of file contents, or 'MISSING' if not found."""
    try:
        return hashlib.sha256(Path(path).read_bytes()).hexdigest()[:16]
    except FileNotFoundError:
        return "MISSING"


def short_path(path: str) -> str:
    """Shorten path for display."""
    home = str(HOME)
    if path.startswith(home):
        return "~" + path[len(home):]
    return path


# ─── SNAPSHOT ───

def cmd_snapshot(slug: str):
    """Capture SHA256 hashes of all protected files."""
    SNAPSHOT_DIR.mkdir(parents=True, exist_ok=True)
    files = get_protected_files()

    snapshot = {
        "slug": slug,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "type": "pre",
        "files": {},
    }

    for f in files:
        snapshot["files"][short_path(f)] = {
            "hash": hash_file(f),
            "size": os.path.getsize(f) if os.path.exists(f) else 0,
        }

    out_path = SNAPSHOT_DIR / f"{slug}.pre.yaml"
    out_path.write_text(yaml.dump(snapshot, allow_unicode=True, default_flow_style=False, sort_keys=False))
    ok(f"Snapshot PRE: {len(files)} arquivos protegidos → {out_path.name}")
    return str(out_path)


# ─── PROPOSE ───

def cmd_propose(slug: str, proposals: list[dict]):
    """Write state-proposal.yaml with intended changes.

    Each proposal: {path: str, action: add|modify|delete, reason: str, sections: [str]?}
    """
    META_DIR.mkdir(parents=True, exist_ok=True)

    proposal = {
        "slug": slug,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "changes": [],
    }

    for p in proposals:
        entry = {
            "path": p["path"],
            "action": p["action"],  # add, modify, delete
            "reason": p["reason"],
        }
        if "sections" in p:
            entry["sections"] = p["sections"]
        proposal["changes"].append(entry)

    out_path = META_DIR / f"{slug}.state-proposal.yaml"
    out_path.write_text(yaml.dump(proposal, allow_unicode=True, default_flow_style=False, sort_keys=False))
    ok(f"Proposta: {len(proposals)} mudanças → {out_path.name}")
    return str(out_path)


# ─── AUDIT ───

def cmd_audit(slug: str) -> int:
    """Compare PRE snapshot vs current state. Validate against proposal."""

    # Load PRE snapshot
    pre_path = SNAPSHOT_DIR / f"{slug}.pre.yaml"
    if not pre_path.exists():
        fail(f"Snapshot PRE não encontrado: {pre_path}")
        return 1

    pre = yaml.safe_load(pre_path.read_text())

    # Load proposal (optional — if missing, ANY change to protected file is violation)
    proposal_path = META_DIR / f"{slug}.state-proposal.yaml"
    if proposal_path.exists():
        proposal = yaml.safe_load(proposal_path.read_text())
        proposed_changes = {c["path"]: c for c in proposal.get("changes", [])}
    else:
        proposed_changes = {}

    # Capture POST hashes
    files = get_protected_files()
    post_hashes = {}
    for f in files:
        sp = short_path(f)
        post_hashes[sp] = {
            "hash": hash_file(f),
            "size": os.path.getsize(f) if os.path.exists(f) else 0,
        }

    # Compare
    results = []
    exit_code = 0

    # Check every protected file
    all_paths = sorted(set(list(pre.get("files", {}).keys()) + list(post_hashes.keys())))

    for path in all_paths:
        pre_info = pre.get("files", {}).get(path, {"hash": "MISSING", "size": 0})
        post_info = post_hashes.get(path, {"hash": "MISSING", "size": 0})

        pre_hash = pre_info["hash"]
        post_hash = post_info["hash"]
        changed = pre_hash != post_hash

        if not changed:
            # Check if it was proposed but not executed
            if path in proposed_changes:
                results.append({
                    "path": path,
                    "proposed_action": proposed_changes[path]["action"],
                    "executed_action": "none",
                    "result": "omitted",
                    "severity": "warn",
                })
                warn(f"Proposto mas não executado: {path}")
                exit_code = max(exit_code, 2)
            continue

        # File changed — was it proposed?
        if path not in proposed_changes:
            # VIOLATION: unproposed change to protected file
            results.append({
                "path": path,
                "proposed_action": "none",
                "executed_action": "modify",
                "pre_hash": pre_hash,
                "post_hash": post_hash,
                "result": "violation",
                "severity": "fatal",
            })
            fail(f"VIOLAÇÃO: mudança não proposta em {path}")

            # Show diff
            full_path = path.replace("~", str(HOME))
            _show_diff_for_file(full_path, pre_hash)

            exit_code = max(exit_code, 5)
        else:
            # Proposed and changed — check action matches
            proposed_action = proposed_changes[path]["action"]
            if post_hash == "MISSING":
                executed_action = "delete"
            elif pre_hash == "MISSING":
                executed_action = "add"
            else:
                executed_action = "modify"

            if proposed_action == executed_action:
                results.append({
                    "path": path,
                    "proposed_action": proposed_action,
                    "executed_action": executed_action,
                    "result": "ok",
                    "severity": "info",
                })
                ok(f"{path}: {executed_action} (conforme proposta)")
            else:
                results.append({
                    "path": path,
                    "proposed_action": proposed_action,
                    "executed_action": executed_action,
                    "result": "divergence",
                    "severity": "fatal",
                })
                fail(f"DIVERGÊNCIA: {path} — proposto={proposed_action}, executado={executed_action}")
                exit_code = max(exit_code, 4)

    # Write audit report
    audit = {
        "slug": slug,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "pre_snapshot": str(pre_path),
        "proposal": str(proposal_path) if proposal_path.exists() else "none",
        "status": "ok" if exit_code == 0 else ("partial" if exit_code == 2 else "failed"),
        "results": results,
    }

    audit_path = META_DIR / f"{slug}.state-audit.yaml"
    audit_path.write_text(yaml.dump(audit, allow_unicode=True, default_flow_style=False, sort_keys=False))

    # Summary
    ok_count = sum(1 for r in results if r["result"] == "ok")
    warn_count = sum(1 for r in results if r["result"] == "omitted")
    fail_count = sum(1 for r in results if r["result"] in ("violation", "divergence"))

    summary = f"Audit: {ok_count} ok, {warn_count} omitidos, {fail_count} violações → {audit_path.name}"
    if exit_code == 0:
        ok(summary)
    elif exit_code == 2:
        warn(summary)
    else:
        fail(summary)

    return exit_code


def _show_diff_for_file(full_path: str, pre_hash: str):
    """Try to show a git diff for the file."""
    dirpath = os.path.dirname(full_path)
    # Find the git repo
    check = dirpath
    while check != "/":
        if os.path.isdir(os.path.join(check, ".git")):
            break
        check = os.path.dirname(check)
    else:
        return

    try:
        result = subprocess.run(
            ["git", "diff", "--", full_path],
            cwd=check, capture_output=True, text=True, errors="replace"
        )
        if result.stdout.strip():
            lines = result.stdout.strip().split("\n")
            # Show first 20 lines
            for line in lines[:20]:
                if line.startswith("+") and not line.startswith("+++"):
                    print(f"    {GREEN}{line}{NC}")
                elif line.startswith("-") and not line.startswith("---"):
                    print(f"    {RED}{line}{NC}")
                else:
                    print(f"    {line}")
            if len(lines) > 20:
                print(f"    ... ({len(lines) - 20} more lines)")
    except Exception:
        pass


# ─── SCAN (out-of-pipeline) ───

def cmd_scan():
    """Scan protected files for changes since last known state (git HEAD)."""
    files = get_protected_files()
    violations = []

    for f in files:
        dirpath = os.path.dirname(f)
        # Find git repo
        check = dirpath
        while check != "/":
            if os.path.isdir(os.path.join(check, ".git")):
                break
            check = os.path.dirname(check)
        else:
            continue

        # Check if file has uncommitted changes
        result = subprocess.run(
            ["git", "diff", "--name-only", "--", f],
            cwd=check, capture_output=True, text=True
        )
        result2 = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--", f],
            cwd=check, capture_output=True, text=True
        )

        if result.stdout.strip() or result2.stdout.strip():
            violations.append({
                "path": short_path(f),
                "action": "modify",
                "proposed": False,
                "severity": "warning",
            })
            warn(f"Mudança não commitada: {short_path(f)}")

    if not violations:
        ok(f"Scan: {len(files)} arquivos protegidos — nenhuma mudança pendente")
        return 0
    else:
        warn(f"Scan: {len(violations)} mudanças pendentes em arquivos protegidos")
        return 2


# ─── CLI ───

def main():
    parser = argparse.ArgumentParser(description="State audit: snapshot, propose, audit, scan")
    sub = parser.add_subparsers(dest="command")

    # snapshot
    snap = sub.add_parser("snapshot", help="Capture PRE hashes")
    snap.add_argument("--slug", required=True)

    # propose (used programmatically — reads YAML from stdin or file)
    prop = sub.add_parser("propose", help="Write state proposal")
    prop.add_argument("--slug", required=True)
    prop.add_argument("--file", help="YAML file with changes list")

    # audit
    aud = sub.add_parser("audit", help="Compare PRE vs POST, validate proposal")
    aud.add_argument("--slug", required=True)

    # scan
    sub.add_parser("scan", help="Scan protected files for uncommitted changes")

    args = parser.parse_args()

    if args.command == "snapshot":
        cmd_snapshot(args.slug)
    elif args.command == "propose":
        if args.file:
            data = yaml.safe_load(Path(args.file).read_text())
            changes = data if isinstance(data, list) else data.get("changes", [])
        elif not sys.stdin.isatty():
            data = yaml.safe_load(sys.stdin.read())
            changes = data if isinstance(data, list) else data.get("changes", [])
        else:
            parser.error("Provide --file or pipe YAML via stdin")
            return
        cmd_propose(args.slug, changes)
    elif args.command == "audit":
        sys.exit(cmd_audit(args.slug))
    elif args.command == "scan":
        sys.exit(cmd_scan())
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
