#!/usr/bin/env python3
"""edge-x — Smart X/Twitter search for practitioners' insights.

Usage:
    edge-x "topic"                    # broad + targeted search
    edge-x "topic" --from karpathy    # search specific account
    edge-x "topic" --min-followers 500  # filter noise
    edge-x "topic" --verbose          # show raw counts

Searches with multiple strategies, filters by quality, returns signal.
"""

import os, sys, json, argparse
from pathlib import Path

# Load credentials
env_file = Path.home() / "edge" / "secrets" / "x-api.env"
if env_file.exists():
    for line in env_file.read_text().splitlines():
        line = line.strip()
        if line and not line.startswith("#") and "=" in line:
            k, v = line.split("=", 1)
            os.environ[k.strip()] = v.strip()

try:
    import tweepy
except ImportError:
    print("ERROR: tweepy not installed. Run: pip install tweepy", file=sys.stderr)
    sys.exit(1)

def get_client():
    return tweepy.Client(
        bearer_token=os.environ.get('X_BEARER_TOKEN', ''),
        consumer_key=os.environ.get('X_API_KEY', ''),
        consumer_secret=os.environ.get('X_API_SECRET', ''),
        access_token=os.environ.get('X_ACCESS_TOKEN', ''),
        access_token_secret=os.environ.get('X_ACCESS_TOKEN_SECRET', ''),
        wait_on_rate_limit=True
    )

# Trusted accounts — practitioners, researchers, builders
# These are people whose tweets about AI/agents/tools are consistently high-signal
TRUSTED_ACCOUNTS = [
    "karpathy",        # AI research, practical insights
    "swyx",            # AI engineering, latent space
    "simonw",          # Tools, datasette, practical AI
    "jxnlco",          # Instructor, structured output, pydantic
    "hwchase17",       # LangChain/LangGraph creator
    "AnthropicAI",     # Anthropic official
    "OpenAI",          # OpenAI official
    "alexalbert__",    # Anthropic, Claude
    "DrJimFan",        # NVIDIA, embodied AI
    "bindureddy",       # AI products, former AllenAI
    "laborinthAI",     # AI agents
    "eugeneyan",       # ML engineering, production AI
    "shreyar",         # Guardrails, LLM reliability
    "jerryjliu0",      # LlamaIndex creator
    "jobergum",        # Vespa, search, RAG
    "rasaborb",        # BERTopic, embeddings
    "ClawSecure",      # OpenClaw security
    "GregKamradt",     # RAG, evals, chunking
    "llaborinthAI",    # AI agents community
]

# Validate handles at import time — fail loud, not silent
_bad = [h for h in TRUSTED_ACCOUNTS if len(h) > 15]
if _bad:
    raise ValueError(f"X handles >15 chars (invalid): {_bad}")

def search_x(topic, from_accounts=None, min_followers=100, min_engagement=2, max_results=15, verbose=False, light=False):
    """Multi-strategy search returning high-quality results.

    light=True: only 2 API calls (broad + top trusted accounts).
    Use for serendipity scans / heartbeat where budget matters.
    """
    client = get_client()
    all_tweets = []
    seen_ids = set()

    queries = []

    # Strategy 1: Broad topic search (filtered)
    queries.append(f'{topic} -is:retweet lang:en')

    if light:
        # Light mode: only 1 trusted-accounts query (top 10 in a single OR batch)
        # Total: 2 API calls instead of 8. Fits 5 queries in rate limit window.
        top_batch = TRUSTED_ACCOUNTS[:10]
        from_clause = " OR ".join(f"from:{a}" for a in top_batch)
        queries.append(f'({from_clause}) {topic} -is:retweet')
        if verbose:
            print(f"  [light mode: {len(queries)} queries]", file=sys.stderr)
    else:
        # Strategy 2: Topic with practitioner signal words
        practitioner_terms = ["built", "shipped", "learned", "thread", "mistake", "production", "real-world"]
        for term in practitioner_terms[:3]:
            queries.append(f'{topic} {term} -is:retweet lang:en')

        # Strategy 3: From trusted accounts
        if from_accounts:
            for acct in from_accounts:
                queries.append(f'from:{acct} {topic} -is:retweet')
        else:
            # Auto-select relevant trusted accounts (batch of 5 per query, max 4 queries)
            for i in range(0, min(len(TRUSTED_ACCOUNTS), 20), 5):
                batch = TRUSTED_ACCOUNTS[i:i+5]
                from_clause = " OR ".join(f"from:{a}" for a in batch)
                queries.append(f'({from_clause}) {topic} -is:retweet')

    for q in queries:
        try:
            results = client.search_recent_tweets(
                query=q[:512],  # API limit
                max_results=min(max_results, 10),
                tweet_fields=['created_at', 'public_metrics', 'author_id'],
                expansions=['author_id'],
                user_fields=['username', 'name', 'public_metrics']
            )
            if not results.data:
                continue

            users = {}
            if results.includes and 'users' in results.includes:
                users = {u.id: u for u in results.includes['users']}

            for tweet in results.data:
                if tweet.id in seen_ids:
                    continue
                seen_ids.add(tweet.id)

                author = users.get(tweet.author_id)
                m = tweet.public_metrics or {}
                likes = m.get('like_count', 0)
                rts = m.get('retweet_count', 0)
                replies = m.get('reply_count', 0)
                engagement = likes + rts + replies
                followers = 0
                username = "?"

                if author:
                    username = author.username
                    if author.public_metrics:
                        followers = author.public_metrics.get('followers_count', 0)

                all_tweets.append({
                    'username': username,
                    'followers': followers,
                    'likes': likes,
                    'rts': rts,
                    'replies': replies,
                    'engagement': engagement,
                    'text': tweet.text,
                    'url': f"https://x.com/{username}/status/{tweet.id}",
                    'created': str(getattr(tweet, 'created_at', ''))[:10],
                    'query': q[:60],
                })
        except tweepy.errors.TooManyRequests:
            if verbose:
                print(f"  [rate-limited on query: {q[:50]}]", file=sys.stderr)
            continue
        except Exception as e:
            if verbose:
                print(f"  [error on query: {q[:50]}]: {e}", file=sys.stderr)
            continue

    # Filter by quality
    filtered = [
        t for t in all_tweets
        if t['followers'] >= min_followers or t['engagement'] >= min_engagement
    ]

    # Sort by engagement (signal strength)
    filtered.sort(key=lambda t: (t['engagement'], t['followers']), reverse=True)

    return filtered, len(all_tweets)

def main():
    parser = argparse.ArgumentParser(description="Smart X/Twitter search")
    parser.add_argument("topic", help="Topic to search")
    parser.add_argument("--from", dest="from_accounts", nargs="*", help="Search specific accounts")
    parser.add_argument("--min-followers", type=int, default=100, help="Minimum follower count (default: 100)")
    parser.add_argument("--min-engagement", type=int, default=2, help="Minimum engagement (likes+RT+replies, default: 2)")
    parser.add_argument("--max", type=int, default=15, help="Max results to show (default: 15)")
    parser.add_argument("--verbose", action="store_true", help="Show debug info")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--light", action="store_true", help="Light mode: 2 API calls instead of 8 (for serendipity/heartbeat)")
    args = parser.parse_args()

    results, total_raw = search_x(
        args.topic,
        from_accounts=args.from_accounts,
        min_followers=args.min_followers,
        min_engagement=args.min_engagement,
        verbose=args.verbose,
        light=args.light
    )

    if args.json:
        print(json.dumps(results[:args.max], indent=2, ensure_ascii=False))
        return

    shown = results[:args.max]

    if not shown:
        print(f"No quality results for '{args.topic}' (raw: {total_raw}, all filtered out)")
        print(f"Try: --min-followers 0 --min-engagement 0")
        return

    print(f"=== X Search: {args.topic} ({len(shown)} quality / {total_raw} raw) ===\n")

    for i, t in enumerate(shown, 1):
        # Compact format: rank, author, engagement, text, url
        engagement_str = f"{t['likes']}L {t['rts']}RT {t['replies']}Re"
        follower_str = f"{t['followers']:,}fol"
        text = t['text'].replace('\n', ' ')[:200]
        print(f"[{i}] @{t['username']} ({follower_str}, {engagement_str})")
        print(f"    {text}")
        print(f"    {t['url']}")
        print()

if __name__ == "__main__":
    main()
