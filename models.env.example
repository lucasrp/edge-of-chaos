# {{ AGENT_NAME }} — Default Models
# Copy this to secrets/models.env
# Each tool reads its model from here. Override per-tool as needed.

# LLM-as-judge for review-gate.py (quality gate before publishing)
EDGE_MODEL_REVIEW=gpt-4o

# Adversarial reviewer for edge-consult.py
EDGE_MODEL_CONSULT=gpt-4o

# Embedding model for search/RAG (embed.py)
EDGE_MODEL_EMBED=text-embedding-3-small

# Multi-turn dialogue (edge-dialogue.py)
EDGE_MODEL_DIALOGUE=gpt-4o

# Deep research (edge-deepresearch.py)
EDGE_MODEL_DEEPRESEARCH_OPENAI=gpt-4.1
EDGE_MODEL_DEEPRESEARCH_GEMINI=gemini-2.5-flash

# Adversarial research validation (edge-adversarial-research.py)
EDGE_MODEL_ADVERSARIAL_OPENAI=gpt-4.1
EDGE_MODEL_ADVERSARIAL_GEMINI=gemini-2.5-flash

# Meta-report generation
EDGE_MODEL_META=gpt-4o
