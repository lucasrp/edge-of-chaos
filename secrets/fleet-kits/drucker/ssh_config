# drucker — SSH config snippet
# Include with:  Include ~/edge/secrets/fleet-kits/drucker/ssh_config
# Or copy the keys to the deploy host and adjust IdentityFile paths.

Host roberto
    HostName 216.238.118.21
    User roberto
    IdentityFile ~/edge/secrets/fleet-kits/drucker/ssh_roberto
    IdentitiesOnly yes
    ServerAliveInterval 15
    ServerAliveCountMax 3

# Tunnel to assertia Postgres (read-only DB).
# Requires operator's key on lucas-pereira@assertia-vm-dev (already present).
# Open tunnel on demand:
#   ssh -f -N assertia-vm-dev-tunnel
# Then connect psql to localhost:15432.
Host assertia-vm-dev-tunnel
    HostName 74.249.102.195
    User lucas-pereira
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
    LocalForward 15432 pg-consorcio-eastus2-stg.postgres.database.azure.com:5432
    ServerAliveInterval 15
