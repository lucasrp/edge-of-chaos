# {{ AGENT_NAME }} — API Keys
# Copy this to secrets/keys.env and fill in your values.
# chmod 600 secrets/keys.env

# Required for: edge-consult, edge-deepresearch, edge-adversarial-research, review-gate, edge-dialogue
OPENAI_API_KEY=sk-your-key-here

# Required for: edge-fontes (web search via Exa)
EXA_API_KEY=your-exa-key-here

# Required for: edge-deepresearch, edge-adversarial-research (Gemini provider)
GEMINI_API_KEY=your-gemini-key-here

# Optional: xAI (Grok model for edge-consult)
# XAI_API_KEY=your-xai-key-here

# Optional: X/Twitter search
# X_BEARER_TOKEN=your-token
# X_API_KEY=your-key
# X_API_SECRET=your-secret
# X_ACCESS_TOKEN=your-token
# X_ACCESS_TOKEN_SECRET=your-secret

# Blog server (if applicable)
# BLOG_PORT=8080
# BLOG_AUTH_USER=admin
# BLOG_AUTH_PASS=changeme
