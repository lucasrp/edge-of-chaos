# agent.yaml — Spec declarativa de uma instância
# Campos REQUIRED não têm default. O resto é derivado automaticamente.
# Copie para agent.yaml e preencha os campos obrigatórios.

# --- Identidade (REQUIRED) ---
name: meu-agente               # REQUIRED: unique name (lowercase, hyphens ok)
codename: ma                    # REQUIRED: skill prefix (ex: /ma-research)
missao: "Describe the agent's mission in 1-2 sentences"  # REQUIRED
voice: "Direct, technical, detail-oriented"              # REQUIRED: tone of voice
dominio: "government"           # REQUIRED: work domain

# --- Derivados (defaults inteligentes — sobrescreva se quiser) ---
idioma: pt-BR
skill_prefix: ""                # default: = codename
tool_prefix: edge
edge_home: ""                   # default: ~/{codename}/
heartbeat_interval: 2h
blog_port: 8766
blog_host: "0.0.0.0"           # público por default (acessível de fora)
blog_auth_enabled: true         # protegido por login
blog_auth_user: admin           # change before deploy
blog_auth_pass: trocar123       # change before deploy

# --- Lifecycle hooks ---
pre_skill: config/pre-skill.md  # executado ANTES de cada skill (identidade, contexto, anti-redundância)
post_skill: config/post-skill.md # executado DEPOIS de cada skill (notify, strategy update, custom actions)

# --- Onboarding ---
onboarding_mode: true           # false depois de graduado

# --- Opcional ---
bio: ""                         # default: = missao
cognitive_profile: "Analytical. Decomposes problems, seeks structure."
knowledge_base: ""              # path local, URL git, ou URL https
public_url: ""                  # se blog público
repo_owner: ""                  # GitHub user/org
repo_name: ""                   # default: = name

# --- Secrets (NUNCA aqui — em .secrets ou env vars) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# EXA_API_KEY=...
