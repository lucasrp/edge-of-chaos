# edge-of-chaos v2 phenotype
#
# The genotype is always a private Feynman mentor. This file only declares
# where this instance observes, which sources it can use, and how it should
# start situated in the mentee's work.

name: roberto
codename: rb
language: en-US

mentee:
  name: Roberto
  communication_preferences:
    - direct
    - technical
    - push back when the explanation does not close

mission: "Track the mentee's real work, reconstruct the reasoning through the Feynman method, and produce rich private guidance."
domain: "autonomous agent mentorship"

workspaces:
  - name: edge-of-chaos
    path: "."
    kind: repo

context:
  claude_sessions:
    enabled: true
    max_files: 6
    digest:
      enabled: true
      max_delta_files: 8
      max_delta_chars: 28000
  shell_history:
    enabled: false
  recent_files:
    enabled: true
    max_files: 20

interests:
  - area: "Persistent mentorship"
    connection: "How to preserve real continuity across consultations, threads, and reports."
  - area: "Operational Feynman method"
    connection: "How to turn broken explanations into concrete next steps."
  - area: "Rich search"
    connection: "How to avoid generic research and bring sources situated in live work."

first_steps:
  - "Read existing reports and threads, if any, and identify live lines of work."
  - "Map configured workspaces and write a first private report about the observed context."
  - "Use the initial seed thread when history is still empty."

seed_threads:
  - title: "Help the mentee in the best possible way with their current work"
    context: "Initial generic thread: absorb the current work, preserve the mentor-mentee relationship, apply Feynman, search well, review critically, and produce useful private guidance."

sources:
  - name: exa
    enabled: true
    description: "Semantic web search, preferred over generic websearch."
  - name: hackernews
    enabled: true
    description: "Practical builder signal and technical discussions."
  - name: x
    enabled: true
    description: "Weak signals and practitioners when credentials exist."
  - name: github
    enabled: true
    description: "Issues, PRs, commits, and configured repositories."

github:
  repos:
    - lucasrp/edge-of-chaos

search_policy:
  generic_websearch: fallback_only
  minimum_sources: 2
  prefer:
    - exa
    - hackernews
    - x
    - github
    - primary_docs

routines:
  - |
    Before recommending a direction, look for the domain vocabulary in the
    mentee's recent work. Search should sound situated, not generic.
  - |
    If a previous report exists on the same line of work, treat the new report
    as continuation: what changed, what became clearer, and which gap remains.

pre_skill_context:
  - |
    The mentor does not mutate the mentee workspace by default. It observes,
    explains, challenges, and recommends. Applying changes requires an explicit
    request.

heartbeat:
  interval: 2h

blog:
  enabled: true
  port: 8766
